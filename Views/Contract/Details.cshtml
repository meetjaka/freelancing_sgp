@model SGP_Freelancing.Models.ViewModels.ContractDetailsViewModel
@{
    ViewData["Title"] = "Contract Details";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var isClient = User.IsInRole("Client");
    var isFreelancer = User.IsInRole("Freelancer");
}

<div class="space-y-8">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-3xl font-black text-slate-900 dark:text-white">@Model.Contract.ProjectTitle</h1>
            <p class="text-slate-500 dark:text-slate-400 mt-1">Contract #@Model.Contract.Id</p>
        </div>
        <div class="flex items-center gap-3">
            @{
                var statusColor = Model.Contract.Status switch {
                    "Active" => "bg-emerald-500/10 text-emerald-500 border-emerald-500/20",
                    "Completed" => "bg-indigo-500/10 text-indigo-500 border-indigo-500/20",
                    "Disputed" => "bg-red-500/10 text-red-500 border-red-500/20",
                    _ => "bg-slate-500/10 text-slate-500 border-slate-500/20"
                };
            }
            <span class="px-4 py-2 rounded-full text-sm font-bold border @statusColor">@Model.Contract.Status</span>
            
            @if (isFreelancer && Model.Contract.Status == "Active")
            {
                <a asp-controller="TimeTracking" asp-action="Timesheet" asp-route-contractId="@Model.Contract.Id"
                   class="flex items-center gap-2 px-4 py-2 bg-violet-500/10 text-violet-500 border border-violet-500/20 rounded-full text-sm font-bold hover:bg-violet-500/20 transition-all">
                    <i class="fas fa-clock"></i> Timesheet
                </a>
            }
            @if (isClient && Model.Contract.Status == "Active")
            {
                <a asp-controller="TimeTracking" asp-action="Timesheet" asp-route-contractId="@Model.Contract.Id"
                   class="flex items-center gap-2 px-4 py-2 bg-violet-500/10 text-violet-500 border border-violet-500/20 rounded-full text-sm font-bold hover:bg-violet-500/20 transition-all">
                    <i class="fas fa-clock"></i> View Timesheet
                </a>
            }
        </div>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left: Contract Info -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Contract Details Card -->
            <div class="bento-card p-6 space-y-4">
                <h2 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                    <i class="fas fa-file-contract text-indigo-500"></i> Contract Overview
                </h2>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                    <div class="bg-slate-50 dark:bg-white/5 rounded-xl p-4 text-center">
                        <p class="text-2xl font-black text-indigo-500">$@Model.Contract.Amount.ToString("N2")</p>
                        <p class="text-xs text-slate-500 mt-1">Total Amount</p>
                    </div>
                    <div class="bg-slate-50 dark:bg-white/5 rounded-xl p-4 text-center">
                        <p class="text-lg font-bold text-slate-900 dark:text-white">@Model.Contract.ClientName</p>
                        <p class="text-xs text-slate-500 mt-1">Client</p>
                    </div>
                    <div class="bg-slate-50 dark:bg-white/5 rounded-xl p-4 text-center">
                        <p class="text-lg font-bold text-slate-900 dark:text-white">@Model.Contract.FreelancerName</p>
                        <p class="text-xs text-slate-500 mt-1">Freelancer</p>
                    </div>
                    <div class="bg-slate-50 dark:bg-white/5 rounded-xl p-4 text-center">
                        <p class="text-lg font-bold text-slate-900 dark:text-white">@Model.Contract.StartDate.ToString("MMM dd, yyyy")</p>
                        <p class="text-xs text-slate-500 mt-1">Start Date</p>
                    </div>
                </div>
            </div>

            <!-- Milestones Section -->
            <div class="bento-card p-6 space-y-4" id="milestones-section">
                <div class="flex items-center justify-between">
                    <h2 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                        <i class="fas fa-tasks text-emerald-500"></i> Milestones
                    </h2>
                    @if (isClient && Model.Contract.Status == "Active")
                    {
                        <button onclick="document.getElementById('addMilestoneModal').classList.remove('hidden')"
                                class="px-4 py-2 bg-indigo-500 text-white rounded-xl text-sm font-bold hover:bg-indigo-400 transition-all shadow-lg shadow-indigo-500/20">
                            <i class="fas fa-plus mr-1"></i> Add Milestone
                        </button>
                    }
                </div>

                <div id="milestones-list" class="space-y-3">
                    <!-- Milestones loaded via JS -->
                    <div class="text-center py-8 text-slate-400">
                        <i class="fas fa-spinner fa-spin text-3xl mb-2"></i>
                        <p>Loading milestones...</p>
                    </div>
                </div>
            </div>

            <!-- Payment Transactions -->
            <div class="bento-card p-6 space-y-4">
                <h2 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                    <i class="fas fa-receipt text-amber-500"></i> Payment History
                </h2>
                @if (Model.Transactions?.Any() == true)
                {
                    <div class="overflow-auto">
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="text-left text-slate-500 border-b border-slate-200 dark:border-white/10">
                                    <th class="pb-3 font-medium">Date</th>
                                    <th class="pb-3 font-medium">Type</th>
                                    <th class="pb-3 font-medium">Amount</th>
                                    <th class="pb-3 font-medium">Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 dark:divide-white/5">
                                @foreach (var tx in Model.Transactions)
                                {
                                    <tr class="hover:bg-slate-50 dark:hover:bg-white/5 transition-colors">
                                        <td class="py-3 text-slate-700 dark:text-slate-300">@tx.CreatedAt.ToString("MMM dd, yyyy")</td>
                                        <td class="py-3"><span class="px-2 py-1 bg-indigo-500/10 text-indigo-500 rounded-lg text-xs font-bold">@tx.Type</span></td>
                                        <td class="py-3 font-bold text-slate-900 dark:text-white">$@tx.Amount.ToString("N2")</td>
                                        <td class="py-3"><span class="px-2 py-1 bg-emerald-500/10 text-emerald-500 rounded-lg text-xs font-bold">@tx.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-center text-slate-400 py-4">No transactions yet</p>
                }
            </div>
        </div>

        <!-- Right Sidebar -->
        <div class="space-y-6">
            <!-- Actions Card -->
            <div class="bento-card p-6 space-y-4">
                <h3 class="font-bold text-slate-900 dark:text-white">Actions</h3>
                @if (Model.Contract.Status == "Active")
                {
                    @if (isClient)
                    {
                        <form asp-controller="Contract" asp-action="Complete" method="post">
                            <input type="hidden" name="id" value="@Model.Contract.Id" />
                            <button type="submit" class="w-full px-4 py-3 bg-emerald-500 text-white rounded-xl font-bold hover:bg-emerald-400 transition-all shadow-lg shadow-emerald-500/20">
                                <i class="fas fa-check-circle mr-2"></i> Complete Contract
                            </button>
                        </form>
                    }
                    
                    <button onclick="document.getElementById('disputeModal').classList.remove('hidden')"
                            class="w-full px-4 py-3 bg-red-500/10 text-red-500 border border-red-500/20 rounded-xl font-bold hover:bg-red-500/20 transition-all">
                        <i class="fas fa-exclamation-triangle mr-2"></i> Raise Dispute
                    </button>
                }

                @if (Model.CanReview)
                {
                    <a asp-controller="Review" asp-action="Create" asp-route-contractId="@Model.Contract.Id"
                       class="w-full block text-center px-4 py-3 bg-amber-500/10 text-amber-500 border border-amber-500/20 rounded-xl font-bold hover:bg-amber-500/20 transition-all">
                        <i class="fas fa-star mr-2"></i> Leave Review
                    </a>
                }
            </div>

            <!-- Dispute History -->
            <div class="bento-card p-6 space-y-4" id="disputes-section">
                <h3 class="font-bold text-slate-900 dark:text-white flex items-center gap-2">
                    <i class="fas fa-gavel text-red-400"></i> Disputes
                </h3>
                <div id="disputes-list" class="space-y-2">
                    <p class="text-sm text-slate-400 text-center py-2">No disputes raised</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Milestone Modal -->
<div id="addMilestoneModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-white dark:bg-[#15171e] rounded-2xl shadow-2xl w-full max-w-md border border-slate-200 dark:border-white/10 p-6 space-y-4">
        <div class="flex items-center justify-between">
            <h3 class="text-lg font-bold text-slate-900 dark:text-white">Add Milestone</h3>
            <button onclick="document.getElementById('addMilestoneModal').classList.add('hidden')" class="text-slate-400 hover:text-slate-600"><i class="fas fa-times"></i></button>
        </div>
        <form asp-controller="Milestone" asp-action="Create" method="post" class="space-y-4">
            <input type="hidden" name="ContractId" value="@Model.Contract.Id" />
            <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Title</label>
                <input type="text" name="Title" required class="w-full px-4 py-2 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none text-slate-900 dark:text-white" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Description</label>
                <textarea name="Description" rows="3" class="w-full px-4 py-2 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none text-slate-900 dark:text-white"></textarea>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Amount ($)</label>
                    <input type="number" step="0.01" name="Amount" required class="w-full px-4 py-2 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none text-slate-900 dark:text-white" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Due Date</label>
                    <input type="date" name="DueDate" class="w-full px-4 py-2 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none text-slate-900 dark:text-white" />
                </div>
            </div>
            <button type="submit" class="w-full px-4 py-3 bg-indigo-500 text-white rounded-xl font-bold hover:bg-indigo-400 transition-all">Create Milestone</button>
        </form>
    </div>
</div>

<!-- Raise Dispute Modal -->
<div id="disputeModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-white dark:bg-[#15171e] rounded-2xl shadow-2xl w-full max-w-md border border-slate-200 dark:border-white/10 p-6 space-y-4">
        <div class="flex items-center justify-between">
            <h3 class="text-lg font-bold text-red-500">Raise a Dispute</h3>
            <button onclick="document.getElementById('disputeModal').classList.add('hidden')" class="text-slate-400 hover:text-slate-600"><i class="fas fa-times"></i></button>
        </div>
        <form asp-controller="Dispute" asp-action="Create" method="post" class="space-y-4">
            <input type="hidden" name="ContractId" value="@Model.Contract.Id" />
            <div>
                <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Reason for dispute</label>
                <textarea name="Reason" rows="4" required class="w-full px-4 py-2 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl focus:ring-2 focus:ring-red-500 outline-none text-slate-900 dark:text-white" placeholder="Describe the issue..."></textarea>
            </div>
            <button type="submit" class="w-full px-4 py-3 bg-red-500 text-white rounded-xl font-bold hover:bg-red-400 transition-all">Submit Dispute</button>
        </form>
    </div>
</div>

@section Scripts {
<script>
    // Load milestones dynamically
    async function loadMilestones() {
        try {
            const response = await fetch('/api/contract/@Model.Contract.Id/milestones');
            if (!response.ok) throw new Error('Failed');
            const milestones = await response.json();
            renderMilestones(milestones);
        } catch {
            // Fallback: just show the page-loaded data
            const container = document.getElementById('milestones-list');
            container.innerHTML = `<p class="text-center text-slate-400 py-4">No milestones yet. ${@(isClient ? "true" : "false") ? 'Click "Add Milestone" to get started.' : ''}</p>`;
        }
    }

    function renderMilestones(milestones) {
        const container = document.getElementById('milestones-list');
        if (!milestones || milestones.length === 0) {
            container.innerHTML = `<p class="text-center text-slate-400 py-4">No milestones yet</p>`;
            return;
        }
        const statusConfig = {
            'Pending': { color: 'text-slate-400 bg-slate-100 dark:bg-white/5', icon: 'fa-circle', dot: 'bg-slate-400' },
            'Funded': { color: 'text-blue-500 bg-blue-50 dark:bg-blue-500/10', icon: 'fa-wallet', dot: 'bg-blue-500' },
            'InProgress': { color: 'text-amber-500 bg-amber-50 dark:bg-amber-500/10', icon: 'fa-spinner', dot: 'bg-amber-500' },
            'Submitted': { color: 'text-violet-500 bg-violet-50 dark:bg-violet-500/10', icon: 'fa-paper-plane', dot: 'bg-violet-500' },
            'Approved': { color: 'text-emerald-500 bg-emerald-50 dark:bg-emerald-500/10', icon: 'fa-check-circle', dot: 'bg-emerald-500' },
            'Disputed': { color: 'text-red-500 bg-red-50 dark:bg-red-500/10', icon: 'fa-exclamation-triangle', dot: 'bg-red-500' }
        };
        container.innerHTML = milestones.map((m, i) => {
            const cfg = statusConfig[m.status] || statusConfig['Pending'];
            return `<div class="flex items-start gap-4 p-4 rounded-xl border border-slate-200 dark:border-white/5 hover:border-indigo-500/30 transition-all">
                <div class="w-8 h-8 rounded-full ${cfg.dot} flex items-center justify-center text-white text-xs font-bold flex-shrink-0">${i+1}</div>
                <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-2">
                        <h4 class="font-bold text-slate-900 dark:text-white truncate">${m.title}</h4>
                        <span class="px-2 py-1 rounded-lg text-xs font-bold ${cfg.color} flex-shrink-0"><i class="fas ${cfg.icon} mr-1"></i>${m.status}</span>
                    </div>
                    <p class="text-sm text-slate-500 mt-1">${m.description || ''}</p>
                    <div class="flex items-center gap-4 mt-2 text-sm"><span class="font-bold text-indigo-500">$${m.amount.toFixed(2)}</span>${m.dueDate ? `<span class="text-slate-400">Due: ${new Date(m.dueDate).toLocaleDateString()}</span>` : ''}</div>
                </div>
            </div>`;
        }).join('');
    }

    // Load milestones on page load - using the server rendered data as fallback
    document.addEventListener('DOMContentLoaded', loadMilestones);
</script>
}
