@using System.Security.Claims
@model List<SGP_Freelancing.Models.DTOs.MessageDto>
@{
    ViewData["Title"] = "Messages";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<style>
    .message-item {
        transition: all 0.2s ease;
    }
    .message-item:hover {
        transform: translateX(4px);
    }
    .message-avatar {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    .unread-indicator {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
        }
        50% {
            opacity: .5;
        }
    }
</style>

<!-- Modern Messages Interface -->
<div class="h-[calc(100vh-120px)]">
    <div class="bento-card h-full flex flex-col overflow-hidden">
        
        <!-- Header -->
        <div class="px-6 py-4 border-b border-white/5 bg-[#12141a]">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-2xl font-bold text-white flex items-center gap-3">
                        <div class="w-10 h-10 bg-indigo-500/10 border border-indigo-500/20 rounded-xl flex items-center justify-center shadow-[0_0_15px_rgba(99,102,241,0.2)]">
                            <i class="fas fa-envelope text-indigo-400"></i>
                        </div>
                        Messages <span class="text-indigo-400">✦</span>
                    </h1>
                    <p class="text-sm text-slate-400 mt-1">@Model.Count conversation@(Model.Count != 1 ? "s" : "")</p>
                </div>
                
                @if (ViewBag.UnreadCount > 0)
                {
                    <div class="flex items-center gap-2 px-4 py-2 bg-red-500/10 text-red-400 rounded-xl border border-red-500/20">
                        <span class="relative flex h-3 w-3">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
                        </span>
                        <span class="font-bold text-sm">@ViewBag.UnreadCount Unread</span>
                    </div>
                }
            </div>
        </div>

        <!-- Search & Filter Bar -->
        <div class="px-6 py-3 border-b border-white/5 bg-[#15171e]/50">
            <div class="flex items-center gap-3">
                <div class="relative flex-1">
                    <i class="fas fa-search absolute left-4 top-1/2 transform -translate-y-1/2 text-slate-500"></i>
                    <input type="text" placeholder="Search conversations..." 
                           class="w-full pl-10 pr-4 py-2 bg-[#12141a] border border-white/10 rounded-xl text-sm text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500/50 transition-all font-medium backdrop-blur-sm shadow-inner"
                           id="searchMessages">
                </div>
                <button class="px-4 py-2 text-sm font-medium text-slate-300 hover:text-white hover:bg-white/10 border border-white/5 hover:border-white/10 rounded-xl transition-all flex items-center gap-2 bg-[#12141a]">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
                    </svg>
                    Filter
                </button>
            </div>
        </div>

        <!-- Messages List -->
        <div class="flex-1 overflow-y-auto px-4 py-4" id="messagesList">
            @if (Model.Any())
            {
                <div class="space-y-2">
                    @foreach (var message in Model)
                    {
                        var otherUserId = message.SenderId == User.FindFirstValue(ClaimTypes.NameIdentifier) 
                            ? message.ReceiverId 
                            : message.SenderId;
                        var otherUserName = message.SenderId == User.FindFirstValue(ClaimTypes.NameIdentifier) 
                            ? message.ReceiverName 
                            : message.SenderName;
                        var initial = string.IsNullOrEmpty(otherUserName) ? "?" : otherUserName[0].ToString().ToUpper();
                        var isUnread = !message.IsRead;

                        <a asp-action="Conversation" asp-route-userId="@otherUserId" 
                           class="message-item flex items-center gap-4 p-4 rounded-xl hover:bg-white/5 transition-all border border-transparent hover:border-indigo-500/30 group @(isUnread ? "bg-indigo-500/5 border-indigo-500/20" : "")"
                           data-message-text="@otherUserName @message.Content">
                            
                            <!-- Avatar -->
                            <div class="relative flex-shrink-0">
                                <div class="w-12 h-12 rounded-full message-avatar flex items-center justify-center text-white text-lg font-bold shadow-md group-hover:scale-110 transition-transform">
                                    @initial
                                </div>
                                @if (isUnread)
                                {
                                    <span class="unread-indicator absolute -top-1 -right-1 w-4 h-4 bg-indigo-500 rounded-full border-2 border-[#15171e] shadow-[0_0_10px_rgba(99,102,241,0.8)]"></span>
                                }
                            </div>

                            <!-- Message Content -->
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center justify-between gap-2 mb-1">
                                    <h3 class="text-base font-bold text-white truncate group-hover:text-indigo-400 transition-colors">
                                        @otherUserName
                                    </h3>
                                    <span class="text-xs text-slate-500 whitespace-nowrap flex items-center gap-1">
                                        <i class="far fa-clock text-[10px]"></i>
                                        @message.CreatedAt.ToString("MMM dd, h:mm tt")
                                    </span>
                                </div>
                                <p class="text-sm text-slate-400 truncate @(isUnread ? "font-bold text-white" : "")">
                                    @if (message.SenderId == User.FindFirstValue(ClaimTypes.NameIdentifier))
                                    {
                                        <span class="text-indigo-400">You: </span>
                                    }
                                    @(message.Content.Length > 70 ? message.Content.Substring(0, 70) + "..." : message.Content)
                                </p>
                            </div>

                            <!-- Status Badge -->
                            <div class="flex-shrink-0">
                                @if (isUnread)
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-indigo-500/20 border border-indigo-500/30 text-indigo-400 text-[10px] uppercase font-bold tracking-wider rounded-full shadow-[0_0_10px_rgba(99,102,241,0.2)]">
                                        NEW
                                    </span>
                                }
                                else
                                {
                                    <i class="fas fa-chevron-right text-slate-600 opacity-0 group-hover:opacity-100 transition-opacity"></i>
                                }
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <!-- Empty State -->
                <div class="flex flex-col items-center justify-center h-full text-center py-12">
                    <div class="w-24 h-24 mb-6 rounded-3xl bg-white/5 border border-white/10 flex items-center justify-center shadow-inner">
                        <i class="fas fa-comments text-slate-500 text-4xl"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">No messages yet</h3>
                    <p class="text-slate-400 mb-6 max-w-sm">Start connecting with freelancers and clients to begin conversations</p>
                    <a asp-controller="Project" asp-action="Index" class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-500 hover:bg-indigo-400 text-white font-bold rounded-full transition-all shadow-[0_0_20px_rgba(99,102,241,0.3)]">
                        Browse Projects
                    </a>
                </div>
            }
        </div>

        <!-- Quick Stats Footer -->
        @if (Model.Any())
        {
            <div class="px-6 py-3 border-t border-white/5 bg-[#12141a]">
                <div class="flex items-center justify-between text-xs text-slate-400 font-bold">
                    <div class="flex items-center gap-4">
                        <span class="flex items-center gap-1">
                            <i class="fas fa-list text-[10px] text-slate-500"></i>
                            Total: <span class="text-slate-300">@Model.Count</span>
                        </span>
                        @if (ViewBag.UnreadCount > 0)
                        {
                            <span class="flex items-center gap-1 text-red-400">
                                <span class="w-2 h-2 bg-red-500 rounded-full shadow-[0_0_8px_rgba(239,68,68,0.8)]"></span>
                                Unread: <span>@ViewBag.UnreadCount</span>
                            </span>
                        }
                    </div>
                    <button class="hover:text-indigo-400 transition-colors flex items-center gap-1" onclick="location.reload()">
                        <i class="fas fa-sync-alt text-[10px]"></i>
                        Refresh
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Search functionality
        document.getElementById('searchMessages')?.addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const messages = document.querySelectorAll('[data-message-text]');
            
            messages.forEach(message => {
                const text = message.getAttribute('data-message-text').toLowerCase();
                if (text.includes(searchTerm)) {
                    message.style.display = 'flex';
                } else {
                    message.style.display = 'none';
                }
            });
        });

        // Auto-refresh every 30 seconds
        setInterval(() => {
            const unreadBadge = document.querySelector('.animate-ping');
            if (unreadBadge) {
                // Visual indicator that refresh is happening
                unreadBadge.style.opacity = '0.5';
                setTimeout(() => {
                    unreadBadge.style.opacity = '1';
                }, 500);
            }
        }, 30000);
    </script>
}
