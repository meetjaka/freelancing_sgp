@using System.Security.Claims
@model SGP_Freelancing.Models.DTOs.PagedResult<SGP_Freelancing.Models.DTOs.MessageDto>
@{
    ViewData["Title"] = "Conversation";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var otherUserId = ViewBag.OtherUserId as string;
    var firstMessage = Model.Items.FirstOrDefault();
    var otherUserName = firstMessage?.SenderId == currentUserId 
        ? firstMessage?.ReceiverName 
        : firstMessage?.SenderName;
    var canSend = ViewBag.CanSend as bool? ?? true;
    var chatStatusMessage = ViewBag.ChatStatusMessage as string;
}

<style>
    .wa-shell {
        height: calc(100vh - 110px);
        background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
    }

    .wa-header {
        background: linear-gradient(135deg, #1e293b 0%, #4f46e5 100%);
    }

    .wa-message-in {
        background: #ffffff;
        border: 1px solid rgba(99, 102, 241, 0.15);
    }

    .wa-message-out {
        background: #e0e7ff;
        border: 1px solid rgba(99, 102, 241, 0.25);
    }

    .wa-footer {
        background: #f8fafc;
    }

    .file-pill {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(15, 23, 42, 0.06);
        border: 1px solid rgba(15, 23, 42, 0.1);
        border-radius: 0.75rem;
        padding: 0.5rem 0.65rem;
        text-decoration: none;
        color: #334155;
        margin-top: 0.5rem;
        max-width: 100%;
    }

    .file-pill:hover {
        background: rgba(79, 70, 229, 0.12);
        border-color: rgba(79, 70, 229, 0.28);
    }

    .message-row {
        margin-bottom: 0.75rem;
        display: flex;
    }

    .message-row.sent {
        justify-content: end;
    }

    .message-row.received {
        justify-content: start;
    }
</style>

<div class="wa-shell w-full rounded-none overflow-hidden border-y border-slate-200 dark:border-white/10">
    <div class="wa-header text-white px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-4 min-w-0">
            <a href="/Message" class="w-10 h-10 rounded-full bg-white/20 border-none text-white flex items-center justify-center transition-all hover:bg-white/30 cursor-pointer">
                <i class="fas fa-arrow-left"></i>
            </a>
            @if (!string.IsNullOrEmpty(otherUserName))
            {
                var initial = otherUserName[0].ToString().ToUpper();
                <div class="w-11 h-11 rounded-full bg-white/25 text-white flex items-center justify-center text-base font-bold shrink-0">@initial</div>
                <div class="min-w-0">
                    <h1 class="text-lg font-bold truncate">@otherUserName</h1>
                    <p class="text-xs opacity-90">online</p>
                </div>
            }
        </div>
        <div class="flex items-center gap-3 text-white/90">
            <form asp-action="DeleteConversation" method="post" onsubmit="return confirm('Delete entire chat with this user? This cannot be undone.');" class="inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="otherUserId" value="@otherUserId" />
                <button type="submit" class="text-xs px-3 py-1.5 rounded-full bg-white/15 hover:bg-white/25 transition-all font-semibold">
                    <i class="fas fa-trash-alt mr-1"></i> Delete Chat
                </button>
            </form>
        </div>
    </div>
    
    @if (!string.IsNullOrWhiteSpace(chatStatusMessage))
    {
        <div class="bg-amber-50 border border-amber-200 px-6 py-3 text-amber-700 font-medium text-sm">
            @chatStatusMessage
        </div>
    }

    <div id="messageContainer" class="h-[calc(100%-140px)] overflow-y-auto px-5 py-5">
        @if (Model.Items.Any())
        {
            @foreach (var message in Model.Items.OrderBy(m => m.CreatedAt))
            {
                var isCurrentUser = message.SenderId == currentUserId;
                
                <div class="mb-3 flex @(isCurrentUser ? "justify-end" : "justify-start") items-start gap-2">
                    @if (isCurrentUser)
                    {
                        <form asp-action="DeleteMessage" method="post" onsubmit="return confirm('Delete this message?');" class="pt-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="messageId" value="@message.Id" />
                            <input type="hidden" name="otherUserId" value="@otherUserId" />
                            <button type="submit" class="w-7 h-7 rounded-full text-slate-500 hover:text-rose-600 hover:bg-rose-50 transition-all" title="Delete message">
                                <i class="fas fa-trash text-xs"></i>
                            </button>
                        </form>
                    }
                    <div class="@(isCurrentUser ? "wa-message-out" : "wa-message-in") max-w-[70%] px-4 py-2.5 rounded-lg shadow-sm">
                        <p class="text-[15px] leading-relaxed text-slate-800 m-0 break-words">@message.Content</p>
                        @if (message.Attachments != null && message.Attachments.Any())
                        {
                            @foreach (var attachment in message.Attachments)
                            {
                                <a class="file-pill" href="/Message/DownloadAttachment/@attachment.Id" title="@attachment.FileName">
                                    <i class="fas fa-paperclip text-indigo-600"></i>
                                    <span class="truncate text-sm font-medium">@attachment.FileName</span>
                                    <span class="text-xs text-slate-500">(@Math.Round(attachment.FileSize / 1024.0, 1) KB)</span>
                                </a>
                            }
                        }
                        <span class="text-[11px] text-slate-500 mt-1 block text-right">@message.CreatedAt.ToString("hh:mm tt")</span>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="h-full flex items-center justify-center text-center text-slate-500">
                <div>
                    <div class="text-5xl mb-4 opacity-40 text-[#128c7e]">
                        <i class="fas fa-comment-dots"></i>
                    </div>
                    <p>No messages yet. Start the conversation!</p>
                </div>
            </div>
        }
    </div>
    
    <div class="wa-footer px-5 py-3 border-t border-slate-200">
        <div id="sendError" class="hidden mb-3 px-4 py-2 rounded-lg bg-rose-50 dark:bg-rose-900/20 border border-rose-200 dark:border-rose-700 text-rose-700 dark:text-rose-300 text-sm font-medium"></div>
        <form id="messageForm" class="flex gap-3 items-center">
            @Html.AntiForgeryToken()
            <input type="file" id="fileInput" class="hidden" />
            <button id="fileUploadButton" type="button" class="w-11 h-11 rounded-full bg-slate-200 hover:bg-slate-300 text-slate-600 text-base flex items-center justify-center transition-all" @(canSend ? "" : "disabled")>
                <i class="fas fa-paperclip"></i>
            </button>
            <input type="text" id="messageInput" class="flex-grow border border-slate-300 bg-white text-slate-800 placeholder-slate-400 rounded-full px-5 py-3 text-base focus:border-indigo-600 focus:outline-none focus:ring-2 focus:ring-indigo-300/50 transition-all" placeholder="Type your message..." required @(canSend ? "" : "disabled") />
            <button type="submit" class="w-12 h-12 rounded-full bg-indigo-600 hover:bg-indigo-700 border-none text-white text-lg flex items-center justify-center transition-all active:scale-95 flex-shrink-0 disabled:opacity-50 disabled:cursor-not-allowed" @(canSend ? "" : "disabled")>
                <i class="fas fa-paper-plane"></i>
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        const receiverId = '@otherUserId';
        const sendError = document.getElementById('sendError');
        const fileUploadButton = document.getElementById('fileUploadButton');
        const fileInput = document.getElementById('fileInput');
        const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        
        // Initialize SignalR connection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

        connection.on("ReceiveMessage", function (senderId, senderName, message, timestamp) {
            if (senderId === receiverId) {
                appendMessage({ senderName, content: message, timestamp, isCurrentUser: false });
                scrollToBottom();
            }
        });

        connection.on("ReceiveFileMessage", function (senderId, senderName, fileName, fileUrl, caption, timestamp) {
            if (senderId === receiverId) {
                appendMessage({
                    senderName,
                    content: caption || ('Shared a file: ' + fileName),
                    timestamp,
                    isCurrentUser: false,
                    attachment: { fileName, fileUrl }
                });
                scrollToBottom();
            }
        });

        connection.start().catch(function (err) {
            console.error(err.toString());
        });

        // Handle form submission
        document.getElementById('messageForm').addEventListener('submit', function(e) {
            e.preventDefault();

            if (sendError) {
                sendError.classList.add('hidden');
                sendError.textContent = '';
            }

            if (!@canSend.ToString().ToLower()) {
                return;
            }
            
            const messageInput = document.getElementById('messageInput');
            const message = messageInput.value.trim();
            
            if (message) {
                // Save to database first (authorization + persistence)
                const payload = new URLSearchParams();
                payload.append('ReceiverId', receiverId);
                payload.append('Subject', 'Project Discussion');
                payload.append('Content', message);
                if (antiForgeryToken) {
                    payload.append('__RequestVerificationToken', antiForgeryToken);
                }

                fetch('/Message/Send', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                    },
                    body: payload.toString()
                })
                .then(async response => {
                    const contentType = response.headers.get('content-type') || '';
                    if (contentType.includes('application/json')) {
                        return response.json();
                    }

                    const text = await response.text();
                    return { success: false, message: text || 'Unable to send message.' };
                })
                .then(data => {
                    if (data.success) {
                        // Broadcast in real-time only after successful save
                        connection.invoke("SendMessage", receiverId, message).catch(function (err) {
                            console.error(err.toString());
                        });

                        appendMessage({ senderName: 'You', content: message, timestamp: new Date(), isCurrentUser: true });
                        messageInput.value = '';
                        scrollToBottom();
                    } else if (sendError) {
                        sendError.textContent = data.message || 'Unable to send message.';
                        sendError.classList.remove('hidden');
                    }
                })
                .catch(() => {
                    if (sendError) {
                        sendError.textContent = 'Network error while sending message.';
                        sendError.classList.remove('hidden');
                    }
                });
            }
        });

        if (fileUploadButton && fileInput) {
            fileUploadButton.addEventListener('click', function() {
                if (!@canSend.ToString().ToLower()) {
                    return;
                }
                fileInput.click();
            });

            fileInput.addEventListener('change', function() {
                const selectedFile = fileInput.files?.[0];
                if (!selectedFile || !@canSend.ToString().ToLower()) {
                    return;
                }

                if (sendError) {
                    sendError.classList.add('hidden');
                    sendError.textContent = '';
                }

                const caption = document.getElementById('messageInput').value.trim();
                const formData = new FormData();
                formData.append('receiverId', receiverId);
                formData.append('file', selectedFile);
                formData.append('caption', caption);
                if (antiForgeryToken) {
                    formData.append('__RequestVerificationToken', antiForgeryToken);
                }

                fetch('/Message/UploadFile', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (!data.success) {
                        throw new Error(data.message || 'Unable to upload file.');
                    }

                    const attachmentUrl = '/Message/DownloadAttachment/' + data.attachment.id;
                    appendMessage({
                        senderName: 'You',
                        content: data.sentMessage?.content || ('Shared a file: ' + selectedFile.name),
                        timestamp: new Date(),
                        isCurrentUser: true,
                        attachment: {
                            fileName: data.attachment.fileName,
                            fileUrl: attachmentUrl
                        }
                    });

                    connection.invoke('SendFileMessage', receiverId, data.attachment.fileName, attachmentUrl, data.sentMessage?.content || caption).catch(function (err) {
                        console.error(err.toString());
                    });

                    document.getElementById('messageInput').value = '';
                    fileInput.value = '';
                    scrollToBottom();
                })
                .catch(error => {
                    if (sendError) {
                        sendError.textContent = error.message || 'Failed to upload file.';
                        sendError.classList.remove('hidden');
                    }
                });
            });
        }

        function appendMessage({ senderName, content, timestamp, isCurrentUser, attachment }) {
            const container = document.getElementById('messageContainer');
            const messageDiv = document.createElement('div');
            messageDiv.className = `message-row ${isCurrentUser ? 'sent' : 'received'}`;
            
            const time = new Date(timestamp).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
            const safeContent = (content || '').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            let attachmentHtml = '';

            if (attachment?.fileName && attachment?.fileUrl) {
                const safeFileName = attachment.fileName.replace(/</g, '&lt;').replace(/>/g, '&gt;');
                const safeFileUrl = attachment.fileUrl.replace(/"/g, '&quot;');
                attachmentHtml = `
                    <a class="file-pill" href="${safeFileUrl}" target="_blank" rel="noopener noreferrer">
                        <i class="fas fa-paperclip text-indigo-600"></i>
                        <span class="truncate text-sm font-medium">${safeFileName}</span>
                    </a>
                `;
            }
            
            messageDiv.innerHTML = `
                <div class="${isCurrentUser ? 'wa-message-out' : 'wa-message-in'} max-w-[70%] px-4 py-2.5 rounded-lg shadow-sm">
                    <p class="text-[15px] leading-relaxed text-slate-800 m-0 break-words">${safeContent}</p>
                    ${attachmentHtml}
                    <span class="text-[11px] text-slate-500 mt-1 block text-right">${time}</span>
                </div>
            `;
            
            container.appendChild(messageDiv);
        }

        function scrollToBottom() {
            const container = document.getElementById('messageContainer');
            container.scrollTop = container.scrollHeight;
        }

        // Scroll to bottom on page load
        scrollToBottom();
    </script>
}
