<!-- Process Section - Dark Bento Box Flow -->
<div class="bg-slate-50 dark:bg-[#0B1120] py-24 transition-colors duration-500 relative">
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-slate-200 dark:via-white/10 to-transparent"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-16 max-w-2xl mx-auto">
            <h2 class="text-4xl lg:text-5xl font-black text-slate-900 dark:text-white mb-4 tracking-tight">How it works</h2>
            <p class="text-lg text-slate-600 dark:text-slate-400 font-medium">From idea to execution in three simple, secure steps.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative mt-12">
            
            <!-- Connecting Line -->
            <div class="hidden md:block absolute top-[50%] -translate-y-[50%] left-[15%] right-[15%] h-1 bg-gradient-to-r from-transparent via-indigo-500/20 to-transparent rounded-full pointer-events-none"></div>

            <!-- Step 1 -->
