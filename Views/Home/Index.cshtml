@{
    ViewData["Title"] = "Home Page";
    ViewData["BodyClass"] = "homepage";
    var totalProjects = ViewBag.TotalProjects ?? 0;
    var totalFreelancers = ViewBag.TotalFreelancers ?? 0;
    var totalClients = ViewBag.TotalClients ?? 0;
    var latestProjectTitle = ViewBag.LatestProjectTitle as string ?? "New project";
    var latestProjectBudget = ViewBag.LatestProjectBudget ?? 0m;
    var latestProjectCategory = ViewBag.LatestProjectCategory as string ?? "Projects";
    var latestProjectStatus = ViewBag.LatestProjectStatus as string ?? "Open";
    var latestContractAmount = ViewBag.LatestContractAmount ?? 0m;
}

<style>
    @@keyframes float {
        0%, 100% { transform: translateY(0px) rotate(0deg); }
        50% { transform: translateY(-15px) rotate(1deg); }
    }
    @@keyframes float-delayed {
        0%, 100% { transform: translateY(0px) rotate(0deg); }
        50% { transform: translateY(-10px) rotate(-1deg); }
    }
    @@keyframes float-slow {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-8px); }
    }
    @@keyframes pulse-glow {
        0%, 100% { opacity: 0.3; transform: scale(1); }
        50% { opacity: 0.6; transform: scale(1.05); }
    }
    @@keyframes slide-up {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@keyframes gradient-shift {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    .hero-animate { animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }
    .hero-animate-delay-1 { animation-delay: 0.15s; }
    .hero-animate-delay-2 { animation-delay: 0.3s; }
    .hero-animate-delay-3 { animation-delay: 0.45s; }
    .hero-animate-delay-4 { animation-delay: 0.6s; }
    .hero-animate-delay-5 { animation-delay: 0.75s; }
    .hero-float { animation: float 6s ease-in-out infinite; }
    .hero-float-delayed { animation: float-delayed 7s ease-in-out infinite; }
    .hero-float-slow { animation: float-slow 8s ease-in-out infinite; }
    .hero-gradient-text {
        background: linear-gradient(135deg, #818CF8, #C084FC, #F472B6);
        background-size: 300% 300%;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: gradient-shift 6s ease infinite;
    }
    .search-glow:focus-within {
        box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.5), 0 0 40px rgba(99, 102, 241, 0.2);
    }
    
    /* Deep Glassmorphism matching reference image */
    .glass-badge {
        background: rgba(30, 30, 45, 0.7);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255,255,255,0.1);
    }
    
    html.dark .glass-badge {
        background: rgba(20, 20, 35, 0.85);
    }
</style>

<!-- Hero Section -->
<div class="relative min-h-[85vh] flex items-center overflow-hidden pt-32 pb-20 bg-slate-50 dark:bg-[#05050A] transition-colors duration-500">
    
    <!-- Animated Background Deep Space Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <!-- Glowing Orbs -->
        <div class="absolute top-[-10%] left-[-10%] w-[600px] h-[600px] rounded-full bg-indigo-500/10 dark:bg-indigo-600/10 blur-[100px]" style="animation: pulse-glow 8s ease-in-out infinite;"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[800px] h-[800px] rounded-full bg-purple-500/10 dark:bg-purple-600/10 blur-[120px]" style="animation: pulse-glow 12s ease-in-out infinite 2s;"></div>
        
        <!-- Ambient Grid -->
        <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.05]" style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 50px 50px; mask-image: radial-gradient(circle at center, black, transparent 80%); -webkit-mask-image: radial-gradient(circle at center, black, transparent 80%);"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-8 items-center">
            
            <!-- Left Content -->
            <div class="max-w-2xl">
                <!-- Status Pill -->
                <div class="hero-animate inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white dark:bg-white/[0.03] backdrop-blur-md border border-slate-200 dark:border-white/10 shadow-sm mb-8">
                    <span class="relative flex h-2.5 w-2.5">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
                    </span>
                    <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Over 10,000 top freelancers online</span>
                </div>

                <h1 class="hero-animate hero-animate-delay-1 text-5xl md:text-[4rem] lg:text-[4.5rem] font-black text-slate-900 dark:text-white leading-[1.05] mb-6 tracking-tighter">
                    Unlock elite <br>
                    <span class="hero-gradient-text pb-2">freelance talent</span> <br>
                    for your next leap.
                </h1>
                
                <p class="hero-animate hero-animate-delay-2 text-lg md:text-xl text-slate-600 dark:text-slate-400 font-normal mb-10 max-w-lg leading-relaxed">
                    Instantly connect with world-class professionals. Build, design, and scale your wildest ideas today.
                </p>
                
                <!-- Hero Search Bar - Bento Style -->
                <form action="/Project" method="get" class="hero-animate hero-animate-delay-3 mb-8">
                    <div class="flex p-2 bg-white dark:bg-[#0f0f13]/80 backdrop-blur-xl rounded-[2rem] shadow-xl dark:shadow-2xl dark:shadow-indigo-500/10 search-glow transition-all duration-300 border border-slate-200 dark:border-white/10 group">
                        <div class="flex-1 flex items-center px-6">
                            <i class="fas fa-search text-slate-400 dark:text-slate-500 text-lg group-focus-within:text-indigo-500 transition-colors"></i>
                            <input type="text" name="search" placeholder="What will you build today?" 
                                   class="w-full py-4 px-4 text-lg text-slate-800 dark:text-white outline-none bg-transparent placeholder:text-slate-400 dark:placeholder:text-slate-500 font-medium tracking-wide">
                        </div>
                        <button type="submit" class="bg-indigo-600 hover:bg-indigo-500 text-white px-10 py-4 font-bold transition-all duration-300 flex items-center gap-2 rounded-full hover:shadow-lg hover:shadow-indigo-500/50 active:scale-95">
                            Search
                        </button>
                    </div>
                </form>
                
                <!-- Popular Tags -->
                <div class="hero-animate hero-animate-delay-4 flex flex-wrap items-center gap-3">
                    <span class="text-slate-500 dark:text-slate-400 text-sm font-medium">Trending:</span>
                    <a href="/Project?search=react" class="px-4 py-1.5 bg-white dark:bg-white/5 hover:bg-indigo-50 dark:hover:bg-white/10 text-slate-700 dark:text-slate-300 text-sm font-medium rounded-full border border-slate-200 dark:border-white/10 transition-all duration-300 hover:border-indigo-300 dark:hover:border-indigo-500/50">React.js</a>
                    <a href="/Project?search=ui" class="px-4 py-1.5 bg-white dark:bg-white/5 hover:bg-indigo-50 dark:hover:bg-white/10 text-slate-700 dark:text-slate-300 text-sm font-medium rounded-full border border-slate-200 dark:border-white/10 transition-all duration-300 hover:border-indigo-300 dark:hover:border-indigo-500/50">UI/UX Design</a>
                    <a href="/Project?search=python" class="px-4 py-1.5 bg-white dark:bg-white/5 hover:bg-indigo-50 dark:hover:bg-white/10 text-slate-700 dark:text-slate-300 text-sm font-medium rounded-full border border-slate-200 dark:border-white/10 transition-all duration-300 hover:border-indigo-300 dark:hover:border-indigo-500/50">Python</a>
                </div>
            </div>
            
            <!-- Right Side - Floating Hero Image exact matching user request -->
            <div class="hidden lg:flex relative h-[600px] items-center justify-center pt-8">
                <div class="relative w-full max-w-[500px]">
                    
                    <!-- Base Image Card -->
                    <div class="relative w-full overflow-hidden rounded-[2.5rem] border border-white/10 shadow-2xl z-10 hero-animate hero-animate-delay-2 shadow-indigo-500/20" style="aspect-ratio: 4/3;">
                        <img src="https://png.pngtree.com/thumb_back/fh260/background/20230707/pngtree-d-illustration-of-a-skilled-freelance-developer-working-on-a-laptop-image_3791858.jpg" 
                             alt="Freelancer at work" 
                             class="w-full h-full object-cover" />
                        <!-- Subtle dark gradient overlay on image -->
                        <div class="absolute inset-0 bg-gradient-to-t from-[#05050A] via-transparent to-transparent pointer-events-none opacity-80"></div>
                        <div class="absolute inset-0 bg-gradient-to-r from-[#05050A]/30 via-transparent to-transparent pointer-events-none opacity-50"></div>
                    </div>
                    
                    <!-- FLOAT 1: Project Completed (Top Left) -->
                    <div class="absolute -top-6 -left-12 z-20 glass-badge rounded-3xl p-4 pr-8 flex items-center gap-4 hero-float">
                        <div class="w-10 h-10 rounded-full bg-emerald-500/20 border border-emerald-500/30 flex items-center justify-center">
                            <i class="fas fa-check-circle text-emerald-400 text-xl"></i>
                        </div>
                        <div>
                            <div class="text-white font-bold text-sm tracking-wide">@latestProjectStatus project</div>
                            <div class="text-slate-300 text-xs font-medium mt-0.5">@latestProjectTitle • $@latestProjectBudget.ToString("N0")</div>
                        </div>
                    </div>
                    
                    <!-- FLOAT 2: Payment Received (Bottom Left) -->
                    <div class="absolute -bottom-8 -left-6 z-20 glass-badge rounded-3xl p-5 flex flex-col gap-2 hero-float-delayed">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-xl bg-indigo-500/30 border border-indigo-500/30 flex items-center justify-center">
                                <i class="fas fa-wallet text-indigo-300 text-sm"></i>
                            </div>
                            <span class="text-white font-bold text-sm">Payment Received</span>
                        </div>
                        <div class="flex items-baseline gap-2 mt-1">
                            <span class="text-3xl font-black text-white tracking-tight">$@latestContractAmount.ToString("N0")</span>
                            <span class="text-emerald-400 text-sm font-bold">DB</span>
                        </div>
                    </div>

                    <!-- FLOAT 3: 24 projects posted (Middle Right) -->
                    <div class="absolute top-[45%] -right-16 z-20 glass-badge rounded-[2rem] py-3 px-5 flex items-center gap-3 hero-float-slow">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-400"></span>
                        </span>
                        <span class="text-white font-bold text-sm tracking-wide">@totalProjects projects on platform</span>
                    </div>

                    <!-- FLOAT 4: Rating (Bottom Right) -->
                    <div class="absolute -bottom-4 right-10 z-20 glass-badge rounded-[1.5rem] py-2.5 px-4 flex items-center gap-2 hero-float">
                        <div class="flex items-center text-amber-400 text-sm gap-0.5">
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                        </div>
                        <span class="text-white font-bold text-sm ml-1">@totalFreelancers</span>
                    </div>
                    
                </div>
            </div>
        </div>
    </div>
</div>

