@model SGP_Freelancing.Models.ViewModels.VerificationViewModel
@{
    ViewData["Title"] = "Verification";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="max-w-2xl mx-auto space-y-8">
    <div>
        <h1 class="text-3xl font-black text-slate-900 dark:text-white">
            <i class="fas fa-shield-alt text-blue-500 mr-2"></i> Identity Verification
        </h1>
        <p class="text-slate-500 mt-1">Get verified to earn a trust badge on your profile</p>
    </div>

    <!-- Status Card -->
    <div class="bento-card p-6 md:p-8 space-y-6">
        @switch (Model.Status.Status)
        {
            case "None":
                <div class="text-center space-y-4 py-6">
                    <div class="w-20 h-20 mx-auto rounded-full bg-slate-100 dark:bg-white/5 flex items-center justify-center">
                        <i class="fas fa-id-card text-3xl text-slate-400"></i>
                    </div>
                    <h2 class="text-xl font-bold text-slate-900 dark:text-white">Not Verified</h2>
                    <p class="text-slate-500 max-w-md mx-auto">Upload a government-issued ID document to get your profile verified and earn a trust badge.</p>
                </div>
                break;
            case "Pending":
                <div class="text-center space-y-4 py-6">
                    <div class="w-20 h-20 mx-auto rounded-full bg-amber-500/10 flex items-center justify-center">
                        <i class="fas fa-hourglass-half text-3xl text-amber-500 animate-pulse"></i>
                    </div>
                    <h2 class="text-xl font-bold text-amber-500">Verification Pending</h2>
                    <p class="text-slate-500 max-w-md mx-auto">Your document is being reviewed by our team. This usually takes 1-2 business days.</p>
                    <p class="text-xs text-slate-400">Submitted: @Model.Status.SubmittedAt?.ToString("MMM dd, yyyy HH:mm")</p>
                </div>
                break;
            case "Approved":
                <div class="text-center space-y-4 py-6">
                    <div class="w-20 h-20 mx-auto rounded-full bg-emerald-500/10 flex items-center justify-center relative">
                        <i class="fas fa-check-circle text-3xl text-emerald-500"></i>
                        <div class="absolute -bottom-1 -right-1 w-7 h-7 bg-blue-500 rounded-full flex items-center justify-center shadow-lg shadow-blue-500/30">
                            <i class="fas fa-check text-white text-xs"></i>
                        </div>
                    </div>
                    <h2 class="text-xl font-bold text-emerald-500">Verified <i class="fas fa-check-circle text-blue-500"></i></h2>
                    <p class="text-slate-500 max-w-md mx-auto">Your identity has been verified. A trust badge is now displayed on your profile.</p>
                    @if (Model.Status.Note != null)
                    {
                        <p class="text-xs text-slate-400">@Model.Status.Note</p>
                    }
                </div>
                break;
            case "Rejected":
                <div class="text-center space-y-4 py-6">
                    <div class="w-20 h-20 mx-auto rounded-full bg-red-500/10 flex items-center justify-center">
                        <i class="fas fa-times-circle text-3xl text-red-500"></i>
                    </div>
                    <h2 class="text-xl font-bold text-red-500">Verification Rejected</h2>
                    <p class="text-slate-500 max-w-md mx-auto">Your document was not accepted. Please try submitting again with a valid document.</p>
                    @if (Model.Status.Note != null)
                    {
                        <div class="bg-red-50 dark:bg-red-500/5 border border-red-200/50 dark:border-red-500/10 rounded-xl p-4 text-left max-w-md mx-auto">
                            <p class="text-sm text-red-700 dark:text-red-300"><strong>Reason:</strong> @Model.Status.Note</p>
                        </div>
                    }
                </div>
                break;
        }

        @if (Model.Status.Status == "None" || Model.Status.Status == "Rejected")
        {
            <form asp-action="Submit" method="post" class="space-y-4 pt-4 border-t border-slate-200 dark:border-white/10">
                <div>
                    <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Document URL</label>
                    <input type="url" name="documentUrl" required placeholder="https://drive.google.com/file/d/your-document"
                        class="w-full px-4 py-3 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none focus:ring-2 focus:ring-indigo-500" />
                    <p class="text-xs text-slate-400 mt-2"><i class="fas fa-info-circle mr-1"></i> Upload your ID to Google Drive, Dropbox, or any cloud service and paste the sharing link here.</p>
                </div>
                <button type="submit" class="w-full px-4 py-3 bg-indigo-500 text-white rounded-xl font-bold hover:bg-indigo-400 transition-all shadow-lg shadow-indigo-500/20">
                    <i class="fas fa-upload mr-2"></i> Submit for Verification
                </button>
            </form>
        }
    </div>
</div>
