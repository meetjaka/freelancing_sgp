@model List<SGP_Freelancing.Models.DTOs.DisputeDto>
@{
    ViewData["Title"] = "Disputes Management";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-black text-slate-900 dark:text-white">
            <i class="fas fa-gavel text-red-400 mr-2"></i> Disputes Management
        </h1>
        <p class="text-slate-500 mt-1">Review and resolve pending disputes</p>
    </div>

    @if (Model.Any())
    {
        <div class="space-y-4">
            @foreach (var dispute in Model)
            {
                <div class="bento-card p-6 space-y-4">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                        <div>
                            <h3 class="font-bold text-slate-900 dark:text-white">@dispute.ProjectTitle</h3>
                            <p class="text-sm text-slate-500">Raised by <span class="text-indigo-500 font-medium">@dispute.RaisedByName</span> • @dispute.CreatedAt.ToString("MMM dd, yyyy")</p>
                        </div>
                        <span class="px-3 py-1 rounded-full text-xs font-bold self-start @(dispute.Status == "Open" ? "bg-red-500/10 text-red-500 border border-red-500/20" : "bg-amber-500/10 text-amber-500 border border-amber-500/20")">
                            @dispute.Status
                        </span>
                    </div>
                    <div class="bg-red-50 dark:bg-red-500/5 border border-red-200/50 dark:border-red-500/10 rounded-xl p-4">
                        <p class="text-sm text-red-700 dark:text-red-300">@dispute.Reason</p>
                    </div>
                    <div class="flex items-center gap-4 text-xs text-slate-500">
                        <span><i class="fas fa-user mr-1"></i> Client: @dispute.ClientName</span>
                        <span><i class="fas fa-user-tie mr-1"></i> Freelancer: @dispute.FreelancerName</span>
                    </div>
                    
                    <!-- Resolve Form -->
                    <form asp-action="Resolve" method="post" class="space-y-3 pt-3 border-t border-slate-200 dark:border-white/10">
                        <input type="hidden" name="DisputeId" value="@dispute.Id" />
                        <textarea name="Resolution" required rows="3" placeholder="Enter your resolution..."
                            class="w-full px-4 py-2 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-sm outline-none focus:ring-2 focus:ring-indigo-500 text-slate-900 dark:text-white"></textarea>
                        <button type="submit" class="px-6 py-2 bg-emerald-500 text-white rounded-xl text-sm font-bold hover:bg-emerald-400 transition-all">
                            <i class="fas fa-check mr-2"></i> Resolve Dispute
                        </button>
                    </form>
                </div>
            }
        </div>
    }
    else
    {
        <div class="bento-card p-12 text-center">
            <i class="fas fa-check-circle text-5xl text-emerald-400 mb-4"></i>
            <h3 class="text-xl font-bold text-slate-600 dark:text-slate-400">No pending disputes</h3>
            <p class="text-slate-400 mt-2">All disputes have been resolved</p>
        </div>
    }
</div>
