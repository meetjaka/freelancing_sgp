@model SGP_Freelancing.Models.ViewModels.AdminHubViewModel
@{
    ViewData["Title"] = "Admin dashboard";
}

<div class="mb-8 rounded-2xl border border-violet-500/30 bg-gradient-to-br from-violet-950/40 via-slate-900/60 to-indigo-950/40 p-8 text-white shadow-xl">
    <p class="text-xs font-semibold uppercase tracking-widest text-violet-300/90 mb-2">Administrator</p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-2">Welcome, @ViewBag.UserName</h1>
    <p class="text-slate-300 text-sm md:text-base max-w-2xl">Review identity submissions, resolve contract disputes, and monitor platform activity. Use the navigation bar or the shortcuts below.</p>
    <div class="flex flex-wrap gap-3 mt-6">
        <a asp-controller="Verification" asp-action="AdminIndex" class="inline-flex items-center gap-2 rounded-full bg-violet-600 px-5 py-2.5 text-sm font-semibold text-white shadow-lg hover:bg-violet-500 transition-colors">
            <i class="fas fa-id-card"></i> Identity verification queue
            @if (Model.PendingVerificationCount > 0)
            {
                <span class="rounded-full bg-white/20 px-2 py-0.5 text-xs">@Model.PendingVerificationCount</span>
            }
        </a>
        <a asp-controller="Dispute" asp-action="Index" class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/5 px-5 py-2.5 text-sm font-semibold text-white hover:bg-white/10 transition-colors">
            <i class="fas fa-gavel"></i> Disputes
            @if (Model.PendingDisputeCount > 0)
            {
                <span class="rounded-full bg-amber-500/30 px-2 py-0.5 text-xs text-amber-100">@Model.PendingDisputeCount</span>
            }
        </a>
        <a asp-controller="Project" asp-action="Index" class="inline-flex items-center gap-2 rounded-full border border-white/15 px-5 py-2.5 text-sm font-medium text-slate-200 hover:bg-white/5 transition-colors">
            <i class="fas fa-briefcase"></i> Browse projects (oversight)
        </a>
    </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-10">
    <a asp-controller="Verification" asp-action="AdminIndex" class="rounded-2xl border border-slate-200 dark:border-white/10 bg-white dark:bg-[#12141a] p-6 hover:border-violet-500/40 transition-colors block">
        <p class="text-xs font-medium uppercase tracking-wide text-slate-500 dark:text-slate-400">Pending ID reviews</p>
        <p class="mt-2 text-4xl font-bold text-slate-900 dark:text-white">@Model.PendingVerificationCount</p>
        <p class="mt-2 text-sm text-violet-600 dark:text-violet-400 font-medium">Open queue →</p>
    </a>
    <a asp-controller="Dispute" asp-action="Index" class="rounded-2xl border border-slate-200 dark:border-white/10 bg-white dark:bg-[#12141a] p-6 hover:border-amber-500/40 transition-colors block">
        <p class="text-xs font-medium uppercase tracking-wide text-slate-500 dark:text-slate-400">Open / under review disputes</p>
        <p class="mt-2 text-4xl font-bold text-slate-900 dark:text-white">@Model.PendingDisputeCount</p>
        <p class="mt-2 text-sm text-amber-600 dark:text-amber-400 font-medium">Manage disputes →</p>
    </a>
    <div class="rounded-2xl border border-slate-200 dark:border-white/10 bg-white dark:bg-[#12141a] p-6">
        <p class="text-xs font-medium uppercase tracking-wide text-slate-500 dark:text-slate-400">Registered accounts</p>
        <p class="mt-2 text-4xl font-bold text-slate-900 dark:text-white">@Model.TotalRegisteredUsers</p>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">All roles (Identity)</p>
    </div>
    <div class="rounded-2xl border border-slate-200 dark:border-white/10 bg-white dark:bg-[#12141a] p-6">
        <p class="text-xs font-medium uppercase tracking-wide text-slate-500 dark:text-slate-400">Open marketplace projects</p>
        <p class="mt-2 text-4xl font-bold text-slate-900 dark:text-white">@Model.TotalOpenProjects</p>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Status = Open</p>
    </div>
</div>

<div class="rounded-2xl border border-slate-200 dark:border-white/10 bg-white dark:bg-[#12141a] p-6 md:p-8">
    <h2 class="text-lg font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
        <i class="fas fa-list-check text-violet-500"></i> Admin capabilities in this build
    </h2>
    <ul class="space-y-3 text-sm text-slate-600 dark:text-slate-300 list-disc pl-5 max-w-3xl">
        <li><strong class="text-slate-900 dark:text-white">Identity verification</strong> — Users submit a cloud link to a government ID on <code class="text-xs bg-slate-100 dark:bg-white/10 px-1 rounded">/Verification/Status</code>. Admins open <code class="text-xs bg-slate-100 dark:bg-white/10 px-1 rounded">/Verification/AdminIndex</code> to approve or reject; approved users get <code class="text-xs bg-slate-100 dark:bg-white/10 px-1 rounded">IsVerified</code> and a trust badge on their profile.</li>
        <li><strong class="text-slate-900 dark:text-white">Disputes</strong> — <code class="text-xs bg-slate-100 dark:bg-white/10 px-1 rounded">/Dispute/Index</code> lists disputes that are Open or Under review. Admins can resolve them (resolution text, contract status updated). Contract dispute details at <code class="text-xs bg-slate-100 dark:bg-white/10 px-1 rounded">/Dispute/Details/{id}</code> show admin actions when applicable.</li>
        <li><strong class="text-slate-900 dark:text-white">Platform oversight</strong> — You can open the public project list (<code class="text-xs bg-slate-100 dark:bg-white/10 px-1 rounded">/Project</code>) and use Messages / Settings like any signed-in user; marketplace navigation is trimmed in the top bar for the Admin role.</li>
    </ul>
    <p class="mt-6 text-xs text-slate-500 dark:text-slate-500">There is no separate <code class="bg-slate-100 dark:bg-white/10 px-1 rounded">/Admin</code> URL: admins land on this page from <strong>Dashboard</strong> in the main menu.</p>
</div>
