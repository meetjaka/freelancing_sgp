@model SGP_Freelancing.Models.ViewModels.GigMarketplaceViewModel
@{
    ViewData["Title"] = "Services Marketplace";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="space-y-8">
    <!-- Hero Header -->
    <div class="relative overflow-hidden rounded-3xl bg-white dark:bg-[#15171e] border border-slate-200 dark:border-white/10 p-8 md:p-12 shadow-sm">
        <div class="relative z-10">
            <h1 class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white mb-2">Services Marketplace</h1>
            <p class="text-slate-500 dark:text-slate-400 text-lg">Browse professional services from top freelancers</p>
            
            <!-- Search Bar -->
            <form method="get" class="mt-6 flex gap-3 max-w-2xl">
                <div class="flex-1 relative">
                    <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                    <input type="text" name="search" value="@Model.SearchTerm" placeholder="Search services..."
                        class="w-full pl-11 pr-4 py-3 bg-slate-50 dark:bg-black/20 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:ring-2 focus:ring-indigo-500/50 outline-none transition-all" />
                </div>
                <select name="categoryId" class="px-4 py-3 bg-slate-50 dark:bg-black/20 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none appearance-none font-medium focus:ring-2 focus:ring-indigo-500/50 transition-all">
                    <option value="">All Categories</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id)">@cat.Name</option>
                    }
                </select>
                <button type="submit" class="px-6 py-3 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 transition-all shadow-md hover:shadow-lg">Search</button>
            </form>
        </div>
    </div>

    <!-- Services Grid -->
    @if (Model.Services.Any())
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            @foreach (var service in Model.Services)
            {
                <a asp-action="Details" asp-route-id="@service.Id" class="bento-card group cursor-pointer overflow-hidden">
                    <!-- Image -->
                    <div class="aspect-video bg-gradient-to-br from-indigo-500/20 to-violet-500/20 relative overflow-hidden">
                        @if (!string.IsNullOrEmpty(service.ImageUrl))
                        {
                            <img src="@service.ImageUrl" alt="@service.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center">
                                <i class="fas fa-briefcase text-4xl text-indigo-500/40"></i>
                            </div>
                        }
                        <div class="absolute top-3 right-3 px-2 py-1 bg-black/60 backdrop-blur-sm rounded-lg text-white text-xs font-bold">
                            @service.CategoryName
                        </div>
                    </div>
                    <!-- Content -->
                    <div class="p-4 space-y-3">
                        <div class="flex items-center gap-2">
                            <div class="w-8 h-8 rounded-full bg-indigo-500 flex items-center justify-center text-white text-xs font-bold">
                                @service.FreelancerName.Substring(0, 1)
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-xs text-slate-500 truncate">
                                    @service.FreelancerName
                                    @if (service.FreelancerIsVerified) { <i class="fas fa-check-circle text-blue-500 ml-1"></i> }
                                </p>
                            </div>
                        </div>
                        <h3 class="font-bold text-slate-900 dark:text-white text-sm line-clamp-2 group-hover:text-indigo-500 transition-colors">@service.Title</h3>
                        <div class="flex items-center justify-between text-xs text-slate-500">
                            <span><i class="fas fa-star text-amber-400 mr-1"></i> @service.AverageRating.ToString("N1")</span>
                            <span><i class="fas fa-shopping-bag mr-1"></i> @service.TotalOrders orders</span>
                        </div>
                        <div class="flex items-center justify-between pt-3 border-t border-slate-200 dark:border-white/5">
                            <span class="text-xs text-slate-500">Starting at</span>
                            <span class="text-lg font-black text-indigo-500">$@service.Price.ToString("N0")</span>
                        </div>
                    </div>
                </a>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalCount > Model.PageSize)
        {
            <div class="flex justify-center gap-2 mt-8">
                @for (int i = 1; i <= Math.Ceiling((double)Model.TotalCount / Model.PageSize); i++)
                {
                    <a asp-action="Index" asp-route-page="@i" asp-route-search="@Model.SearchTerm" asp-route-categoryId="@Model.CategoryId"
                       class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-bold transition-all @(Model.PageNumber == i ? "bg-indigo-500 text-white" : "bg-slate-100 dark:bg-white/5 text-slate-600 dark:text-slate-400 hover:bg-indigo-500/10")">
                        @i
                    </a>
                }
            </div>
        }
    }
    else
    {
        <div class="bento-card p-12 text-center">
            <i class="fas fa-store text-5xl text-slate-300 mb-4"></i>
            <h3 class="text-xl font-bold text-slate-600 dark:text-slate-400">No services found</h3>
            <p class="text-slate-400 mt-2">Try adjusting your search or browse all categories</p>
        </div>
    }
</div>
