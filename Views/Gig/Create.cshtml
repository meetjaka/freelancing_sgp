@model SGP_Freelancing.Models.ViewModels.CreateGigViewModel
@{
    ViewData["Title"] = "Create Service";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="max-w-3xl mx-auto space-y-8">
    <div>
        <h1 class="text-3xl font-black text-slate-900 dark:text-white">Create a New Service</h1>
        <p class="text-slate-500 mt-1">List your service for clients to browse and order</p>
    </div>

    <form asp-action="Create" method="post" class="bento-card p-6 md:p-8 space-y-6">
        <div>
            <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Service Title</label>
            <input type="text" name="Title" required maxlength="200" placeholder="e.g. I will design a modern logo for your brand"
                class="w-full px-4 py-3 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>

        <div>
            <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Description</label>
            <textarea name="Description" rows="6" required placeholder="Describe your service in detail..."
                class="w-full px-4 py-3 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none focus:ring-2 focus:ring-indigo-500"></textarea>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Category</label>
                <select name="CategoryId" required class="w-full px-4 py-3 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none focus:ring-2 focus:ring-indigo-500">
                    <option value="">Select...</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Price ($)</label>
                <input type="number" step="1" min="1" name="Price" required placeholder="50"
                    class="w-full px-4 py-3 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none focus:ring-2 focus:ring-indigo-500" />
            </div>
            <div>
                <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Delivery (days)</label>
                <input type="number" min="1" max="365" name="DeliveryDays" required placeholder="7"
                    class="w-full px-4 py-3 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none focus:ring-2 focus:ring-indigo-500" />
            </div>
        </div>

        <div>
            <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Skills</label>
            <div class="flex flex-wrap gap-2">
                @foreach (var skill in Model.Skills)
                {
                    <label class="flex items-center gap-2 px-3 py-2 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl hover:border-indigo-500/50 transition-colors cursor-pointer">
                        <input type="checkbox" name="SkillIds" value="@skill.Id" class="w-4 h-4 rounded text-indigo-500 focus:ring-indigo-500" />
                        <span class="text-sm text-slate-700 dark:text-slate-300">@skill.Name</span>
                    </label>
                }
            </div>
        </div>

        <div class="flex items-center justify-end gap-4 pt-4 border-t border-slate-200 dark:border-white/10">
            <a asp-action="MyGigs" class="px-6 py-3 text-slate-500 hover:text-slate-700 dark:hover:text-white font-medium transition-colors">Cancel</a>
            <button type="submit" class="px-8 py-3 bg-indigo-500 text-white rounded-xl font-bold hover:bg-indigo-400 transition-all shadow-lg shadow-indigo-500/20">
                <i class="fas fa-rocket mr-2"></i> Publish Service
            </button>
        </div>
    </form>
</div>
