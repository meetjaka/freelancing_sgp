@model SGP_Freelancing.Models.ViewModels.GigDetailsViewModel
@{
    ViewData["Title"] = Model.Service.Title;
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="max-w-6xl mx-auto space-y-8">
    <a asp-action="Index" class="inline-flex items-center gap-2 text-indigo-500 hover:text-indigo-400 transition-colors text-sm font-medium">
        <i class="fas fa-arrow-left"></i> Back to Marketplace
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left: Service Details -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Image -->
            <div class="aspect-video bg-gradient-to-br from-indigo-500/20 to-violet-500/20 rounded-2xl overflow-hidden">
                @if (!string.IsNullOrEmpty(Model.Service.ImageUrl))
                {
                    <img src="@Model.Service.ImageUrl" alt="@Model.Service.Title" class="w-full h-full object-cover" />
                }
                else
                {
                    <div class="w-full h-full flex items-center justify-center">
                        <i class="fas fa-briefcase text-6xl text-indigo-500/30"></i>
                    </div>
                }
            </div>

            <div class="bento-card p-6 space-y-4">
                <div class="flex items-center gap-2 text-sm text-indigo-500">
                    <i class="fas fa-tag"></i> @Model.Service.CategoryName
                </div>
                <h1 class="text-2xl md:text-3xl font-black text-slate-900 dark:text-white">@Model.Service.Title</h1>
                
                <!-- Freelancer Info -->
                <div class="flex items-center gap-3 pb-4 border-b border-slate-200 dark:border-white/10">
                    <div class="w-12 h-12 rounded-full bg-indigo-500 flex items-center justify-center text-white text-lg font-bold">
                        @Model.Service.FreelancerName.Substring(0, 1)
                    </div>
                    <div>
                        <p class="font-bold text-slate-900 dark:text-white">
                            @Model.Service.FreelancerName
                            @if (Model.Service.FreelancerIsVerified) { <i class="fas fa-check-circle text-blue-500 ml-1"></i> }
                        </p>
                        <div class="flex items-center gap-3 text-sm text-slate-500">
                            <span><i class="fas fa-star text-amber-400 mr-1"></i> @Model.Service.FreelancerRating.ToString("N1")</span>
                            <span><i class="fas fa-shopping-bag mr-1"></i> @Model.Service.TotalOrders orders</span>
                        </div>
                    </div>
                </div>

                <h3 class="text-lg font-bold text-slate-900 dark:text-white">About This Service</h3>
                <div class="prose prose-slate dark:prose-invert max-w-none text-sm leading-relaxed">
                    @Html.Raw(Model.Service.Description.Replace("\n", "<br/>"))
                </div>

                @if (Model.Service.Skills.Any())
                {
                    <div>
                        <h4 class="font-bold text-slate-900 dark:text-white mb-2">Skills Used</h4>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var skill in Model.Service.Skills)
                            {
                                <span class="px-3 py-1 bg-indigo-500/10 text-indigo-500 rounded-full text-xs font-bold">@skill</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Right: Order Card -->
        <div class="space-y-6">
            <div class="bento-card p-6 space-y-4 sticky top-24">
                <div class="flex items-center justify-between">
                    <span class="text-sm text-slate-500">Price</span>
                    <span class="text-3xl font-black text-indigo-500">$@Model.Service.Price.ToString("N0")</span>
                </div>
                <div class="space-y-2 text-sm">
                    <div class="flex items-center justify-between py-2 border-b border-slate-100 dark:border-white/5">
                        <span class="text-slate-500"><i class="far fa-clock mr-2"></i> Delivery Time</span>
                        <span class="font-bold text-slate-900 dark:text-white">@Model.Service.DeliveryDays days</span>
                    </div>
                    <div class="flex items-center justify-between py-2 border-b border-slate-100 dark:border-white/5">
                        <span class="text-slate-500"><i class="fas fa-shopping-bag mr-2"></i> Total Orders</span>
                        <span class="font-bold text-slate-900 dark:text-white">@Model.Service.TotalOrders</span>
                    </div>
                    <div class="flex items-center justify-between py-2">
                        <span class="text-slate-500"><i class="fas fa-star mr-2"></i> Rating</span>
                        <span class="font-bold text-amber-500">@Model.Service.AverageRating.ToString("N1") / 5.0</span>
                    </div>
                </div>

                @if (Model.CanOrder)
                {
                    <form asp-action="PlaceOrder" method="post" class="space-y-3">
                        <input type="hidden" name="ServiceId" value="@Model.Service.Id" />
                        <div>
                            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Requirements (optional)</label>
                            <textarea name="Requirements" rows="3" placeholder="Describe what you need..."
                                class="w-full px-4 py-2 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-sm outline-none focus:ring-2 focus:ring-indigo-500 text-slate-900 dark:text-white"></textarea>
                        </div>
                        <button type="submit" class="w-full px-4 py-3 bg-indigo-500 text-white rounded-xl font-bold hover:bg-indigo-400 transition-all shadow-lg shadow-indigo-500/20 flex items-center justify-center gap-2">
                            <i class="fas fa-shopping-cart"></i> Order Now — $@Model.Service.Price.ToString("N0")
                        </button>
                    </form>
                }
                else if (!User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Login" class="w-full block text-center px-4 py-3 bg-indigo-500 text-white rounded-xl font-bold hover:bg-indigo-400 transition-all">
                        Sign In to Order
                    </a>
                }
                else
                {
                    <p class="text-sm text-slate-400 text-center">Only clients can place orders</p>
                }
            </div>
        </div>
    </div>
</div>
