<!DOCTYPE html>
<html lang="en" class="scroll-smooth dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SGP Freelancing Platform</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        /* Futuristic Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(15, 23, 42, 0.5); 
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(99, 102, 241, 0.5); 
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(99, 102, 241, 0.8); 
        }

        /* Top Navbar active styles */
        .nav-link {
            position: relative;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            color: #94a3b8; /* text-slate-400 */
        }
        
        .nav-link:hover {
            color: #f8fafc; /* text-slate-50 */
            background: rgba(255, 255, 255, 0.05);
        }
        
        .nav-link.active {
            color: #6366f1; /* indigo-500 */
            background: rgba(99, 102, 241, 0.1);
        }

        .nav-link.active::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 50%;
            transform: translateX(-50%);
            width: 20px;
            height: 3px;
            background: #6366f1;
            border-radius: 4px 4px 0 0;
            box-shadow: 0 -2px 10px rgba(99, 102, 241, 0.5);
        }

        /* Smooth bento box hover */
        .bento-card {
            background-color: #12141a;
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 1rem;
            transition: all 0.3s ease;
            transform-origin: center;
        }
        .bento-card:hover {
            transform: translateY(-4px) scale(1.01);
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5), 0 0 20px rgba(99, 102, 241, 0.05);
            border-color: rgba(99, 102, 241, 0.3);
        }

        /* Notification badge pulse */
        @@keyframes pulse-badge {
            0%, 100% {
                opacity: 1;
                transform: scale(1);
            }
            50% {
                opacity: 0.7;
                transform: scale(1.1);
            }
        }
        
        .notification-badge {
            animation: pulse-badge 2s ease-in-out infinite;
        }
        
        /* Logo animation */
        .logo-icon {
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        .logo-container:hover .logo-icon {
            transform: rotate(15deg) scale(1.1);
        }

        /* Light Mode Overrides for Hardcoded Dark Utilities */
        html:not(.dark) body {
            background-color: #f8fafc !important;
            color: #1e293b !important;
        }
        
        /* Nav */
        html:not(.dark) nav {
            background-color: rgba(255, 255, 255, 0.95) !important;
            border-bottom-color: #e2e8f0 !important;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
        }
        
        /* Bento Cards */
        html:not(.dark) .bento-card {
            background-color: #ffffff !important;
            border-color: #cbd5e1 !important;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1) !important;
        }
        html:not(.dark) .bento-card:hover {
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
            border-color: #818cf8 !important; /* light indigo */
        }

        /* Typography */
        html:not(.dark) .text-white {
            color: #0f172a !important; /* Near black */
        }
        html:not(.dark) .text-slate-200,
        html:not(.dark) .text-slate-300,
        html:not(.dark) .text-slate-400 {
            color: #475569 !important; /* Darker slate */
        }
        html:not(.dark) h1, html:not(.dark) h2, html:not(.dark) h3, html:not(.dark) h4, html:not(.dark) h5, html:not(.dark) h6 {
            color: #0f172a !important;
        }

        /* Forms, inputs, internal backgrounds */
        html:not(.dark) .bg-\[\#12141a\],
        html:not(.dark) .bg-\[\#15171e\],
        html:not(.dark) .bg-black\/20 {
            background-color: #f1f5f9 !important;
            border-color: #cbd5e1 !important;
            color: #0f172a !important;
        }
        
        /* Borders */
        html:not(.dark) .border-white\/10,
        html:not(.dark) .border-white\/5 {
            border-color: #e2e8f0 !important;
        }
        
        /* Active/Hover Backgrounds */
        html:not(.dark) .bg-white\/5 {
            background-color: #f1f5f9 !important;
        }
        html:not(.dark) .hover\:bg-white\/5:hover {
            background-color: #e2e8f0 !important;
        }
        html:not(.dark) .hover\:bg-white\/10:hover {
            background-color: #cbd5e1 !important;
        }
        html:not(.dark) .nav-link {
            color: #64748b !important;
        }
        html:not(.dark) .nav-link:hover {
            color: #0f172a !important;
            background: rgba(0, 0, 0, 0.05) !important;
        }
        html:not(.dark) .nav-link.active {
            color: #4f46e5 !important;
            background: rgba(79, 70, 229, 0.1) !important;
        }
    </style>
</head>
<body class="font-sans bg-[#0a0a0f] text-slate-300 min-h-screen selection:bg-indigo-500/30">
    @if (User.Identity.IsAuthenticated)
    {
        <!-- Main Content Wrapper (No Sidebar) -->
        <div class="flex flex-col min-h-screen">
            <!-- Futuristic Top Navigation Bar -->
            <nav class="sticky top-0 z-50 bg-[#0f1115]/80 backdrop-blur-xl border-b border-white/5 shadow-2xl">
                <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="flex items-center justify-between h-20">
                        
                        <!-- Left: Logo -->
                        <div class="flex-shrink-0 flex items-center gap-3 logo-container mr-8">
                            <div class="logo-icon w-10 h-10 bg-indigo-500/10 border border-indigo-500/20 rounded-xl flex items-center justify-center shadow-[0_0_15px_rgba(99,102,241,0.2)]">
                                <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                                </svg>
                            </div>
                            <span class="text-xl font-bold tracking-tight text-slate-900 dark:text-white">SGP<span class="text-indigo-600 dark:text-indigo-400">.io</span></span>
                        </div>

                        <!-- Center: Desktop Navigation -->
                        <div class="hidden md:flex flex-1 items-center justify-center gap-1">
                            <div class="flex bg-white/5 rounded-full p-1.5 border border-white/5 backdrop-blur-md">
                                <a asp-controller="Dashboard" asp-action="Index" class="nav-link px-5 py-2 rounded-full text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                                    Dashboard
                                </a>
                                
                                @if (User.IsInRole("Client"))
                                {
                                    <a asp-controller="Project" asp-action="MyProjects" class="nav-link px-5 py-2 rounded-full text-sm font-medium @(ViewContext.RouteData.Values["action"]?.ToString() == "MyProjects" ? "active" : "")">
                                        Projects
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="Project" asp-action="Index" class="nav-link px-5 py-2 rounded-full text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Project" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                                        Projects
                                    </a>
                                    <a asp-controller="Portfolio" asp-action="Index" class="nav-link px-5 py-2 rounded-full text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Portfolio" ? "active" : "")">
                                        Portfolios
                                    </a>
                                }
                                
                                <a asp-controller="Contract" asp-action="Index" class="nav-link px-5 py-2 rounded-full text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contract" ? "active" : "")">
                                    Contracts
                                </a>
                                <a asp-controller="Analytics" asp-action="Index" class="nav-link px-5 py-2 rounded-full text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Analytics" ? "active" : "")">
                                    Analytics
                                </a>
                            </div>
                        </div>

                        <!-- Right: Actions & User -->
                        <div class="flex items-center gap-4 ml-8">
                            
                            <!-- New Project Button (Clients Only) / Earnings (Freelancers Only) -->
                            <div class="hidden lg:block">
                                @if (User.IsInRole("Client"))
                                {
                                    <a asp-controller="Project" asp-action="Create" class="flex items-center gap-2 px-4 py-2 bg-indigo-500 hover:bg-indigo-400 text-white rounded-full text-sm font-bold transition-all shadow-[0_0_20px_rgba(99,102,241,0.3)] hover:shadow-[0_0_25px_rgba(99,102,241,0.5)]">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                                        </svg>
                                        Post Job
                                    </a>
                                }
                                else if (User.IsInRole("Freelancer"))
                                {
                                    <a asp-controller="Finance" asp-action="Index" class="flex items-center gap-2 px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 text-white rounded-full text-sm font-medium transition-all">
                                        <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                        Earnings
                                    </a>
                                }
                            </div>

                            <div class="h-8 w-px bg-white/10 mx-2 hidden sm:block"></div>

                            <!-- Messages Icon -->
                            <a asp-controller="Message" asp-action="Index" class="relative p-2 text-slate-400 hover:text-white hover:bg-white/5 rounded-full transition-all group" title="Messages">
                                <i class="far fa-comment-dots text-lg group-hover:text-indigo-400 transition-colors"></i>
                                <!-- Assuming you'd have an unread count from ViewBag/Component here eventually, using static dot for design -->
                                <span class="absolute top-1 right-1 w-2 h-2 bg-indigo-500 rounded-full shadow-[0_0_8px_rgba(99,102,241,0.8)]"></span>
                            </a>

                            <!-- Theme Toggle -->
                            <button class="relative p-2 text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-white/5 rounded-full transition-all group" id="themeToggleBtn" title="Toggle Theme">
                                <i class="fas fa-moon text-lg transition-all duration-300 transform group-hover:rotate-12"></i>
                            </button>

                            <!-- Notifications -->
                            <div class="relative">
                                <button class="relative p-2 text-slate-400 hover:text-white hover:bg-white/5 rounded-full transition-all group" id="notificationsBtn" title="Notifications">
                                    <i class="far fa-bell text-lg group-hover:text-indigo-400 transition-colors"></i>
                                    <span class="notification-badge absolute top-1 right-1.5 w-2 h-2 bg-red-500 rounded-full shadow-[0_0_8px_rgba(239,68,68,0.8)]"></span>
                                </button>
                                
                                <!-- Notifications Dropdown Placeholder -->
                                <div id="notificationsDropdown" class="hidden absolute right-0 mt-3 w-80 bg-[#15171e] rounded-2xl shadow-2xl border border-white/10 overflow-hidden transform origin-top-right transition-all">
                                    <div class="px-4 py-3 border-b border-white/5 flex items-center justify-between">
                                        <h3 class="font-bold text-white">Notifications</h3>
                                        <button class="text-xs text-indigo-400 hover:text-indigo-300">Mark all read</button>
                                    </div>
                                    <div class="p-4 text-center text-sm text-slate-500">
                                        No new notifications
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Search Icon (Mobile) -->
                            <button class="md:hidden p-2 text-slate-400 hover:text-white hover:bg-white/5 rounded-full transition-all">
                                <i class="fas fa-search text-lg"></i>
                            </button>

                            <!-- User Dropdown Menu -->
                            <div class="relative group ml-1">
                                <button class="flex items-center gap-3 p-1 pr-3 bg-white/5 hover:bg-white/10 rounded-full border border-white/5 transition-all">
                                    <div class="w-8 h-8 rounded-full bg-indigo-500 border border-indigo-600 flex items-center justify-center text-white font-bold text-sm overflow-hidden">
                                        <!-- You can place an image here later -->
                                        @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                                    </div>
                                    <div class="hidden sm:block text-left">
                                        @{
                                            string userRole = User.IsInRole("Client") ? "Client" : User.IsInRole("Freelancer") ? "Freelancer" : "User";
                                        }
                                        <span class="text-sm font-bold text-slate-800 dark:text-white group-hover:text-indigo-400 transition-colors">@User.Identity?.Name</span>
                                        <span class="text-xs text-slate-500 dark:text-slate-400 block mt-0.5">@userRole</span>
                                    </div>
                                    <i class="fas fa-chevron-down text-xs text-slate-500 ml-1"></i>
                                </button>

                                <!-- Dropdown Content -->
                                <div class="absolute right-0 mt-2 w-48 bg-[#15171e] rounded-2xl shadow-2xl border border-white/10 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-right group-hover:translate-y-0 translate-y-2">
                                    <a asp-controller="Account" asp-action="Profile" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-300 hover:text-white hover:bg-white/5 transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                        </svg>
                                        Profile
                                    </a>
                                    <a asp-controller="Settings" asp-action="Index" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-300 hover:text-white hover:bg-white/5 transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        </svg>
                                        Settings
                                    </a>
                                    <div class="h-px bg-white/10 my-1"></div>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="w-full flex items-center gap-2 px-4 py-2 text-sm text-red-400 hover:text-red-300 hover:bg-red-500/10 transition-colors text-left">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                                            </svg>
                                            Logout
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Mobile Navigation Menu (Hidden by default, can be toggled via JS if needed, but omitted for brevity/focus on desktop layout first, handled primarily by making main nav stack if necessary) -->
                </div>
            </nav>

            <!-- Page Content -->
            <main class="flex-1 w-full max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-8">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <!-- Public Layout -->
        <header>
            <nav class="bg-gradient-to-r from-indigo-600 to-purple-600 shadow-lg">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="flex items-center justify-between h-16">
                        <a href="/" class="flex items-center text-white font-bold text-xl">
                            <i class="fas fa-handshake mr-2"></i>SGP Freelancing
                        </a>
                        <div class="hidden md:flex items-center space-x-8">
                            <a asp-controller="Home" asp-action="Index" class="text-white/80 hover:text-white transition-colors">
                                <i class="fas fa-home mr-1"></i>Home
                            </a>
                            <a asp-controller="Project" asp-action="Index" class="text-white/80 hover:text-white transition-colors">
                                <i class="fas fa-briefcase mr-1"></i>Browse Projects
                            </a>
                        </div>
                        <div class="flex items-center space-x-4">
                            <a asp-controller="Account" asp-action="Login" class="text-white/80 hover:text-white transition-colors">
                                <i class="fas fa-sign-in-alt mr-1"></i>Login
                            </a>
                            <a asp-controller="Account" asp-action="Register" class="bg-white text-indigo-600 px-4 py-2 rounded-lg font-semibold hover:bg-slate-100 transition-colors">
                                <i class="fas fa-user-plus mr-1"></i>Sign Up
                            </a>
                        </div>
                    </div>
                </div>
            </nav>
        </header>
        
        <main class="min-h-screen">
            @RenderBody()
        </main>

        <footer class="bg-slate-900 text-white py-12">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div>
                        <h5 class="text-xl font-bold mb-4"><i class="fas fa-handshake mr-2"></i>SGP Freelancing</h5>
                        <p class="text-slate-400">Connect with top freelancers and find exciting projects worldwide.</p>
                    </div>
                    <div>
                        <h6 class="font-semibold mb-4">Quick Links</h6>
                        <ul class="space-y-2">
                            <li><a href="#" class="text-slate-400 hover:text-white transition-colors">About Us</a></li>
                            <li><a asp-controller="Home" asp-action="Privacy" class="text-slate-400 hover:text-white transition-colors">Privacy Policy</a></li>
                            <li><a href="#" class="text-slate-400 hover:text-white transition-colors">Terms of Service</a></li>
                            <li><a href="#" class="text-slate-400 hover:text-white transition-colors">Contact</a></li>
                        </ul>
                    </div>
                    <div>
                        <h6 class="font-semibold mb-4">Follow Us</h6>
                        <div class="flex space-x-4">
                            <a href="#" class="text-slate-400 hover:text-white transition-colors"><i class="fab fa-facebook text-2xl"></i></a>
                            <a href="#" class="text-slate-400 hover:text-white transition-colors"><i class="fab fa-twitter text-2xl"></i></a>
                            <a href="#" class="text-slate-400 hover:text-white transition-colors"><i class="fab fa-linkedin text-2xl"></i></a>
                            <a href="#" class="text-slate-400 hover:text-white transition-colors"><i class="fab fa-instagram text-2xl"></i></a>
                        </div>
                    </div>
                </div>
                <div class="border-t border-slate-800 mt-8 pt-8 text-center text-slate-400">
                    &copy; 2026 SGP Freelancing Platform. All rights reserved.
                </div>
            </div>
        </footer>
    }

    <script>
        // Theme Toggle Logic
        const themeToggleBtn = document.getElementById('themeToggleBtn');
        const htmlElement = document.documentElement;
        
        if (themeToggleBtn) {
            const themeIcon = themeToggleBtn.querySelector('i');

            // Initialize theme
            if (localStorage.theme === 'light' || (!('theme' in localStorage) && !window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                htmlElement.classList.remove('dark');
                themeIcon.classList.remove('fa-moon', 'text-slate-400');
                themeIcon.classList.add('fa-sun', 'text-amber-500');
            } else {
                htmlElement.classList.add('dark');
                themeIcon.classList.remove('fa-sun', 'text-amber-500');
                themeIcon.classList.add('fa-moon', 'text-slate-400');
            }

            // Click handler
            themeToggleBtn.addEventListener('click', () => {
                themeIcon.style.transform = 'rotate(180deg) scale(0.5)';
                themeIcon.style.opacity = '0';
                
                setTimeout(() => {
                    htmlElement.classList.toggle('dark');
                    if (htmlElement.classList.contains('dark')) {
                        localStorage.theme = 'dark';
                        themeIcon.classList.remove('fa-sun', 'text-amber-500');
                        themeIcon.classList.add('fa-moon', 'text-slate-400');
                    } else {
                        localStorage.theme = 'light';
                        themeIcon.classList.remove('fa-moon', 'text-slate-400');
                        themeIcon.classList.add('fa-sun', 'text-amber-500');
                    }
                    themeIcon.style.transform = 'rotate(0deg) scale(1)';
                    themeIcon.style.opacity = '1';
                }, 150);
            });
        }
        
        // Notifications dropdown toggle
        const notificationsBtn = document.getElementById('notificationsBtn');
        const notificationsDropdown = document.getElementById('notificationsDropdown');
        
        if (notificationsBtn && notificationsDropdown) {
            notificationsBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                notificationsDropdown.classList.toggle('hidden');
            });
            
            // Close dropdown when clicking outside
            document.addEventListener('click', function() {
                notificationsDropdown.classList.add('hidden');
            });
            
            notificationsDropdown.addEventListener('click', function(e) {
                e.stopPropagation();
            });
        }
    </script>
    
    @if (TempData["Success"] != null)
    {
        <div data-temp-success="@TempData["Success"]"></div>
    }
    @if (TempData["Error"] != null)
    {
        <div data-temp-error="@TempData["Error"]"></div>
    }
    @if (TempData["Warning"] != null)
    {
        <div data-temp-warning="@TempData["Warning"]"></div>
    }
    @if (TempData["Info"] != null)
    {
        <div data-temp-info="@TempData["Info"]"></div>
    }
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
