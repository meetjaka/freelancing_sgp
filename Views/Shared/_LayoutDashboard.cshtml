<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SGP Freelancing Platform</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        /* Futuristic Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(15, 23, 42, 0.5); 
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(99, 102, 241, 0.5); 
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(99, 102, 241, 0.8); 
        }

        /* Top Navbar active styles */
        .nav-link {
            position: relative;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            color: #64748b; /* text-slate-500 */
            white-space: nowrap;
        }
        html.dark .nav-link {
            color: #94a3b8; /* text-slate-400 */
        }
        
        .nav-link:hover {
            color: #0f172a; /* text-slate-900 */
            background: rgba(0, 0, 0, 0.05);
        }
        html.dark .nav-link:hover {
            color: #f8fafc; /* text-slate-50 */
            background: rgba(255, 255, 255, 0.05);
        }
        
        .nav-link.active {
            color: #6366f1; /* indigo-500 */
            background: rgba(99, 102, 241, 0.1);
        }

        .nav-link.active::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 50%;
            transform: translateX(-50%);
            width: 16px;
            height: 2px;
            background: #6366f1;
            border-radius: 4px 4px 0 0;
            box-shadow: 0 -2px 10px rgba(99, 102, 241, 0.5);
        }

        /* Hide scrollbar on compact nav pill (md–xl overflow) */
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        /* Smooth bento box hover */
        .bento-card {
            background-color: #ffffff;
            border: 1px solid rgba(0, 0, 0, 0.08);
            border-radius: 1rem;
            transition: all 0.3s ease;
            transform-origin: center;
        }
        html.dark .bento-card {
            background-color: #12141a;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .bento-card:hover {
            transform: translateY(-4px) scale(1.01);
            box-shadow: 0 10px 30px -5px rgba(0,0,0,0.1), 0 0 20px rgba(99, 102, 241, 0.08);
            border-color: rgba(99, 102, 241, 0.3);
        }
        html.dark .bento-card:hover {
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5), 0 0 20px rgba(99, 102, 241, 0.05);
        }

        /* Notification badge pulse */
        @@keyframes pulse-badge {
            0%, 100% {
                opacity: 1;
                transform: scale(1);
            }
            50% {
                opacity: 0.7;
                transform: scale(1.1);
            }
        }
        
        .notification-badge {
            animation: pulse-badge 2s ease-in-out infinite;
        }
        
        /* Logo animation */
        .logo-icon {
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        .logo-container:hover .logo-icon {
            transform: rotate(15deg) scale(1.1);
        }

        /* Typography - removed global override, using proper dark: prefixes instead */
    </style>
</head>
<body class="font-sans bg-white dark:bg-[#0a0a0f] text-slate-900 dark:text-slate-300 min-h-screen selection:bg-indigo-500/30 transition-colors duration-300">
    @if (User.Identity.IsAuthenticated)
    {
        <!-- Main Content Wrapper (No Sidebar) -->
        <div class="flex flex-col min-h-screen">
            <!-- Futuristic Top Navigation Bar -->
            <nav class="sticky top-0 z-50 overflow-visible bg-white/80 dark:bg-[#0f1115]/80 backdrop-blur-xl border-b border-slate-200 dark:border-white/5 shadow-lg dark:shadow-2xl transition-colors duration-300">
                <div class="max-w-[1600px] mx-auto px-3 sm:px-5 lg:px-8 overflow-visible pr-2 sm:pr-3">
                    <div class="flex items-center justify-between h-[4.25rem] sm:h-20 overflow-visible min-w-0 gap-2">
                        
                        <!-- Left: Logo -->
                        <div class="flex-shrink-0 flex items-center gap-2 sm:gap-3 logo-container mr-2 md:mr-4 lg:mr-8">
                            <div class="logo-icon w-9 h-9 sm:w-10 sm:h-10 bg-gradient-to-br from-indigo-600 via-violet-600 to-fuchsia-600 rounded-xl sm:rounded-2xl flex items-center justify-center shadow-[0_0_18px_rgba(99,102,241,0.35)] border border-white/10">
                                <span class="text-white font-black text-base sm:text-lg tracking-tight">F</span>
                            </div>
                            <span class="text-lg sm:text-xl font-black tracking-tight text-slate-900 dark:text-white">Freeio</span>
                        </div>

                        <!-- Center: Desktop Navigation -->
                        <div class="hidden md:flex flex-1 min-w-0 items-center justify-center px-1">
                            <div class="flex max-w-full min-w-0 bg-slate-100 dark:bg-white/5 rounded-full p-1 border border-slate-200 dark:border-white/5 backdrop-blur-md overflow-x-auto no-scrollbar">
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-controller="Dashboard" asp-action="Index" class="nav-link px-2.5 py-1.5 lg:px-4 lg:py-2 rounded-full text-xs lg:text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                                        Admin home
                                    </a>
                                    <a asp-controller="Verification" asp-action="AdminIndex" class="nav-link px-2.5 py-1.5 lg:px-4 lg:py-2 rounded-full text-xs lg:text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Verification" && ViewContext.RouteData.Values["action"]?.ToString() == "AdminIndex" ? "active" : "")">
                                        ID verifications
                                    </a>
                                    <a asp-controller="Dispute" asp-action="Index" class="nav-link px-2.5 py-1.5 lg:px-4 lg:py-2 rounded-full text-xs lg:text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dispute" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                                        Disputes
                                    </a>
                                    <a asp-controller="Project" asp-action="Index" class="nav-link px-2.5 py-1.5 lg:px-4 lg:py-2 rounded-full text-xs lg:text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Project" ? "active" : "")">
                                        Projects
                                    </a>
                                    <a asp-controller="Message" asp-action="Index" class="nav-link px-2.5 py-1.5 lg:px-4 lg:py-2 rounded-full text-xs lg:text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Message" ? "active" : "")">
                                        Messages
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="Dashboard" asp-action="Index" class="nav-link px-2.5 py-1.5 lg:px-4 lg:py-2 rounded-full text-xs lg:text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                                        Dashboard
                                    </a>
                                    @if (User.IsInRole("Client"))
                                    {
                                        <a asp-controller="Project" asp-action="MyProjects" class="nav-link px-2.5 py-1.5 lg:px-4 lg:py-2 rounded-full text-xs lg:text-sm font-medium @(ViewContext.RouteData.Values["action"]?.ToString() == "MyProjects" ? "active" : "")">
                                            Projects
                                        </a>
                                        <a asp-controller="Freelancer" asp-action="Index" class="nav-link px-2.5 py-1.5 lg:px-4 lg:py-2 rounded-full text-xs lg:text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Freelancer" ? "active" : "")">
                                            <span class="hidden xl:inline">Freelancers</span><span class="xl:hidden">Talent</span>
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-controller="Project" asp-action="Index" title="Browse Projects" class="nav-link px-2.5 py-1.5 lg:px-4 lg:py-2 rounded-full text-xs lg:text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Project" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                                            <span class="hidden xl:inline">Browse Projects</span><span class="xl:hidden">Browse</span>
                                        </a>
                                        <a asp-controller="Portfolio" asp-action="Index" class="nav-link px-2.5 py-1.5 lg:px-4 lg:py-2 rounded-full text-xs lg:text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Portfolio" ? "active" : "")">
                                            <span class="hidden min-[1200px]:inline">Portfolios</span><span class="min-[1200px]:hidden">Portfolio</span>
                                        </a>
                                    }
                                    <a asp-controller="Contract" asp-action="Index" class="nav-link px-2.5 py-1.5 lg:px-4 lg:py-2 rounded-full text-xs lg:text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contract" ? "active" : "")">
                                        <span class="hidden min-[1200px]:inline">Milestones & Contracts</span><span class="min-[1200px]:hidden">Milestones</span>
                                    </a>
                                    <a asp-controller="Gig" asp-action="Index" class="nav-link px-2.5 py-1.5 lg:px-4 lg:py-2 rounded-full text-xs lg:text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Gig" && (ViewContext.RouteData.Values["action"]?.ToString() == "Index" || ViewContext.RouteData.Values["action"]?.ToString() == "Details") ? "active" : "")">
                                        Services
                                    </a>
                                    <a asp-controller="Analytics" asp-action="Index" class="nav-link px-2.5 py-1.5 lg:px-4 lg:py-2 rounded-full text-xs lg:text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Analytics" ? "active" : "")">
                                        <span class="hidden lg:inline">Analytics</span><span class="lg:hidden">Stats</span>
                                    </a>
                                }
                            </div>
                        </div>

                        <!-- Right: Actions & User -->
                        <div class="flex flex-shrink-0 items-center gap-1.5 sm:gap-2 md:gap-3 ml-1 sm:ml-3 overflow-visible">
                            
                            <!-- Quick action (clients / freelancers only) -->
                            <div class="hidden lg:block">
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-controller="Verification" asp-action="AdminIndex" class="flex items-center gap-1.5 px-3 py-1.5 bg-violet-600 hover:bg-violet-500 text-white rounded-full text-xs font-bold transition-all shadow-[0_0_16px_rgba(124,58,237,0.35)]">
                                        <i class="fas fa-user-check text-sm"></i>
                                        Review IDs
                                    </a>
                                }
                                else if (User.IsInRole("Client"))
                                {
                                    <a asp-controller="Project" asp-action="Create" class="flex items-center gap-1.5 px-3 py-1.5 bg-indigo-500 hover:bg-indigo-400 text-white rounded-full text-xs font-bold transition-all shadow-[0_0_20px_rgba(99,102,241,0.3)] hover:shadow-[0_0_25px_rgba(99,102,241,0.5)]">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                                        </svg>
                                        Post Job
                                    </a>
                                }
                                else if (User.IsInRole("Freelancer"))
                                {
                                    <a asp-controller="Connects" asp-action="Index" class="flex items-center gap-1.5 px-3 py-1.5 bg-slate-100 dark:bg-white/5 hover:bg-slate-200 dark:hover:bg-white/10 border border-slate-300 dark:border-white/10 text-slate-900 dark:text-white rounded-full text-xs font-medium transition-all">
                                        <i class="fas fa-bolt text-amber-400 text-sm"></i>
                                        Connects
                                    </a>
                                }
                            </div>

                            <div class="h-7 w-px bg-slate-300 dark:bg-white/10 mx-0.5 sm:mx-1 hidden sm:block"></div>

                            <!-- Messages Icon -->
                            <a asp-controller="Message" asp-action="Index" class="relative p-1.5 sm:p-2 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded-full transition-all group" title="Messages">
                                <i class="far fa-comment-dots text-base sm:text-lg group-hover:text-indigo-500 dark:group-hover:text-indigo-400 transition-colors"></i>
                                <!-- Assuming you'd have an unread count from ViewBag/Component here eventually, using static dot for design -->
                                <span class="absolute top-1 right-1 w-2 h-2 bg-indigo-500 rounded-full shadow-[0_0_8px_rgba(99,102,241,0.8)]"></span>
                            </a>

                            <!-- Theme Toggle -->
                            <button class="relative p-1.5 sm:p-2 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded-full transition-all group" id="themeToggleBtn" title="Toggle Theme">
                                <i class="fas fa-moon text-base sm:text-lg transition-all duration-300 transform group-hover:rotate-12"></i>
                            </button>

                            <!-- Notifications -->
                            <div class="relative">
                                <button class="relative p-1.5 sm:p-2 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded-full transition-all group" id="notificationsBtn" title="Notifications">
                                    <i class="far fa-bell text-base sm:text-lg group-hover:text-indigo-500 dark:group-hover:text-indigo-400 transition-colors"></i>
                                    <span class="notification-badge absolute top-1 right-1.5 w-2 h-2 bg-red-500 rounded-full shadow-[0_0_8px_rgba(239,68,68,0.8)]"></span>
                                </button>
                                
                                <!-- Notifications Dropdown Placeholder -->
                                <div id="notificationsDropdown" class="hidden absolute right-0 mt-3 w-80 bg-white dark:bg-[#15171e] rounded-2xl shadow-2xl border border-slate-200 dark:border-white/10 overflow-hidden transform origin-top-right transition-all">
                                    <div class="px-4 py-3 border-b border-slate-200 dark:border-white/5 flex items-center justify-between">
                                        <h3 class="font-bold text-slate-900 dark:text-white">Notifications</h3>
                                        <button class="text-xs text-indigo-500 dark:text-indigo-400 hover:text-indigo-600 dark:hover:text-indigo-300">Mark all read</button>
                                    </div>
                                    <div class="p-4 text-center text-sm text-slate-500">
                                        No new notifications
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Search Icon (Mobile) -->
                            <button class="md:hidden p-2 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded-full transition-all">
                                <i class="fas fa-search text-lg"></i>
                            </button>

                            <!-- User Dropdown Menu (panel is fixed + JS-positioned to avoid viewport clip) -->
                            <div class="relative z-[60] ml-0.5 flex-shrink-0">
                                <button type="button" id="userMenuBtn" class="flex items-center gap-2 sm:gap-2.5 p-1 pr-2 sm:pr-3 max-w-[9.5rem] sm:max-w-[11rem] md:max-w-[13rem] lg:max-w-[15rem] bg-slate-100 dark:bg-white/5 hover:bg-slate-200 dark:hover:bg-white/10 rounded-full border border-slate-300 dark:border-white/5 transition-all" aria-expanded="false" aria-haspopup="true">
                                    <div class="w-7 h-7 sm:w-8 sm:h-8 rounded-full bg-indigo-500 border border-indigo-600 flex items-center justify-center text-white font-bold text-xs sm:text-sm overflow-hidden flex-shrink-0">
                                        @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                                    </div>
                                    <div class="hidden sm:block text-left min-w-0 flex-1">
                                        @{
                                            string userRole = User.IsInRole("Admin") ? "Admin" : User.IsInRole("Client") ? "Client" : User.IsInRole("Freelancer") ? "Freelancer" : "User";
                                        }
                                        <span class="text-xs sm:text-sm font-bold text-slate-800 dark:text-white hover:text-indigo-400 transition-colors truncate block">@User.Identity?.Name</span>
                                        <span class="text-[10px] sm:text-xs text-slate-500 dark:text-slate-400 block mt-0.5 truncate">@userRole</span>
                                    </div>
                                    <i class="fas fa-chevron-down text-[10px] sm:text-xs text-slate-500 flex-shrink-0"></i>
                                </button>

                                <div id="userMenuDropdown" class="hidden fixed w-44 max-w-[calc(100vw-1rem)] z-[200] bg-white dark:bg-[#15171e] rounded-xl shadow-2xl border border-slate-200 dark:border-white/10 py-1.5 transition-opacity duration-150">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-controller="Dashboard" asp-action="Index" class="flex items-center gap-2 px-3 py-2 text-xs text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-colors whitespace-nowrap">
                                            <i class="fas fa-gauge-high w-3.5 text-center flex-shrink-0 text-violet-500"></i>
                                            Admin home
                                        </a>
                                        <a asp-controller="Verification" asp-action="AdminIndex" class="flex items-center gap-2 px-3 py-2 text-xs text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-colors whitespace-nowrap">
                                            <i class="fas fa-id-card w-3.5 text-center flex-shrink-0"></i>
                                            ID verifications
                                        </a>
                                        <a asp-controller="Dispute" asp-action="Index" class="flex items-center gap-2 px-3 py-2 text-xs text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-colors whitespace-nowrap">
                                            <i class="fas fa-gavel w-3.5 text-center flex-shrink-0"></i>
                                            Disputes
                                        </a>
                                        <a asp-controller="Project" asp-action="Index" class="flex items-center gap-2 px-3 py-2 text-xs text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-colors whitespace-nowrap">
                                            <i class="fas fa-briefcase w-3.5 text-center flex-shrink-0"></i>
                                            Browse projects
                                        </a>
                                    }
                                    else
                                    {
                                        @if (User.IsInRole("Freelancer"))
                                        {
                                            <a asp-controller="Profile" asp-action="EditFreelancer" class="flex items-center gap-2 px-3 py-2 text-xs text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-colors whitespace-nowrap">
                                                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                                </svg>
                                                Edit Profile
                                            </a>
                                        }
                                        else if (User.IsInRole("Client"))
                                        {
                                            <a asp-controller="Profile" asp-action="EditClient" class="flex items-center gap-2 px-3 py-2 text-xs text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-colors whitespace-nowrap">
                                                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                                </svg>
                                                Edit Profile
                                            </a>
                                        }
                                        <a asp-controller="Earnings" asp-action="Index" class="flex items-center gap-2 px-3 py-2 text-xs text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-colors whitespace-nowrap">
                                            <i class="fas fa-chart-line w-3.5 text-center flex-shrink-0"></i>
                                            @(User.IsInRole("Client") ? "Spending" : "Earnings")
                                        </a>
                                        <a asp-controller="Verification" asp-action="Status" class="flex items-center gap-2 px-3 py-2 text-xs text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-colors whitespace-nowrap">
                                            <i class="fas fa-shield-alt w-3.5 text-center flex-shrink-0"></i>
                                            Verification
                                        </a>
                                        @if (User.IsInRole("Freelancer"))
                                        {
                                            <a asp-controller="Gig" asp-action="MyGigs" class="flex items-center gap-2 px-3 py-2 text-xs text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-colors whitespace-nowrap">
                                                <i class="fas fa-store w-3.5 text-center flex-shrink-0"></i>
                                                My Services
                                            </a>
                                        }
                                    }
                                    <a asp-controller="Settings" asp-action="Index" class="flex items-center gap-2 px-3 py-2 text-xs text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-colors whitespace-nowrap">
                                        <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        </svg>
                                        Settings
                                    </a>
                                    <div class="h-px bg-slate-200 dark:bg-white/10 my-1"></div>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="w-full flex items-center gap-2 px-3 py-2 text-xs text-red-400 hover:text-red-300 hover:bg-red-500/10 transition-colors text-left whitespace-nowrap">
                                            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                                            </svg>
                                            Logout
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Mobile Navigation Menu (Hidden by default, can be toggled via JS if needed, but omitted for brevity/focus on desktop layout first, handled primarily by making main nav stack if necessary) -->
                </div>
            </nav>

            <!-- Page Content -->
            <main class="flex-1 w-full max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-8">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <!-- Public Layout -->
        <header>
            <nav class="bg-gradient-to-r from-indigo-600 to-purple-600 shadow-lg">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="flex items-center justify-between h-16">
                        <a href="/" class="flex items-center text-white font-bold text-xl">
                            <i class="fas fa-handshake mr-2"></i>Freeio
                        </a>
                        <div class="hidden md:flex items-center space-x-8">
                            <a asp-controller="Home" asp-action="Index" class="text-white/80 hover:text-white transition-colors">
                                <i class="fas fa-home mr-1"></i>Home
                            </a>
                            <a asp-controller="Project" asp-action="Index" class="text-white/80 hover:text-white transition-colors">
                                <i class="fas fa-briefcase mr-1"></i>Browse Projects
                            </a>
                        </div>
                        <div class="flex items-center space-x-4">
                            <a asp-controller="Account" asp-action="Login" class="text-white/80 hover:text-white transition-colors">
                                <i class="fas fa-sign-in-alt mr-1"></i>Login
                            </a>
                            <a asp-controller="Account" asp-action="Register" class="bg-white text-indigo-600 px-4 py-2 rounded-lg font-semibold hover:bg-slate-100 transition-colors">
                                <i class="fas fa-user-plus mr-1"></i>Sign Up
                            </a>
                        </div>
                    </div>
                </div>
            </nav>
        </header>
        
        <main class="min-h-screen">
            @RenderBody()
        </main>

        <footer class="bg-slate-100 dark:bg-slate-900 text-slate-900 dark:text-white py-12 border-t border-slate-200 dark:border-slate-800">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div>
                        <h5 class="text-xl font-bold mb-4"><i class="fas fa-handshake mr-2"></i>Freeio</h5>
                        <p class="text-slate-500 dark:text-slate-400">Connect with top freelancers and find exciting projects worldwide.</p>
                    </div>
                    <div>
                        <h6 class="font-semibold mb-4">Quick Links</h6>
                        <ul class="space-y-2">
                            <li><a href="#" class="text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">About Us</a></li>
                            <li><a asp-controller="Home" asp-action="Privacy" class="text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">Privacy Policy</a></li>
                            <li><a href="#" class="text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">Terms of Service</a></li>
                            <li><a href="#" class="text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">Contact</a></li>
                        </ul>
                    </div>
                    <div>
                        <h6 class="font-semibold mb-4">Follow Us</h6>
                        <div class="flex space-x-4">
                            <a href="#" class="text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors"><i class="fab fa-facebook text-2xl"></i></a>
                            <a href="#" class="text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors"><i class="fab fa-twitter text-2xl"></i></a>
                            <a href="#" class="text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors"><i class="fab fa-linkedin text-2xl"></i></a>
                            <a href="#" class="text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors"><i class="fab fa-instagram text-2xl"></i></a>
                        </div>
                    </div>
                </div>
                <div class="border-t border-slate-300 dark:border-slate-800 mt-8 pt-8 text-center text-slate-500 dark:text-slate-400">
                    &copy; 2026 SGP Freelancing Platform. All rights reserved.
                </div>
            </div>
        </footer>
    }

    <script>
        // Theme Toggle Logic
        const themeToggleBtn = document.getElementById('themeToggleBtn');
        const htmlElement = document.documentElement;
        
        if (themeToggleBtn) {
            const themeIcon = themeToggleBtn.querySelector('i');

            // Initialize theme
            const savedTheme = localStorage.getItem('theme');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            
            if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
                htmlElement.classList.add('dark');
                themeIcon.classList.remove('fa-sun', 'text-amber-500');
                themeIcon.classList.add('fa-moon', 'text-slate-400');
            } else {
                htmlElement.classList.remove('dark');
                themeIcon.classList.remove('fa-moon', 'text-slate-400');
                themeIcon.classList.add('fa-sun', 'text-amber-500');
            }

            // Click handler
            themeToggleBtn.addEventListener('click', () => {
                themeIcon.style.transform = 'rotate(180deg) scale(0.5)';
                themeIcon.style.opacity = '0';
                
                setTimeout(() => {
                    htmlElement.classList.toggle('dark');
                    if (htmlElement.classList.contains('dark')) {
                        localStorage.theme = 'dark';
                        themeIcon.classList.remove('fa-sun', 'text-amber-500');
                        themeIcon.classList.add('fa-moon', 'text-slate-400');
                    } else {
                        localStorage.theme = 'light';
                        themeIcon.classList.remove('fa-moon', 'text-slate-400');
                        themeIcon.classList.add('fa-sun', 'text-amber-500');
                    }
                    themeIcon.style.transform = 'rotate(0deg) scale(1)';
                    themeIcon.style.opacity = '1';
                }, 150);
            });
        }
        
        // Notifications dropdown toggle
        const notificationsBtn = document.getElementById('notificationsBtn');
        const notificationsDropdown = document.getElementById('notificationsDropdown');
        
        if (notificationsBtn && notificationsDropdown) {
            notificationsBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                const userPanel = document.getElementById('userMenuDropdown');
                if (userPanel) userPanel.classList.add('hidden');
                const userBtn = document.getElementById('userMenuBtn');
                if (userBtn) userBtn.setAttribute('aria-expanded', 'false');
                notificationsDropdown.classList.toggle('hidden');
            });
            
            document.addEventListener('click', function() {
                notificationsDropdown.classList.add('hidden');
            });
            
            notificationsDropdown.addEventListener('click', function(e) {
                e.stopPropagation();
            });
        }

        // User menu: click toggle + fixed positioning inside viewport
        (function () {
            const userMenuBtn = document.getElementById('userMenuBtn');
            const userMenuDropdown = document.getElementById('userMenuDropdown');
            if (!userMenuBtn || !userMenuDropdown) return;

            function positionUserMenu() {
                if (userMenuDropdown.classList.contains('hidden')) return;
                const r = userMenuBtn.getBoundingClientRect();
                const margin = 8;
                const maxW = 176; /* w-44 */
                const menuWidth = Math.min(maxW, window.innerWidth - margin * 2);
                let rightPx = window.innerWidth - r.right;
                const leftEdge = window.innerWidth - rightPx - menuWidth;
                if (leftEdge < margin)
                    rightPx = window.innerWidth - menuWidth - margin;
                userMenuDropdown.style.top = (r.bottom + 6) + 'px';
                userMenuDropdown.style.right = rightPx + 'px';
                userMenuDropdown.style.left = 'auto';
                userMenuDropdown.style.width = menuWidth + 'px';
            }

            function closeUserMenu() {
                userMenuDropdown.classList.add('hidden');
                userMenuBtn.setAttribute('aria-expanded', 'false');
            }

            function toggleUserMenu(e) {
                e.stopPropagation();
                const notifPanel = document.getElementById('notificationsDropdown');
                if (notifPanel) notifPanel.classList.add('hidden');
                userMenuDropdown.classList.toggle('hidden');
                const open = !userMenuDropdown.classList.contains('hidden');
                userMenuBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
                if (open) positionUserMenu();
            }

            userMenuBtn.addEventListener('click', toggleUserMenu);
            userMenuDropdown.addEventListener('click', function (e) { e.stopPropagation(); });

            document.addEventListener('click', closeUserMenu);
            window.addEventListener('resize', function () {
                if (!userMenuDropdown.classList.contains('hidden')) positionUserMenu();
            });
            window.addEventListener('scroll', function () {
                if (!userMenuDropdown.classList.contains('hidden')) positionUserMenu();
            }, true);
        })();
    </script>
    
    @if (TempData["Success"] != null)
    {
        <div data-temp-success="@TempData["Success"]"></div>
    }
    @if (TempData["Error"] != null)
    {
        <div data-temp-error="@TempData["Error"]"></div>
    }
    @if (TempData["Warning"] != null)
    {
        <div data-temp-warning="@TempData["Warning"]"></div>
    }
    @if (TempData["Info"] != null)
    {
        <div data-temp-info="@TempData["Info"]"></div>
    }
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
