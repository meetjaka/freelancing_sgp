@model SGP_Freelancing.Models.DTOs.UpdateFreelancerProfileDto
@{
    ViewData["Title"] = "Edit Freelancer Profile";
    var skills = ViewBag.Skills as List<SGP_Freelancing.Models.Entities.Skill> ?? new List<SGP_Freelancing.Models.Entities.Skill>();
}

<style>
    .bento-card {
        backdrop-filter: blur(12px);
        border-radius: 1.5rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }

    html:not(.dark) .bento-card {
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid rgba(0, 0, 0, 0.08);
    }

    html.dark .bento-card {
        background: rgba(15, 17, 21, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .skill-checkbox {
        display: none;
    }

    .skill-label {
        display: inline-block;
        padding: 0.5rem 1rem;
        margin: 0.25rem;
        border-radius: 0.75rem;
        cursor: pointer;
        transition: all 0.2s;
        font-size: 0.875rem;
    }

    html:not(.dark) .skill-label {
        background: rgba(99, 102, 241, 0.08);
        border: 1px solid rgba(99, 102, 241, 0.2);
        color: rgb(99, 102, 241);
    }

    html.dark .skill-label {
        background: rgba(99, 102, 241, 0.1);
        border: 1px solid rgba(99, 102, 241, 0.3);
        color: rgb(167, 139, 250);
    }

    .skill-checkbox:checked + .skill-label {
        transform: scale(1.05);
    }

    html:not(.dark) .skill-checkbox:checked + .skill-label {
        background: rgb(99, 102, 241);
        color: white;
        border-color: rgb(99, 102, 241);
    }

    html.dark .skill-checkbox:checked + .skill-label {
        background: rgb(99, 102, 241);
        color: white;
        border-color: rgb(79, 70, 229);
    }

    .skill-label:hover {
        transform: translateY(-2px);
    }
</style>

<div class="container mx-auto px-6 py-8 max-w-4xl">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Edit Freelancer Profile</h1>
        <p class="text-slate-600 dark:text-slate-400">Update your professional information and skills</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl">
            <p class="text-green-800 dark:text-green-200">@TempData["SuccessMessage"]</p>
        </div>
    }

    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
    {
        <div class="mb-6 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl">
            <p class="text-red-800 dark:text-red-200">@ViewBag.ErrorMessage</p>
        </div>
    }

    <form asp-action="EditFreelancer" method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        
        <div asp-validation-summary="ModelOnly" class="mb-4 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl text-red-800 dark:text-red-200"></div>

        <!-- Professional Title -->
        <div class="bento-card p-6">
            <label asp-for="Title" class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
                Professional Title
            </label>
            <input asp-for="Title" 
                   class="w-full px-4 py-3 rounded-xl border bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:focus:ring-indigo-400"
                   placeholder="e.g., Full Stack Developer, UI/UX Designer" />
            <span asp-validation-for="Title" class="text-red-500 text-sm mt-1"></span>
        </div>

        <!-- Bio -->
        <div class="bento-card p-6">
            <label asp-for="Bio" class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
                Bio
            </label>
            <textarea asp-for="Bio" 
                      rows="5"
                      class="w-full px-4 py-3 rounded-xl border bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:focus:ring-indigo-400"
                      placeholder="Tell clients about your experience, expertise, and what makes you unique..."></textarea>
            <span asp-validation-for="Bio" class="text-red-500 text-sm mt-1"></span>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-2">Maximum 2000 characters</p>
        </div>

        <!-- Hourly Rate -->
        <div class="bento-card p-6">
            <label asp-for="HourlyRate" class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
                Hourly Rate (USD)
            </label>
            <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 dark:text-slate-400 font-semibold">$</span>
                <input asp-for="HourlyRate" 
                       type="number" 
                       step="0.01" 
                       min="0" 
                       max="10000"
                       class="w-full pl-8 pr-4 py-3 rounded-xl border bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:focus:ring-indigo-400"
                       placeholder="50.00" />
            </div>
            <span asp-validation-for="HourlyRate" class="text-red-500 text-sm mt-1"></span>
        </div>

        <!-- Portfolio URL -->
        <div class="bento-card p-6">
            <label asp-for="PortfolioUrl" class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
                Portfolio URL
            </label>
            <input asp-for="PortfolioUrl" 
                   type="url"
                   class="w-full px-4 py-3 rounded-xl border bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:focus:ring-indigo-400"
                   placeholder="https://yourportfolio.com" />
            <span asp-validation-for="PortfolioUrl" class="text-red-500 text-sm mt-1"></span>
        </div>

        <!-- Skills -->
        <div class="bento-card p-6">
            <label class="block text-sm font-semibold text-slate-900 dark:text-white mb-4">
                Skills
            </label>
            <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">Select all skills that apply to you</p>
            
            <div class="flex flex-wrap gap-2">
                @foreach (var skill in skills)
                {
                    var isChecked = Model?.SkillIds?.Contains(skill.Id) ?? false;
                    <div>
                        <input type="checkbox" 
                               name="SkillIds" 
                               value="@skill.Id" 
                               id="skill_@skill.Id" 
                               class="skill-checkbox"
                               @(isChecked ? "checked" : "") />
                        <label for="skill_@skill.Id" class="skill-label">
                            @skill.Name
                        </label>
                    </div>
                }
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex gap-4 pt-4">
            <button type="submit" 
                    class="flex-1 px-6 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-semibold rounded-xl transition-all transform hover:scale-[1.02] shadow-lg">
                Save Profile
            </button>
            <a asp-controller="Dashboard" asp-action="Index" 
               class="px-6 py-3 bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-300 font-semibold rounded-xl border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700 transition-all text-center">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
