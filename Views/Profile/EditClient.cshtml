@model SGP_Freelancing.Models.DTOs.UpdateClientProfileDto
@{
    ViewData["Title"] = "Edit Client Profile";
}

<style>
    .bento-card {
        backdrop-filter: blur(12px);
        border-radius: 1.5rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }

    html:not(.dark) .bento-card {
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid rgba(0, 0, 0, 0.08);
    }

    html.dark .bento-card {
        background: rgba(15, 17, 21, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
</style>

<div class="container mx-auto px-6 py-8 max-w-4xl">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Edit Client Profile</h1>
        <p class="text-slate-600 dark:text-slate-400">Update your company information</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl">
            <p class="text-green-800 dark:text-green-200">@TempData["SuccessMessage"]</p>
        </div>
    }

    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
    {
        <div class="mb-6 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl">
            <p class="text-red-800 dark:text-red-200">@ViewBag.ErrorMessage</p>
        </div>
    }

    <form asp-action="EditClient" method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        
        <div asp-validation-summary="ModelOnly" class="mb-4 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl text-red-800 dark:text-red-200"></div>

        <!-- Company Name -->
        <div class="bento-card p-6">
            <label asp-for="CompanyName" class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
                Company Name
            </label>
            <input asp-for="CompanyName" 
                   class="w-full px-4 py-3 rounded-xl border bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:focus:ring-indigo-400"
                   placeholder="e.g., Acme Corporation" />
            <span asp-validation-for="CompanyName" class="text-red-500 text-sm mt-1"></span>
        </div>

        <!-- Company Description -->
        <div class="bento-card p-6">
            <label asp-for="CompanyDescription" class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
                Company Description
            </label>
            <textarea asp-for="CompanyDescription" 
                      rows="5"
                      class="w-full px-4 py-3 rounded-xl border bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:focus:ring-indigo-400"
                      placeholder="Tell freelancers about your company, industry, and what you're looking for..."></textarea>
            <span asp-validation-for="CompanyDescription" class="text-red-500 text-sm mt-1"></span>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-2">Maximum 1000 characters</p>
        </div>

        <!-- Website -->
        <div class="bento-card p-6">
            <label asp-for="Website" class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
                Company Website
            </label>
            <input asp-for="Website" 
                   type="url"
                   class="w-full px-4 py-3 rounded-xl border bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:focus:ring-indigo-400"
                   placeholder="https://yourcompany.com" />
            <span asp-validation-for="Website" class="text-red-500 text-sm mt-1"></span>
        </div>

        <!-- Action Buttons -->
        <div class="flex gap-4 pt-4">
            <button type="submit" 
                    class="flex-1 px-6 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-semibold rounded-xl transition-all transform hover:scale-[1.02] shadow-lg">
                Save Profile
            </button>
            <a asp-controller="Dashboard" asp-action="Index" 
               class="px-6 py-3 bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-300 font-semibold rounded-xl border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700 transition-all text-center">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
