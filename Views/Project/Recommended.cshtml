@model List<SGP_Freelancing.Models.DTOs.ProjectDto>
@{
    ViewData["Title"] = "AI Recommended Projects";
}

<!-- Page Header -->
<div class="mb-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-500/10 border border-indigo-500/20 rounded-full mb-4">
        <i class="fas fa-robot text-indigo-500"></i>
        <span class="text-xs font-bold text-indigo-500 tracking-wider">POWERED BY AI</span>
    </div>
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Your AI Recommendations <span class="text-indigo-500 dark:text-indigo-400">✦</span></h1>
    <p class="text-slate-500 dark:text-slate-400">These projects were specifically matched to your unique profile skills using our advanced Content-Based Machine Learning model.</p>
</div>

<div class="space-y-4 max-w-4xl">
    @if (Model != null && Model.Any())
    {
        @foreach (var project in Model)
        {
            <div class="bento-card p-6 flex flex-col group relative">
                <!-- Decorative glow on hover (AI theme) -->
                <div class="absolute -inset-0.5 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-2xl blur opacity-0 group-hover:opacity-20 transition duration-500 pointer-events-none"></div>
                
                <div class="relative flex items-start justify-between mb-4">
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="inline-flex items-center px-2.5 py-1 bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 text-[10px] font-bold uppercase tracking-wider rounded-full border border-indigo-500/20">@project.CategoryName</span>
                            <span class="text-xs text-emerald-500 font-medium whitespace-nowrap"><i class="fas fa-bolt mr-1"></i> High AI Match</span>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-indigo-500 dark:group-hover:text-indigo-400 transition-colors">
                            <a asp-action="Details" asp-route-id="@project.Id">@project.Title</a>
                        </h3>
                        <p class="text-slate-500 dark:text-slate-400 line-clamp-2 mb-4 text-sm">
                            @(project.Description.Length > 200 ? project.Description.Substring(0, 200) + "..." : project.Description)
                        </p>
                        
                        @if (project.Skills.Any())
                        {
                            <div class="flex flex-wrap gap-2 mb-4">
                                @foreach (var skill in project.Skills.Take(5))
                                {
                                    <span class="px-2.5 py-1 bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-600 dark:text-slate-300 text-[11px] font-bold rounded-lg">@skill</span>
                                }
                                @if (project.Skills.Count() > 5)
                                {
                                    <span class="px-2.5 py-1 bg-indigo-500/10 border border-indigo-500/20 text-indigo-600 dark:text-indigo-400 text-[11px] font-bold rounded-lg">+@(project.Skills.Count() - 5)</span>
                                }
                            </div>
                        }
                    </div>
                    <div class="text-right ml-6 flex-shrink-0 flex flex-col items-end gap-2">
                        <p class="text-2xl font-bold text-slate-900 dark:text-white mb-1 tracking-tight">$@project.Budget.ToString("N0")</p>
                        <p class="text-[11px] uppercase tracking-wider font-bold text-slate-500">Budget</p>
                    </div>
                </div>
                
                <div class="relative flex items-center justify-between pt-4 border-t border-slate-200 dark:border-white/5 mt-auto">
                    <div class="flex items-center gap-6 text-sm text-slate-500 dark:text-slate-400 font-medium">
                        <div class="flex items-center gap-2">
                            <i class="far fa-user text-slate-400 dark:text-slate-500"></i>
                            <span>@project.ClientName</span>
                        </div>
                    </div>
                    <a asp-action="Details" asp-route-id="@project.Id" class="inline-flex items-center gap-2 px-5 py-2 bg-indigo-500 hover:bg-indigo-400 text-white font-bold text-sm rounded-full transition-colors border border-indigo-500 shadow-[0_0_15px_rgba(99,102,241,0.3)]">
                        Apply Now
                        <i class="fas fa-arrow-right text-[10px]"></i>
                    </a>
                </div>
            </div>
        }
    }
    else
    {
        <div class="py-20 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-2xl shadow-inner backdrop-blur-sm overflow-hidden">
            <div class="max-w-2xl pl-6 sm:pl-10 lg:pl-14 pr-6 sm:pr-10 lg:pr-14 flex flex-col items-start border-l-4 border-indigo-500/70">
                <div class="w-20 h-20 bg-slate-200 dark:bg-[#12141a] border border-slate-300 dark:border-white/5 rounded-full flex items-center justify-center mb-6 shadow-lg">
                    <i class="fas fa-robot text-3xl text-indigo-400 dark:text-indigo-500"></i>
                </div>
                <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">No active matches found</h3>
                <p class="text-slate-500 dark:text-slate-400 mb-8 max-w-lg leading-relaxed">We couldn't find any perfect AI matches right now. Make sure your Freelancer profile has Skills added to it so the AI can learn what you are good at!</p>
                <div class="flex justify-start gap-3">
                    <a href="/Profile/EditFreelancer" class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-500 hover:bg-indigo-400 text-white font-bold rounded-full transition-all shadow-[0_0_20px_rgba(99,102,241,0.3)] hover:shadow-[0_0_25px_rgba(99,102,241,0.5)]">
                        Update My Skills
                        <i class="fas fa-arrow-right text-sm"></i>
                    </a>
                </div>
            </div>
        </div>
    }
</div>
