@model SGP_Freelancing.Models.DTOs.CreateProjectDto
@{
    ViewData["Title"] = "Post New Project";
}

<style>
    .glass-panel {
        backdrop-filter: blur(18px);
        border: 1px solid rgba(99, 102, 241, 0.12);
        box-shadow: 0 24px 70px rgba(15, 23, 42, 0.10);
    }

    html.dark .glass-panel {
        background: rgba(15, 17, 21, 0.72);
        border-color: rgba(255, 255, 255, 0.06);
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.45);
    }

    .hero-orb {
        position: absolute;
        border-radius: 9999px;
        filter: blur(36px);
        pointer-events: none;
    }
</style>

<!-- Header -->
<div class="relative overflow-hidden mb-8 rounded-b-[2rem]">
    <div class="absolute inset-0 bg-gradient-to-r from-indigo-600 via-violet-600 to-fuchsia-600"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/15 rounded-full blur-3xl -mr-48 -mt-48"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-cyan-300/15 rounded-full blur-3xl -ml-48 -mb-48"></div>
    <div class="max-w-6xl mx-auto px-6 py-16 relative z-10 text-white">
        <div class="max-w-3xl">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/20 bg-white/10 text-xs font-bold uppercase tracking-[0.25em] mb-5">
                <i class="fas fa-sparkles"></i>
                Client Workspace
            </div>
            <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-4">Post a project that attracts serious freelancers</h1>
            <p class="text-base md:text-lg text-white/85 max-w-2xl leading-relaxed">Describe the work clearly, set the budget, and let the platform surface the right talent for the job.</p>
        </div>
    </div>
</div>

<div class="max-w-6xl mx-auto px-6 pb-10">
    <div class="grid grid-cols-1 xl:grid-cols-12 gap-8 items-start">
        <div class="xl:col-span-4">
            <div class="glass-panel bg-white/90 dark:bg-[#11131a]/80 rounded-[1.75rem] p-6 md:p-8 sticky top-28">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-indigo-600 to-violet-600 text-white flex items-center justify-center shadow-lg shadow-indigo-500/25">
                        <i class="fas fa-magic"></i>
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase tracking-[0.2em] text-indigo-500 dark:text-indigo-400">Tips for Success</p>
                        <h2 class="text-xl font-black text-slate-900 dark:text-white">Write for clarity</h2>
                    </div>
                </div>

                <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-6">
                    A stronger brief gets better bids. Keep the title specific, explain the outcome you want, and mention the skills or tools you expect.
                </p>

                <div class="space-y-4">
                    <div class="flex gap-3 p-4 rounded-2xl bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/5">
                        <div class="w-10 h-10 rounded-xl bg-indigo-500/10 text-indigo-500 flex items-center justify-center shrink-0">
                            <i class="fas fa-check"></i>
                        </div>
                        <div>
                            <p class="font-bold text-slate-900 dark:text-white">Use a clear title</p>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Describe the project in one sentence.</p>
                        </div>
                    </div>
                    <div class="flex gap-3 p-4 rounded-2xl bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/5">
                        <div class="w-10 h-10 rounded-xl bg-violet-500/10 text-violet-500 flex items-center justify-center shrink-0">
                            <i class="fas fa-layer-group"></i>
                        </div>
                        <div>
                            <p class="font-bold text-slate-900 dark:text-white">Mention the stack</p>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Add technologies so the right freelancers respond.</p>
                        </div>
                    </div>
                    <div class="flex gap-3 p-4 rounded-2xl bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/5">
                        <div class="w-10 h-10 rounded-xl bg-fuchsia-500/10 text-fuchsia-500 flex items-center justify-center shrink-0">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div>
                            <p class="font-bold text-slate-900 dark:text-white">Set a realistic budget</p>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Good budgets get stronger proposals.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="xl:col-span-8">
            <div class="glass-panel bg-white/90 dark:bg-[#11131a]/80 rounded-[1.75rem] p-6 md:p-10">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 px-4 py-3 rounded-lg mb-6 transition-colors duration-300"></div>
            
            <!-- Project Details Section -->
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 bg-gradient-to-br from-indigo-600 to-purple-600 rounded-lg flex items-center justify-center text-white">
                    <i class="fas fa-clipboard-list"></i>
                </div>
                <h2 class="text-xl font-bold text-gray-800 dark:text-white transition-colors duration-300">Project Details</h2>
            </div>

            <div class="mb-6">
                <label asp-for="Title" class="block text-sm font-semibold text-gray-700 dark:text-slate-300 mb-2 transition-colors duration-300">
                    Project Title *
                </label>
                <input asp-for="Title" class="w-full px-5 py-4 border-2 border-gray-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500 rounded-xl text-base transition-all focus:border-indigo-600 focus:ring-4 focus:ring-indigo-100 dark:focus:ring-indigo-900/30 outline-none" placeholder="e.g., Build a responsive e-commerce website" maxlength="100" />
                <span asp-validation-for="Title" class="text-red-600 dark:text-red-400 text-sm transition-colors duration-300"></span>
                <div class="text-xs text-gray-500 dark:text-slate-400 mt-1 transition-colors duration-300">
                    <i class="fas fa-info-circle mr-1"></i>
                    Make it clear and specific
                </div>
            </div>
            
            <div class="mb-6">
                <label asp-for="Description" class="block text-sm font-semibold text-gray-700 dark:text-slate-300 mb-2 transition-colors duration-300">
                    Project Description *
                </label>
                <textarea asp-for="Description" class="w-full px-5 py-4 border-2 border-gray-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500 rounded-xl text-base transition-all focus:border-indigo-600 focus:ring-4 focus:ring-indigo-100 dark:focus:ring-indigo-900/30 outline-none" rows="8" placeholder="Describe your project in detail. Include objectives, requirements, preferred technologies, and any specific deliverables..." id="descriptionField"></textarea>
                <span asp-validation-for="Description" class="text-red-600 dark:text-red-400 text-sm transition-colors duration-300"></span>
                <div class="text-right text-xs text-gray-500 dark:text-slate-400 mt-1 transition-colors duration-300">
                    <span id="charCount">0</span> characters
                </div>
            </div>

            <div class="mb-6">
                <div class="flex justify-between items-end mb-2">
                    <label asp-for="CategoryId" class="block text-sm font-semibold text-gray-700 dark:text-slate-300 transition-colors duration-300">
                        Category *
                    </label>
                    <button type="button" id="btnPredictCategory" class="text-xs text-indigo-600 dark:text-indigo-400 font-bold bg-indigo-50 dark:bg-indigo-900/30 px-3 py-1 rounded-full hover:bg-indigo-100 transition-colors">
                        <i class="fas fa-magic mr-1"></i> Auto-Detect
                    </button>
                </div>
                <select asp-for="CategoryId" class="w-full px-5 py-4 border-2 border-gray-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-gray-900 dark:text-white rounded-xl text-base transition-all focus:border-indigo-600 focus:ring-4 focus:ring-indigo-100 dark:focus:ring-indigo-900/30 outline-none appearance-none bg-no-repeat bg-[length:1em] bg-[position:right_1rem_center] bg-[url('data:image/svg+xml,%3csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270%200%2016%2016%27%3e%3cpath fill=%27none%27 stroke=%27%238B7BE6%27 stroke-linecap=%27round%27 stroke-linejoin=%27round%27 stroke-width=%272%27 d=%27M2%205l6%206%206-6%27/%3e%3c/svg%3e')]">
                    <option value="">Select a category</option>
                    <option value="1">💻 Web Development</option>
                    <option value="2">📱 Mobile Development</option>
                    <option value="3">🎨 Design & Creative</option>
                    <option value="4">✍️ Writing & Translation</option>
                    <option value="5">📊 Data Science & AI</option>
                    <option value="6">📈 Digital Marketing</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-red-600 dark:text-red-400 text-sm transition-colors duration-300"></span>
            </div>

            <div class="mb-6">
                <div class="flex justify-between items-end mb-2">
                    <label asp-for="SkillIds" class="block text-sm font-semibold text-gray-700 dark:text-slate-300 transition-colors duration-300">
                        Required Skills
                    </label>
                    <button type="button" id="btnExtractSkills" class="text-xs text-fuchsia-600 dark:text-fuchsia-400 font-bold bg-fuchsia-50 dark:bg-fuchsia-900/30 px-3 py-1 rounded-full hover:bg-fuchsia-100 transition-colors">
                        <i class="fas fa-brain mr-1"></i> Auto-Extract
                    </button>
                </div>
                <!-- Note: using standard multi-select. Can be enhanced with Select2 or similar JS libraries later -->
                <select asp-for="SkillIds" id="SkillIds" multiple class="w-full px-5 py-4 border-2 border-gray-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-gray-900 dark:text-white rounded-xl text-base transition-all focus:border-indigo-600 focus:ring-4 focus:ring-indigo-100 dark:focus:ring-indigo-900/30 outline-none" style="height: 150px;">
                    @if (ViewBag.Skills != null)
                    {
                        foreach (var skill in ViewBag.Skills)
                        {
                            <option value="@skill.Id">@skill.Name</option>
                        }
                    }
                </select>
                <div class="text-xs text-gray-500 dark:text-slate-400 mt-1 transition-colors duration-300">
                    <i class="fas fa-info-circle mr-1"></i>
                    Hold Ctrl (or Cmd) to select multiple skills manually. AI can also extract them from your description!
                </div>
                <span asp-validation-for="SkillIds" class="text-red-600 dark:text-red-400 text-sm transition-colors duration-300"></span>
            </div>

            <div class="h-px bg-gradient-to-r from-transparent via-gray-200 dark:via-slate-600 to-transparent my-10 transition-colors duration-300"></div>

            <!-- Budget & Timeline Section -->
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 bg-gradient-to-br from-indigo-600 to-purple-600 rounded-lg flex items-center justify-center text-white">
                    <i class="fas fa-dollar-sign"></i>
                </div>
                <h2 class="text-xl font-bold text-gray-800 dark:text-white transition-colors duration-300">Budget & Timeline</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <div class="flex justify-between items-end mb-2">
                        <label asp-for="Budget" class="block text-sm font-semibold text-gray-700 dark:text-slate-300 transition-colors duration-300">
                            Project Budget *
                        </label>
                        <button type="button" id="btnPredictBudget" class="text-xs text-green-600 dark:text-green-400 font-bold bg-green-50 dark:bg-green-900/30 px-3 py-1 rounded-full hover:bg-green-100 transition-colors">
                            <i class="fas fa-robot mr-1"></i> Predict Fair Rate
                        </button>
                    </div>
                    <div class="relative">
                        <span class="absolute left-5 top-1/2 -translate-y-1/2 font-bold text-gray-600 dark:text-slate-400 text-base z-10 transition-colors duration-300">$</span>
                        <input asp-for="Budget" type="number" step="0.01" class="w-full pl-10 pr-5 py-4 border-2 border-gray-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500 rounded-xl text-base transition-all focus:border-indigo-600 focus:ring-4 focus:ring-indigo-100 dark:focus:ring-indigo-900/30 outline-none" placeholder="2500" />
                    </div>
                    <span asp-validation-for="Budget" class="text-red-600 dark:text-red-400 text-sm transition-colors duration-300"></span>
                    <div class="text-xs text-gray-500 dark:text-slate-400 mt-1 transition-colors duration-300">
                        <i class="fas fa-info-circle mr-1"></i>
                        Set a realistic budget
                    </div>
                </div>
                <div>
                    <label asp-for="Deadline" class="block text-sm font-semibold text-gray-700 dark:text-slate-300 mb-2 transition-colors duration-300">
                        Deadline (Optional)
                    </label>
                    <input asp-for="Deadline" type="date" class="w-full px-5 py-4 border-2 border-gray-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-gray-900 dark:text-white rounded-xl text-base transition-all focus:border-indigo-600 focus:ring-4 focus:ring-indigo-100 dark:focus:ring-indigo-900/30 outline-none" />
                    <span asp-validation-for="Deadline" class="text-red-600 dark:text-red-400 text-sm transition-colors duration-300"></span>
                    <div class="text-xs text-gray-500 dark:text-slate-400 mt-1 transition-colors duration-300">
                        <i class="fas fa-info-circle mr-1"></i>
                        When do you need it done?
                    </div>
                </div>
            </div>

            <div class="h-px bg-gradient-to-r from-transparent via-gray-200 dark:via-slate-600 to-transparent my-10 transition-colors duration-300"></div>

            <!-- Requirements Files -->
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 bg-gradient-to-br from-indigo-600 to-purple-600 rounded-lg flex items-center justify-center text-white">
                    <i class="fas fa-paperclip"></i>
                </div>
                <h2 class="text-xl font-bold text-gray-800 dark:text-white transition-colors duration-300">Project Requirement Files</h2>
            </div>

            <div class="mb-8">
                <label class="block text-sm font-semibold text-gray-700 dark:text-slate-300 mb-2 transition-colors duration-300">
                    Upload Files (Optional)
                </label>
                <input type="file" name="projectFiles" multiple class="w-full px-5 py-4 border-2 border-dashed border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-gray-900 dark:text-white rounded-xl text-base transition-all focus:border-indigo-600 focus:ring-4 focus:ring-indigo-100 dark:focus:ring-indigo-900/30 outline-none" />
                <div class="text-xs text-gray-500 dark:text-slate-400 mt-1 transition-colors duration-300">
                    <i class="fas fa-info-circle mr-1"></i>
                    You can add requirement docs, reference images, zip files, and other project materials (max 10MB each).
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div class="md:col-span-3">
                    <button type="submit" class="w-full py-5 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold text-lg rounded-xl transition-all hover:-translate-y-1 hover:shadow-2xl hover:shadow-indigo-400/40">
                        <i class="fas fa-rocket mr-2"></i>Post Project
                    </button>
                </div>
                <div class="md:col-span-1">
                    <a asp-action="Index" class="block w-full py-5 bg-white dark:bg-slate-700 text-gray-600 dark:text-slate-300 font-semibold text-base rounded-xl border-2 border-gray-200 dark:border-slate-600 transition-all hover:border-indigo-600 dark:hover:border-indigo-400 hover:text-indigo-600 dark:hover:text-indigo-400 text-center">
                        <i class="fas fa-times mr-2"></i>Cancel
                    </a>
                </div>
            </div>

            <p class="text-center mt-6 text-sm text-gray-500 dark:text-slate-400 transition-colors duration-300">
                <i class="fas fa-shield-alt mr-1"></i>
                Your project will be visible to thousands of qualified freelancers
            </p>
        </form>
            </div>
        </div>
    </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Character counter
        document.getElementById('descriptionField').addEventListener('input', function() {
            document.getElementById('charCount').textContent = this.value.length;
        });

        // Set minimum date for deadline
        const today = new Date().toISOString().split('T')[0];
        const deadlineInput = document.querySelector('input[name="Deadline"]');
        if (deadlineInput) {
            deadlineInput.setAttribute('min', today);
        }

        // ML Predictions
        const getTitleDesc = () => ({
            title: document.getElementById('Title').value,
            description: document.getElementById('descriptionField').value
        });

        document.getElementById('btnPredictCategory').addEventListener('click', async function() {
            const data = getTitleDesc();
            if (!data.title && !data.description) {
                alert("Please enter title and description first.");
                return;
            }
            
            const btn = this;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Predicting...';
            btn.disabled = true;

            try {
                const response = await fetch('/api/ml/predict-category', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'same-origin',
                    body: JSON.stringify(data)
                });
                
                if (response.ok) {
                    const result = await response.json();
                    const categorySelect = document.getElementById('CategoryId');
                    
                    const categoryMap = {
                        'technology programming': 'Web Development',
                        'design multimedia': 'Design & Creative',
                        'writing translation': 'Writing & Translation',
                        'sales marketing': 'Digital Marketing',
                        'data entry': 'Data Science & AI',
                        'admin support': 'Digital Marketing'
                    };
                    
                    let aiSuggested = result.predicted_category.toLowerCase();
                    let targetText = categoryMap[aiSuggested] ? categoryMap[aiSuggested].toLowerCase() : aiSuggested;

                    // Find the matching option text
                    let found = false;
                    for (let i = 0; i < categorySelect.options.length; i++) {
                        if (categorySelect.options[i].text.toLowerCase().includes(targetText) || 
                            categorySelect.options[i].text.toLowerCase().includes(aiSuggested)) {
                            categorySelect.selectedIndex = i;
                            found = true;
                            // Add a visual flash
                            categorySelect.classList.add('ring-2', 'ring-green-400');
                            setTimeout(() => categorySelect.classList.remove('ring-2', 'ring-green-400'), 1500);
                            break;
                        }
                    }
                    if (!found) alert(`AI suggested: ${result.predicted_category}, but we couldn't properly map it to the dropdown.`);
                } else {
                    const err = await response.text();
                    console.error("Auto detect failed:", err);
                    alert("Failed to reach AI service properly. Please check console.");
                }
            } catch (err) {
                console.error("Auto detect exception:", err);
                alert("Something went wrong with the AI prediction.");
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        });

        document.getElementById('btnPredictBudget').addEventListener('click', async function() {
            const data = getTitleDesc();
            if (!data.title && !data.description) {
                alert("Please enter title and description first.");
                return;
            }

            const categorySelect = document.getElementById('CategoryId');
            const categoryText = categorySelect.options[categorySelect.selectedIndex]?.text || "";
            
            const btn = this;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Computing...';
            btn.disabled = true;

            try {
                const response = await fetch('/api/ml/predict-budget', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'same-origin',
                    body: JSON.stringify({
                        ...data,
                        category: categoryText.replace(/[^a-zA-Z\s]/g, '').trim(), // Remove emojis
                        experience_level: 2
                    })
                });
                
                if (response.ok) {
                    const result = await response.json();
                    const budgetInput = document.getElementById('Budget');
                    budgetInput.value = result.predicted_budget_usd;
                    
                    // Visual flash
                    budgetInput.classList.add('ring-2', 'ring-green-400');
                    setTimeout(() => budgetInput.classList.remove('ring-2', 'ring-green-400'), 1500);
                } else {
                    const err = await response.text();
                    console.error("Predict budget failed:", err);
                    alert("Failed to reach AI service properly.");
                }
            } catch (err) {
                console.error("Predict budget exception:", err);
                alert("Something went wrong with the budget prediction.");
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        });

        document.getElementById('btnExtractSkills').addEventListener('click', async function() {
            const data = getTitleDesc();
            if (!data.description) {
                alert("Please enter a project description first so the AI can extract skills from it.");
                return;
            }

            const btn = this;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Extracting...';
            btn.disabled = true;

            try {
                const response = await fetch('/api/ml/extract-skills', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'same-origin',
                    body: JSON.stringify({
                        text: data.description,
                        top_n: 10
                    })
                });
                
                if (response.ok) {
                    const result = await response.json();
                    const skillSelect = document.getElementById('SkillIds');
                    let optionsFound = 0;

                    // Deselect currently selected options
                    for (let i = 0; i < skillSelect.options.length; i++) {
                        skillSelect.options[i].selected = false;
                    }

                    // Extract AI skills as a flat array of lowercase strings
                    const aiSkills = result.skills.map(s => s.skill.toLowerCase());

                    // Check which HTML options match the AI suggestions
                    for (let i = 0; i < skillSelect.options.length; i++) {
                        const optionText = skillSelect.options[i].text.toLowerCase();
                        if (aiSkills.some(ai => optionText.includes(ai) || ai.includes(optionText))) {
                            skillSelect.options[i].selected = true;
                            optionsFound++;
                        }
                    }

                    if (optionsFound > 0) {
                        skillSelect.classList.add('ring-2', 'ring-fuchsia-400');
                        setTimeout(() => skillSelect.classList.remove('ring-2', 'ring-fuchsia-400'), 1500);
                        
                        // Scroll to the skills box visually
                        skillSelect.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    } else {
                        alert(`AI extracted: ${aiSkills.join(', ')}. None of these strictly align with our DB categories.`);
                    }
                } else {
                    const err = await response.text();
                    console.error("Extract skills failed:", err);
                    alert("Failed to reach AI service properly.");
                }
            } catch (err) {
                console.error("Extract skills exception:", err);
                alert("Something went wrong with the skill extraction.");
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        });
    </script>
}
