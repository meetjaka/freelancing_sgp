@model SGP_Freelancing.Models.DTOs.PagedResult<SGP_Freelancing.Models.DTOs.ProjectDto>
@{
    ViewData["Title"] = "Browse Projects";
}

<!-- Page Header -->
<div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Browse Projects <span class="text-indigo-500 dark:text-indigo-400">✦</span></h1>
    <p class="text-slate-500 dark:text-slate-400">Find your next opportunity from thousands of projects</p>
</div>

<!-- Search Bar -->
<form asp-action="Index" method="get" class="mb-8">
    <div class="flex gap-3">
        <div class="flex-1 relative">
            <i class="fas fa-search absolute left-4 top-1/2 transform -translate-y-1/2 text-slate-400 dark:text-slate-500"></i>
            <input type="text" name="searchTerm" placeholder="Search projects..." value="@ViewBag.SearchTerm" class="w-full pl-12 pr-4 py-3 bg-white dark:bg-[#12141a] border border-slate-300 dark:border-white/5 rounded-xl text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 transition-all font-medium shadow-sm dark:shadow-inner">
        </div>
        <button type="submit" class="px-6 py-3 bg-indigo-500 hover:bg-indigo-400 text-white font-bold rounded-xl transition-all shadow-[0_0_20px_rgba(99,102,241,0.3)]">
            Search
        </button>
    </div>
</form>

<div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
    <!-- Filters Sidebar -->
    <div class="lg:col-span-1">
        <div class="bento-card p-6 sticky top-24">
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                <i class="fas fa-filter text-indigo-500 dark:text-indigo-400"></i>
                Filters
            </h3>

            <form asp-action="Index" method="get">
                <input type="hidden" name="searchTerm" value="@ViewBag.SearchTerm">
                
                <!-- Category -->
                <div class="mb-6">
                    <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-3">Category</label>
                    <div class="space-y-2">
                        <label class="flex items-center gap-3 cursor-pointer hover:bg-slate-100 dark:hover:bg-white/5 p-2 rounded-lg transition-colors group">
                            <input type="radio" name="categoryId" value="" class="w-4 h-4 text-indigo-500 bg-slate-100 dark:bg-white/5 border-slate-300 dark:border-white/20 focus:ring-indigo-500 focus:ring-offset-white dark:focus:ring-offset-[#15171e]" checked>
                            <span class="text-sm text-slate-600 dark:text-slate-400 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">All Categories</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer hover:bg-slate-100 dark:hover:bg-white/5 p-2 rounded-lg transition-colors group">
                            <input type="radio" name="categoryId" value="1" class="w-4 h-4 text-indigo-500 bg-slate-100 dark:bg-white/5 border-slate-300 dark:border-white/20 focus:ring-indigo-500 focus:ring-offset-white dark:focus:ring-offset-[#15171e]">
                            <span class="text-sm text-slate-600 dark:text-slate-400 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">Web Development</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer hover:bg-slate-100 dark:hover:bg-white/5 p-2 rounded-lg transition-colors group">
                            <input type="radio" name="categoryId" value="2" class="w-4 h-4 text-indigo-500 bg-slate-100 dark:bg-white/5 border-slate-300 dark:border-white/20 focus:ring-indigo-500 focus:ring-offset-white dark:focus:ring-offset-[#15171e]">
                            <span class="text-sm text-slate-600 dark:text-slate-400 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">Mobile Development</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer hover:bg-slate-100 dark:hover:bg-white/5 p-2 rounded-lg transition-colors group">
                            <input type="radio" name="categoryId" value="3" class="w-4 h-4 text-indigo-500 bg-slate-100 dark:bg-white/5 border-slate-300 dark:border-white/20 focus:ring-indigo-500 focus:ring-offset-white dark:focus:ring-offset-[#15171e]">
                            <span class="text-sm text-slate-600 dark:text-slate-400 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">Design & Creative</span>
                        </label>
                    </div>
                </div>

                <!-- Budget Range -->
                <div class="mb-6">
                    <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-3">Budget Range</label>
                    <select name="budgetRange" class="w-full px-4 py-2.5 bg-white dark:bg-[#12141a] border border-slate-300 dark:border-white/10 text-slate-900 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/50 appearance-none font-medium">
                        <option value="">Any Budget</option>
                        <option value="0-500">$0 - $500</option>
                        <option value="500-1000">$500 - $1,000</option>
                        <option value="1000-2500">$1,000 - $2,500</option>
                        <option value="2500-5000">$2,500 - $5,000</option>
                        <option value="5000+">$5,000+</option>
                    </select>
                </div>

                <button type="submit" class="w-full px-4 py-2.5 bg-slate-100 dark:bg-white/5 hover:bg-slate-200 dark:hover:bg-white/10 text-slate-900 dark:text-white font-bold border border-slate-300 dark:border-white/10 rounded-lg transition-all text-sm">
                    Apply Filters
                </button>
            </form>
        </div>
    </div>

    <!-- Projects List -->
    <div class="lg:col-span-3">
        @if (User.IsInRole("Client"))
        {
            <div class="bg-indigo-50 dark:bg-indigo-900/20 border border-indigo-200 dark:border-indigo-800 rounded-xl p-4 mb-6 flex items-center gap-3">
                <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-sm text-indigo-900 dark:text-indigo-300">Want to post a project? <a asp-action="Create" class="font-semibold hover:underline">Click here to get started</a></span>
            </div>
        }

        <!-- Results Header -->
        <div class="flex items-center justify-between mb-6">
            <p class="text-sm text-slate-600 dark:text-slate-400">
                <span class="font-semibold text-slate-900 dark:text-white">@Model.TotalCount</span> projects found
            </p>
            <select class="px-4 py-2 bg-white dark:bg-[#12141a] border border-slate-300 dark:border-white/10 text-sm text-slate-900 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500">
                <option>Newest first</option>
                <option>Budget: High to Low</option>
                <option>Budget: Low to High</option>
                <option>Most bids</option>
            </select>
        </div>

        <!-- Projects Grid -->
        <div class="space-y-4">
            @if (Model.Items.Any())
            {
                @foreach (var project in Model.Items)
                {
                    <div class="bento-card p-6 flex flex-col group relative">
                        <!-- Decorative glow on hover -->
                        <div class="absolute -inset-0.5 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-2xl blur opacity-0 group-hover:opacity-20 transition duration-500 pointer-events-none"></div>
                        
                        <div class="relative flex items-start justify-between mb-4">
                            <div class="flex-1">
                                <div class="flex items-center gap-3 mb-2">
                                    <span class="inline-flex items-center px-2.5 py-1 bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 text-[10px] font-bold uppercase tracking-wider rounded-full border border-indigo-500/20">@project.CategoryName</span>
                                    <span class="text-xs text-slate-500 font-medium">Posted 2 days ago</span>
                                </div>
                                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-indigo-500 dark:group-hover:text-indigo-400 transition-colors">
                                    <a asp-action="Details" asp-route-id="@project.Id">@project.Title</a>
                                </h3>
                                <p class="text-slate-500 dark:text-slate-400 line-clamp-2 mb-4 text-sm">
                                    @(project.Description.Length > 200 ? project.Description.Substring(0, 200) + "..." : project.Description)
                                </p>
                                
                                @if (project.Skills.Any())
                                {
                                    <div class="flex flex-wrap gap-2 mb-4">
                                        @foreach (var skill in project.Skills.Take(5))
                                        {
                                            <span class="px-2.5 py-1 bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-600 dark:text-slate-300 text-[11px] font-bold rounded-lg">@skill</span>
                                        }
                                        @if (project.Skills.Count() > 5)
                                        {
                                            <span class="px-2.5 py-1 bg-indigo-500/10 border border-indigo-500/20 text-indigo-600 dark:text-indigo-400 text-[11px] font-bold rounded-lg">+@(project.Skills.Count() - 5)</span>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="text-right ml-6 flex-shrink-0">
                                <p class="text-2xl font-bold text-slate-900 dark:text-white mb-1 tracking-tight">$@project.Budget.ToString("N0")</p>
                                <p class="text-[11px] uppercase tracking-wider font-bold text-slate-500">Fixed Price</p>
                            </div>
                        </div>
                        
                        <div class="relative flex items-center justify-between pt-4 border-t border-slate-200 dark:border-white/5 mt-auto">
                            <div class="flex items-center gap-6 text-sm text-slate-500 dark:text-slate-400 font-medium">
                                <div class="flex items-center gap-2">
                                    <i class="far fa-user text-slate-400 dark:text-slate-500"></i>
                                    <span>@project.ClientName</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <i class="far fa-file-alt text-slate-400 dark:text-slate-500"></i>
                                    <span>@project.BidsCount bids</span>
                                </div>
                            </div>
                            <a asp-action="Details" asp-route-id="@project.Id" class="inline-flex items-center gap-2 px-5 py-2 bg-slate-100 dark:bg-white/5 hover:bg-slate-200 dark:hover:bg-white/10 text-slate-900 dark:text-white font-bold text-sm rounded-full transition-colors border border-slate-300 dark:border-white/10 group-hover:bg-indigo-500 group-hover:text-white group-hover:border-indigo-400">
                                View Details
                                <i class="fas fa-chevron-right text-[10px]"></i>
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-20 bg-slate-50 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-2xl shadow-inner backdrop-blur-sm">
                    <div class="w-20 h-20 bg-slate-200 dark:bg-[#12141a] border border-slate-300 dark:border-white/5 rounded-full flex items-center justify-center mx-auto mb-6 shadow-lg">
                        <i class="fas fa-search text-3xl text-slate-400 dark:text-slate-500"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">No projects found</h3>
                    <p class="text-slate-500 dark:text-slate-400 mb-8 max-w-sm mx-auto">Try adjusting your filters or search terms to find what you're looking for.</p>
                    @if (User.IsInRole("Client"))
                    {
                        <a asp-action="Create" class="inline-flex items-center gap-2 px-8 py-3 bg-indigo-500 hover:bg-indigo-400 text-white font-bold rounded-full transition-all shadow-[0_0_20px_rgba(99,102,241,0.3)] hover:shadow-[0_0_25px_rgba(99,102,241,0.5)]">
                            Post a Project
                            <i class="fas fa-arrow-right text-sm"></i>
                        </a>
                    }
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="flex items-center justify-center gap-2 mt-8">
                <a class="w-10 h-10 flex items-center justify-center border border-slate-300 dark:border-white/10 rounded-full text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-all @(Model.HasPreviousPage ? "" : "opacity-50 cursor-not-allowed")" 
                   asp-action="Index" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-categoryId="@ViewBag.CategoryId" asp-route-searchTerm="@ViewBag.SearchTerm">
                    <i class="fas fa-chevron-left text-xs"></i>
                </a>
                
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a class="w-10 h-10 flex items-center justify-center rounded-full font-bold transition-all text-sm @(i == Model.PageNumber ? "bg-indigo-500 text-white shadow-[0_0_15px_rgba(99,102,241,0.4)]" : "border border-slate-300 dark:border-white/5 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5")" 
                       asp-action="Index" asp-route-pageNumber="@i" asp-route-categoryId="@ViewBag.CategoryId" asp-route-searchTerm="@ViewBag.SearchTerm">@i</a>
                }
                
                <a class="w-10 h-10 flex items-center justify-center border border-slate-300 dark:border-white/10 rounded-full text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-all @(Model.HasNextPage ? "" : "opacity-50 cursor-not-allowed")" 
                   asp-action="Index" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-categoryId="@ViewBag.CategoryId" asp-route-searchTerm="@ViewBag.SearchTerm">
                    <i class="fas fa-chevron-right text-xs"></i>
                </a>
            </div>
        }
    </div>
</div>