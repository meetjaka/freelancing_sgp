@{
    ViewData["Title"] = "Settings";
}

<!-- Page Header -->
<div class="mb-8">
    <h1 class="text-3xl font-bold text-white mb-1">Settings <span class="text-indigo-400">✦</span></h1>
    <p class="text-slate-400">Manage your account preferences and security</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
    <!-- Settings Sidebar -->
    <div class="lg:col-span-1">
        <div class="bento-card overflow-hidden sticky top-24 p-2">
            <nav class="flex flex-col space-y-1">
                <a href="#account" class="settings-tab active flex items-center gap-3 px-4 py-3 bg-indigo-500/10 text-indigo-400 border-l-4 border-indigo-500 rounded-r-lg transition-colors" data-tab="account">
                    <i class="far fa-user"></i>
                    <span class="font-bold text-sm">Account</span>
                </a>
                <a href="#security" class="settings-tab flex items-center gap-3 px-4 py-3 text-slate-400 hover:text-white hover:bg-white/5 border-l-4 border-transparent hover:border-indigo-500 rounded-r-lg transition-colors" data-tab="security">
                    <i class="fas fa-shield-alt"></i>
                    <span class="font-bold text-sm">Security</span>
                </a>
                <a href="#notifications" class="settings-tab flex items-center gap-3 px-4 py-3 text-slate-400 hover:text-white hover:bg-white/5 border-l-4 border-transparent hover:border-indigo-500 rounded-r-lg transition-colors" data-tab="notifications">
                    <i class="far fa-bell"></i>
                    <span class="font-bold text-sm">Notifications</span>
                </a>
                <a href="#privacy" class="settings-tab flex items-center gap-3 px-4 py-3 text-slate-400 hover:text-white hover:bg-white/5 border-l-4 border-transparent hover:border-indigo-500 rounded-r-lg transition-colors" data-tab="privacy">
                    <i class="fas fa-lock"></i>
                    <span class="font-bold text-sm">Privacy</span>
                </a>
                <a href="#billing" class="settings-tab flex items-center gap-3 px-4 py-3 text-slate-400 hover:text-white hover:bg-white/5 border-l-4 border-transparent hover:border-indigo-500 rounded-r-lg transition-colors" data-tab="billing">
                    <i class="fas fa-credit-card"></i>
                    <span class="font-bold text-sm">Billing</span>
                </a>
            </nav>
        </div>
    </div>

    <!-- Settings Content -->
    <div class="lg:col-span-3">
        <!-- Account Settings -->
        <div class="settings-panel" id="account">
            <div class="bento-card p-6 mb-6">
                <h3 class="text-lg font-bold text-white mb-6">Account Information</h3>
                <form class="space-y-5">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">First Name</label>
                            <input type="text" class="w-full px-4 py-2.5 bg-[#12141a] border border-white/10 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/50 backdrop-blur-sm shadow-inner" value="@User.Identity?.Name">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-300 mb-2">Last Name</label>
                            <input type="text" class="w-full px-4 py-2.5 bg-[#12141a] border border-white/10 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/50 backdrop-blur-sm shadow-inner" value="User">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-2">Email Address</label>
                        <input type="email" class="w-full px-4 py-2.5 bg-[#12141a] border border-white/10 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/50 backdrop-blur-sm shadow-inner" value="@User.Identity?.Name@@example.com">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-2">Phone Number</label>
                        <input type="tel" class="w-full px-4 py-2.5 bg-[#12141a] border border-white/10 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/50 backdrop-blur-sm shadow-inner" placeholder="+1 (555) 000-0000">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-2">Bio</label>
                        <textarea class="w-full px-4 py-2.5 bg-[#12141a] border border-white/10 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/50 resize-none backdrop-blur-sm shadow-inner" rows="4" placeholder="Tell us about yourself..."></textarea>
                    </div>
                    <button type="submit" class="px-6 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-bold rounded-lg transition-all shadow-[0_0_20px_rgba(99,102,241,0.3)]">
                        Save Changes
                    </button>
                </form>
            </div>
        </div>

        <!-- Security Settings -->
        <div class="settings-panel hidden" id="security">
            <div class="bento-card p-6 mb-6">
                <h3 class="text-lg font-bold text-white mb-6">Change Password</h3>
                <form class="space-y-5">
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-2">Current Password</label>
                        <input type="password" class="w-full px-4 py-2.5 bg-[#12141a] border border-white/10 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/50 backdrop-blur-sm shadow-inner">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-2">New Password</label>
                        <input type="password" class="w-full px-4 py-2.5 bg-[#12141a] border border-white/10 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/50 backdrop-blur-sm shadow-inner">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-2">Confirm New Password</label>
                        <input type="password" class="w-full px-4 py-2.5 bg-[#12141a] border border-white/10 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/50 backdrop-blur-sm shadow-inner">
                    </div>
                    <button type="submit" class="px-6 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-bold rounded-lg transition-all shadow-[0_0_20px_rgba(99,102,241,0.3)]">
                        Update Password
                    </button>
                </form>
            </div>

            <div class="bento-card p-6">
                <h3 class="text-lg font-bold text-white mb-2">Two-Factor Authentication</h3>
                <p class="text-sm text-slate-400 mb-4">Add an extra layer of security to your account</p>
                <button class="px-6 py-2.5 border border-indigo-500 text-indigo-400 font-bold rounded-lg hover:bg-indigo-500 hover:text-white transition-colors">
                    Enable 2FA
                </button>
            </div>
        </div>

        <!-- Notification Settings -->
        <div class="settings-panel hidden" id="notifications">
            <div class="bento-card p-6">
                <h3 class="text-lg font-bold text-white mb-6">Notification Preferences</h3>
                <div class="space-y-4 mb-6">
                    <label class="flex items-center justify-between p-4 bg-white/5 rounded-lg cursor-pointer hover:bg-white/10 transition-colors">
                        <div>
                            <span class="font-medium text-white block">Email Notifications</span>
                            <span class="text-sm text-slate-400">Receive updates via email</span>
                        </div>
                        <input type="checkbox" checked class="w-5 h-5 text-indigo-600 rounded focus:ring-indigo-500">
                    </label>
                    <label class="flex items-center justify-between p-4 bg-white/5 rounded-lg cursor-pointer hover:bg-white/10 transition-colors">
                        <div>
                            <span class="font-medium text-white block">New Project Alerts</span>
                            <span class="text-sm text-slate-400">Get notified about new projects</span>
                        </div>
                        <input type="checkbox" checked class="w-5 h-5 text-indigo-600 rounded focus:ring-indigo-500">
                    </label>
                    <label class="flex items-center justify-between p-4 bg-white/5 rounded-lg cursor-pointer hover:bg-white/10 transition-colors">
                        <div>
                            <span class="font-medium text-white block">Message Notifications</span>
                            <span class="text-sm text-slate-400">Notifications for new messages</span>
                        </div>
                        <input type="checkbox" checked class="w-5 h-5 text-indigo-600 rounded focus:ring-indigo-500">
                    </label>
                    <label class="flex items-center justify-between p-4 bg-white/5 rounded-lg cursor-pointer hover:bg-white/10 transition-colors">
                        <div>
                            <span class="font-medium text-white block">Bid Updates</span>
                            <span class="text-sm text-slate-400">Updates on your bids</span>
                        </div>
                        <input type="checkbox" class="w-5 h-5 text-indigo-600 rounded focus:ring-indigo-500">
                    </label>
                </div>
                <button type="submit" class="px-6 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-bold rounded-lg transition-all shadow-[0_0_20px_rgba(99,102,241,0.3)]">
                    Save Preferences
                </button>
            </div>
        </div>

        <!-- Privacy Settings -->
        <div class="settings-panel hidden" id="privacy">
            <div class="bento-card p-6">
                <h3 class="text-lg font-bold text-white mb-6">Privacy Settings</h3>
                <div class="space-y-4 mb-6">
                    <label class="flex items-center justify-between p-4 bg-white/5 rounded-lg cursor-pointer hover:bg-white/10 transition-colors">
                        <div>
                            <span class="font-medium text-white block">Public Profile</span>
                            <span class="text-sm text-slate-400">Make your profile visible to everyone</span>
                        </div>
                        <input type="checkbox" checked class="w-5 h-5 text-indigo-600 rounded focus:ring-indigo-500">
                    </label>
                    <label class="flex items-center justify-between p-4 bg-white/5 rounded-lg cursor-pointer hover:bg-white/10 transition-colors">
                        <div>
                            <span class="font-medium text-white block">Show Email</span>
                            <span class="text-sm text-slate-400">Display email on your profile</span>
                        </div>
                        <input type="checkbox" class="w-5 h-5 text-indigo-600 rounded focus:ring-indigo-500">
                    </label>
                    <label class="flex items-center justify-between p-4 bg-white/5 rounded-lg cursor-pointer hover:bg-white/10 transition-colors">
                        <div>
                            <span class="font-medium text-white block">Show Portfolio</span>
                            <span class="text-sm text-slate-400">Display your completed projects</span>
                        </div>
                        <input type="checkbox" checked class="w-5 h-5 text-indigo-600 rounded focus:ring-indigo-500">
                    </label>
                </div>
                <button type="submit" class="px-6 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-bold rounded-lg transition-all shadow-[0_0_20px_rgba(99,102,241,0.3)]">
                    Save Settings
                </button>
            </div>
        </div>

        <!-- Billing Settings -->
        <div class="settings-panel hidden" id="billing">
            <div class="bento-card p-6 mb-6">
                <h3 class="text-lg font-bold text-white mb-6">Payment Methods</h3>
                <div class="bg-indigo-500/10 border border-indigo-500/20 rounded-lg p-4 mb-4 flex items-center gap-3">
                    <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <span class="text-sm text-indigo-300">No payment methods added yet</span>
                </div>
                <button class="inline-flex items-center gap-2 px-6 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-bold rounded-lg transition-all shadow-[0_0_20px_rgba(99,102,241,0.3)]">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    Add Payment Method
                </button>
            </div>

            <div class="bento-card p-6">
                <h3 class="text-lg font-bold text-white mb-4">Billing History</h3>
                <p class="text-slate-400">No billing history available</p>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const tabs = document.querySelectorAll('.settings-tab');
        const panels = document.querySelectorAll('.settings-panel');
        
        tabs.forEach(tab => {
            tab.addEventListener('click', function(e) {
                e.preventDefault();
                const targetId = this.getAttribute('data-tab');
                
                // Remove active from all tabs
                tabs.forEach(t => {
                    t.classList.remove('active', 'bg-indigo-50', 'dark:bg-indigo-900/20', 'text-indigo-600', 'dark:text-indigo-400', 'border-indigo-600');
                    t.classList.add('text-slate-700', 'dark:text-slate-300', 'border-transparent');
                });
                
                // Add active to clicked tab
                this.classList.remove('text-slate-700', 'dark:text-slate-300', 'border-transparent');
                this.classList.add('active', 'bg-indigo-50', 'dark:bg-indigo-900/20', 'text-indigo-600', 'dark:text-indigo-400', 'border-indigo-600');
                
                // Hide all panels
                panels.forEach(p => p.classList.add('hidden'));
                // Show target panel
                document.getElementById(targetId).classList.remove('hidden');
            });
        });
    });
</script>
