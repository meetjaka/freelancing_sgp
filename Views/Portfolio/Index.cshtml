@model List<PortfolioDto>
@using SGP_Freelancing.Models.DTOs;
@{
    ViewData["Title"] = "Freelancer Portfolios";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<!-- Portfolio Index/Browse Page -->
<div class="h-full">
    <!-- Hero Section / Header -->
    <div class="mb-10 bento-card p-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 overflow-visible z-10 relative">
        <div class="wave-bg"></div>
        <div class="relative z-10">
            <p class="text-indigo-400 font-medium tracking-wider text-sm uppercase mb-2">Showcase</p>
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-2 tracking-tight">
                Freelancer Portfolios <span class="text-indigo-400 text-3xl">✦</span>
            </h1>
            <p class="text-slate-400 text-lg">
                Explore the best work samples and case studies from our top-rated freelancers
            </p>
            @if (User.IsInRole("Freelancer"))
            {
                <div class="mt-6">
                    <button onclick="document.getElementById('createPortfolioModal').classList.remove('hidden')" class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-500 hover:bg-indigo-400 text-white font-bold rounded-full transition-all shadow-[0_0_20px_rgba(99,102,241,0.3)] hover:shadow-[0_0_25px_rgba(99,102,241,0.5)]">
                        <i class="fas fa-plus"></i>
                        Build My Portfolio
                    </button>
                    <button onclick="document.getElementById('managePortfolioModal').classList.remove('hidden')" class="ml-3 inline-flex items-center gap-2 px-6 py-3 bg-white/10 hover:bg-white/20 text-white font-bold rounded-full transition-all backdrop-blur-sm">
                        <i class="fas fa-briefcase"></i>
                        Manage
                    </button>
                </div>
            }
        </div>
        <div class="hidden md:block relative z-10">
            <div class="w-32 h-32 bg-indigo-500/10 border border-indigo-500/20 rounded-full flex items-center justify-center shadow-[0_0_30px_rgba(99,102,241,0.15)] backdrop-blur-sm">
                <i class="fas fa-images text-indigo-400 text-5xl"></i>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="w-full">
        <!-- Alerts -->
        @if (TempData["Success"] != null)
        {
            <div class="bg-emerald-500/10 border border-emerald-500/20 p-4 rounded-2xl mb-8 animate-slide-in backdrop-blur-md">
                <div class="flex items-center">
                    <i class="fas fa-check-circle text-emerald-400 text-2xl mr-3"></i>
                    <p class="text-emerald-400 font-medium">@TempData["Success"]</p>
                </div>
            </div>
        }

        <!-- Empty State -->
        @if (Model == null || Model.Count == 0)
        {
            <div class="bento-card p-16 text-center flex flex-col items-center justify-center min-h-[400px]">
                <div class="mb-6">
                    <div class="w-28 h-28 bg-[#15171e] border border-white/5 rounded-full flex items-center justify-center mx-auto shadow-inner">
                        <i class="fas fa-briefcase text-slate-500 text-5xl"></i>
                    </div>
                </div>
                <h2 class="text-3xl font-bold text-white mb-4 tracking-tight">No Portfolios Available Yet</h2>
                <p class="text-slate-400 text-lg mb-8 max-w-md mx-auto">
                    Be the first to showcase your work! Create a portfolio to display your best projects to potential clients.
                </p>
                @if (User.IsInRole("Freelancer"))
                {
                    <a asp-action="Create" class="inline-flex items-center gap-2 px-8 py-4 bg-indigo-500 hover:bg-indigo-400 text-white font-bold rounded-full transition-all shadow-[0_0_20px_rgba(99,102,241,0.3)]">
                        <i class="fas fa-plus"></i>
                        Create Your Portfolio
                    </a>
                }
            </div>
        }
        else
        {
            <!-- Portfolio Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var portfolio in Model)
                {
                    <div class="bento-card group flex flex-col justify-between overflow-hidden relative">
                        <!-- Cover Image -->
                        <div class="relative h-48 bg-[#15171e] overflow-hidden rounded-t-3xl border-b border-white/5">
                            @if (!string.IsNullOrEmpty(portfolio.CoverImageUrl))
                            {
                                <img src="@portfolio.CoverImageUrl" 
                                     alt="@portfolio.Title"
                                     class="w-full h-full object-cover group-hover:scale-105 transition duration-500 opacity-80 group-hover:opacity-100">
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center bg-indigo-500/10 backdrop-blur-sm">
                                    <i class="fas fa-image text-indigo-500 text-5xl opacity-40"></i>
                                </div>
                            }

                            <!-- Badge -->
                            @if (portfolio.IsFeatured)
                            {
                                <div class="absolute top-4 right-4">
                                    <span class="inline-flex items-center px-3 py-1 bg-amber-500/90 backdrop-blur-md text-white font-bold rounded-full text-xs shadow-[0_0_10px_rgba(245,158,11,0.3)]">
                                        <i class="fas fa-star mr-1"></i> Featured
                                    </span>
                                </div>
                            }
                        </div>

                        <!-- Portfolio Info -->
                        <div class="p-6 flex-1 flex flex-col">
                            <!-- Freelancer Info -->
                            <div class="flex items-center mb-4">
                                <div class="w-10 h-10 bg-indigo-500/20 border border-indigo-500/30 rounded-xl flex items-center justify-center text-indigo-400 font-bold text-sm shadow-[0_0_10px_rgba(99,102,241,0.1)]">
                                    @portfolio.FreelancerName.FirstOrDefault()
                                </div>
                                <div class="ml-3 flex-1">
                                    <p class="font-bold text-white text-sm">@portfolio.FreelancerName</p>
                                    <p class="text-xs text-slate-400">Freelancer</p>
                                </div>
                            </div>

                            <!-- Title -->
                            <h3 class="text-xl font-bold text-white mb-2 line-clamp-2">
                                @portfolio.Title
                            </h3>

                            <!-- Rating -->
                            @if (portfolio.AverageRating > 0)
                            {
                                <div class="flex items-center gap-2 mb-4">
                                    <div class="flex gap-1">
                                        @for (int i = 0; i < (int)portfolio.AverageRating; i++)
                                        {
                                            <i class="fas fa-star text-amber-400 text-xs"></i>
                                        }
                                        @if (portfolio.AverageRating % 1 > 0)
                                        {
                                            <i class="fas fa-star-half-alt text-amber-400 text-xs"></i>
                                        }
                                    </div>
                                    <span class="text-xs font-bold text-slate-300">
                                        @portfolio.AverageRating.ToString("F1")
                                    </span>
                                </div>
                            }

                            <!-- Stats -->
                            <div class="flex gap-4 mb-6 text-sm text-slate-400 py-4 mt-auto border-t border-white/5">
                                <div class="flex items-center gap-1.5">
                                    <i class="fas fa-images text-indigo-400"></i>
                                    <span class="font-bold text-white">@portfolio.TotalCases</span>
                                    <span class="text-xs">Case@(portfolio.TotalCases != 1 ? "s" : "")</span>
                                </div>
                                <div class="flex items-center gap-1.5">
                                    <i class="fas fa-comments text-indigo-400"></i>
                                    <span class="font-bold text-white">@portfolio.TotalTestimonials</span>
                                    <span class="text-xs">Review@(portfolio.TotalTestimonials != 1 ? "s" : "")</span>
                                </div>
                                <div class="flex items-center gap-1.5">
                                    <i class="fas fa-eye text-indigo-400"></i>
                                    <span class="font-bold text-white">@portfolio.ViewCount</span>
                                    <span class="text-xs">Views</span>
                                </div>
                            </div>

                            <!-- View Button -->
                            <a asp-action="Details" 
                               asp-route-id="@portfolio.Id" 
                               class="w-full flex items-center justify-center gap-2 px-6 py-3 bg-[#15171e] hover:bg-white/5 border border-white/10 text-white font-bold rounded-xl transition-colors">
                                <i class="fas fa-eye"></i>
                                View Portfolio
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Manage Portfolio Modal -->
<div id="managePortfolioModal" class="hidden fixed inset-0 z-50 overflow-y-auto">
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="document.getElementById('managePortfolioModal').classList.add('hidden')"></div>
    
    <!-- Modal Content -->
    <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:p-0">
        <div class="relative inline-block align-bottom bento-card border border-white/10 rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-4xl sm:w-full max-h-[90vh] flex flex-col">
            <!-- Header -->
            <div class="px-6 py-4 border-b border-white/5 bg-[#12141a] flex justify-between items-center sticky top-0 z-10">
                <h3 class="text-xl font-bold text-white flex items-center gap-2">
                    <i class="fas fa-briefcase text-indigo-400"></i>
                    Manage My Portfolios
                </h3>
                <button onclick="document.getElementById('managePortfolioModal').classList.add('hidden')" class="text-slate-400 hover:text-white transition-colors p-2 hover:bg-white/5 rounded-full">
                    <i class="fas fa-times text-lg"></i>
                </button>
            </div>
            
            <!-- Body -->
            <div class="px-6 py-8 overflow-y-auto bg-[#0a0a0f]">
                @{
                    var myPortfolios = Model != null && User.Identity?.Name != null 
                        ? Model.Where(p => p.FreelancerName == User.Identity.Name).ToList() 
                        : new List<PortfolioDto>();
                }
                
                @if (myPortfolios.Any())
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        @foreach (var portfolio in myPortfolios)
                        {
                            <div class="bento-card p-5 group flex flex-col relative">
                                <!-- Banner -->
                                <div class="relative h-32 bg-[#15171e] rounded-xl overflow-hidden mb-4 border border-white/5">
                                    @if (!string.IsNullOrEmpty(portfolio.CoverImageUrl))
                                    {
                                        <img src="@portfolio.CoverImageUrl" alt="@portfolio.Title" class="w-full h-full object-cover">
                                    }
                                    else
                                    {
                                        <div class="w-full h-full flex items-center justify-center bg-indigo-500/10 backdrop-blur-sm">
                                            <i class="fas fa-image text-indigo-500 text-4xl opacity-40"></i>
                                        </div>
                                    }
                                </div>
                                
                                <h4 class="text-lg font-bold text-white mb-2">@portfolio.Title</h4>
                                <p class="text-sm text-slate-400 mb-4 line-clamp-2">@portfolio.Description</p>
                                
                                <div class="mt-auto flex items-center justify-between border-t border-white/5 pt-4">
                                    <div class="flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@portfolio.Id" class="px-3 py-1.5 bg-indigo-500/10 hover:bg-indigo-500/20 text-indigo-400 rounded-lg text-sm font-bold transition-colors">
                                            <i class="fas fa-edit mr-1"></i> Edit
                                        </a>
                                        <a asp-action="Details" asp-route-id="@portfolio.Id" class="px-3 py-1.5 bg-white/5 hover:bg-white/10 text-white rounded-lg text-sm font-bold transition-colors">
                                            <i class="fas fa-eye mr-1"></i> View
                                        </a>
                                    </div>
                                    <form asp-action="Delete" asp-route-id="@portfolio.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this portfolio?');">
                                        <button type="submit" class="p-1.5 text-slate-500 hover:text-red-400 hover:bg-red-400/10 rounded-lg transition-colors">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-12">
                        <div class="w-20 h-20 bg-indigo-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="fas fa-folder-open text-3xl text-indigo-400"></i>
                        </div>
                        <h4 class="text-xl font-bold text-white mb-2">No Portfolios Found</h4>
                        <p class="text-slate-400 mb-6">You haven't created any portfolios yet.</p>
                        <button onclick="document.getElementById('managePortfolioModal').classList.add('hidden'); document.getElementById('createPortfolioModal').classList.remove('hidden');" class="px-6 py-2.5 bg-indigo-500 text-white rounded-xl font-bold hover:bg-indigo-400 transition-colors">
                            Create Your First Portfolio
                        </button>
                    </div>
                }
            </div>
            
            <!-- Footer -->
            <div class="px-6 py-4 border-t border-white/5 bg-[#12141a] flex justify-end gap-3 rounded-b-2xl sticky bottom-0">
                <button type="button" onclick="document.getElementById('managePortfolioModal').classList.add('hidden')" class="px-6 py-2.5 text-sm font-bold text-slate-300 hover:text-white hover:bg-white/5 rounded-xl transition-all">
                    Close
                </button>
            </div>
        </div>
        </div>
    </div>
</div>

<!-- Create Portfolio Modal -->
<div id="createPortfolioModal" class="hidden fixed inset-0 z-50 overflow-y-auto">
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="document.getElementById('createPortfolioModal').classList.add('hidden')"></div>
    
    <!-- Modal Content -->
    <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:p-0">
        <div class="relative inline-block align-bottom bento-card border border-white/10 rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-3xl sm:w-full max-h-[90vh] flex flex-col">
            <!-- Header -->
            <div class="px-6 py-4 border-b border-white/5 bg-[#12141a] flex justify-between items-center sticky top-0 z-10">
                <h3 class="text-xl font-bold text-white flex items-center gap-2">
                    <i class="fas fa-plus-circle text-indigo-400"></i>
                    Create Your Portfolio
                </h3>
                <button onclick="document.getElementById('createPortfolioModal').classList.add('hidden')" class="text-slate-400 hover:text-white transition-colors p-2 hover:bg-white/5 rounded-full">
                    <i class="fas fa-times text-lg"></i>
                </button>
            </div>
            
            <!-- Body -->
            <div class="px-6 py-8 overflow-y-auto bg-[#0a0a0f]">
                <!-- Provide a dummy model since this is in the index page -->
                <form asp-action="Create" method="post" class="space-y-6">
                    <!-- Portfolio Title -->
                    <div>
                        <label for="Title" class="flex items-center text-sm font-bold text-slate-300 mb-2">
                            <i class="fas fa-heading text-indigo-500 mr-2"></i>
                            Portfolio Title
                            <span class="text-rose-500 ml-1">*</span>
                        </label>
                        <input name="Title" id="Title"
                               class="w-full px-4 py-3 bg-[#15171e] text-white border-2 border-white/5 rounded-xl focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition duration-300 text-sm" 
                               placeholder="e.g., Professional Web Designer &amp; Developer" 
                               required>
                    </div>

                    <!-- Description -->
                    <div>
                        <label for="Description" class="flex items-center text-sm font-bold text-slate-300 mb-2">
                            <i class="fas fa-align-left text-indigo-500 mr-2"></i>
                            Short Description
                        </label>
                        <textarea name="Description" id="Description"
                                  class="w-full px-4 py-3 bg-[#15171e] text-white border-2 border-white/5 rounded-xl focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition duration-300 resize-none text-sm" 
                                  rows="3"
                                  placeholder="A brief overview of your portfolio and expertise..."></textarea>
                    </div>

                    <!-- Detailed Bio -->
                    <div>
                        <label for="DetailedBio" class="flex items-center text-sm font-bold text-slate-300 mb-2">
                            <i class="fas fa-file-alt text-indigo-500 mr-2"></i>
                            Detailed Bio
                        </label>
                        <textarea name="DetailedBio" id="DetailedBio"
                                  class="w-full px-4 py-3 bg-[#15171e] text-white border-2 border-white/5 rounded-xl focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition duration-300 resize-none text-sm" 
                                  rows="5"
                                  placeholder="Tell your story... Highlight your experience, skills, approach, and what sets you apart..."></textarea>
                    </div>

                    <!-- Visibility Section -->
                    <div class="bg-indigo-500/5 border border-indigo-500/20 rounded-xl p-5">
                        <div class="flex items-center">
                            <input name="IsPublic" 
                                   type="checkbox" 
                                   value="true"
                                   id="isPublic" 
                                   class="w-5 h-5 bg-[#15171e] border border-white/10 text-indigo-500 rounded focus:ring-indigo-500 cursor-pointer"
                                   checked>
                            <label for="isPublic" class="ml-3 flex-1 cursor-pointer">
                                <span class="font-semibold text-white">Make portfolio public</span>
                                <p class="text-slate-400 text-xs mt-0.5">Visible to all clients browsing portfolios on the platform</p>
                            </label>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="flex gap-4 pt-4 border-t border-white/5">
                        <button type="submit" class="flex-1 flex items-center justify-center px-6 py-3 bg-indigo-500 hover:bg-indigo-400 text-white font-bold rounded-xl shadow-[0_0_20px_rgba(99,102,241,0.3)] transition-all">
                            <i class="fas fa-check-circle mr-2"></i>
                            Create Portfolio
                        </button>
                        <button type="button" onclick="document.getElementById('createPortfolioModal').classList.add('hidden')" class="flex-1 flex items-center justify-center px-6 py-3 border border-white/10 text-slate-300 hover:text-white hover:bg-white/5 font-bold rounded-xl transition-all">
                            <i class="fas fa-times mr-2"></i>
                            Cancel
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    /* Chart/Wave Graphic Mockup reused from index */
    .wave-bg {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 50%;
        background: linear-gradient(to top, rgba(99, 102, 241, 0.1), transparent);
        mask-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 100 20" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"><path d="M0,20 C30,10 70,30 100,0 L100,20 Z" fill="black"/></svg>');
        -webkit-mask-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 100 20" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"><path d="M0,20 C30,10 70,30 100,0 L100,20 Z" fill="black"/></svg>');
        mask-size: 100% 100%;
        -webkit-mask-size: 100% 100%;
        opacity: 0.5;
        pointer-events: none;
        z-index: 0;
    }

    @@keyframes slide-in {
        from {
            transform: translateX(-100%);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
    
    .animate-slide-in {
        animation: slide-in 0.3s ease-out;
    }
    
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>