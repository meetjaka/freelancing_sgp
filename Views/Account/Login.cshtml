@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 bg-slate-50 dark:bg-[#05050A] transition-colors duration-500 relative overflow-hidden">
    
    <!-- Ambient Glow -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full bg-indigo-500/10 dark:bg-indigo-600/10 blur-[100px] mix-blend-screen"></div>
        <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] rounded-full bg-purple-500/10 dark:bg-purple-600/10 blur-[120px] mix-blend-screen"></div>
        <!-- Ambient Grid -->
        <div class="absolute inset-0 opacity-[0.02] dark:opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 50px 50px;"></div>
    </div>

    <div class="max-w-md w-full z-10 relative">
        <!-- Card -->
        <div class="bg-white dark:bg-[#0f0f13]/80 backdrop-blur-xl rounded-[2.5rem] shadow-2xl dark:shadow-indigo-500/5 p-8 border border-slate-200 dark:border-white/10 transition-colors duration-500">
            <!-- Header -->
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl mb-6 shadow-lg shadow-indigo-500/30 ring-1 ring-white/20">
                    <i class="fas fa-handshake text-white text-2xl"></i>
                </div>
                <h2 class="text-3xl font-black text-slate-900 dark:text-white mb-2 tracking-tight">Welcome Back!</h2>
                <p class="text-slate-500 dark:text-slate-400 font-medium tracking-wide">Sign in to continue to your account</p>
            </div>

            <form asp-action="Login" method="post" class="space-y-6">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="bg-rose-50 dark:bg-rose-500/10 border border-rose-200 dark:border-rose-500/20 text-rose-700 dark:text-rose-400 px-4 py-3 rounded-2xl text-sm font-medium" role="alert"></div>
                }
                
                <!-- Email Field -->
                <div>
                    <label for="email" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Email Address</label>
                    <div class="relative group border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 rounded-2xl focus-within:ring-2 focus-within:ring-indigo-500/50 focus-within:border-indigo-500 transition-all">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fas fa-envelope text-slate-400 dark:text-slate-500 group-focus-within:text-indigo-500 transition-colors"></i>
                        </div>
                        <input type="email" id="email" name="Email" 
                               class="w-full pl-11 pr-4 py-3.5 bg-transparent border-none text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-0 transition-all font-medium" 
                               placeholder="Enter your email" required>
                    </div>
                </div>

                <!-- Password Field -->
                <div>
                    <label for="password" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Password</label>
                    <div class="relative group border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 rounded-2xl focus-within:ring-2 focus-within:ring-indigo-500/50 focus-within:border-indigo-500 transition-all">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fas fa-lock text-slate-400 dark:text-slate-500 group-focus-within:text-indigo-500 transition-colors"></i>
                        </div>
                        <input type="password" id="password" name="Password" 
                               class="w-full pl-11 pr-4 py-3.5 bg-transparent border-none text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-0 transition-all font-medium" 
                               placeholder="Enter your password" required>
                    </div>
                </div>

                <!-- Remember & Forgot -->
                <div class="flex items-center justify-between mt-6">
                    <label class="flex items-center cursor-pointer group">
                        <input type="checkbox" name="RememberMe" class="w-4.5 h-4.5 text-indigo-600 border-slate-300 dark:border-slate-600 rounded bg-slate-50 dark:bg-white/5 focus:ring-indigo-500/50 focus:ring-offset-0 dark:focus:ring-offset-0 transition-all">
                        <span class="ml-2.5 text-sm font-medium text-slate-600 dark:text-slate-400 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">Remember me</span>
                    </label>
                    <a href="#" class="text-sm font-bold text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors">Forgot password?</a>
                </div>

                <!-- Submit Button -->
                <button type="submit" 
                        class="w-full py-4 px-4 bg-indigo-600 hover:bg-indigo-500 text-white font-bold text-lg rounded-2xl hover:shadow-xl hover:shadow-indigo-500/30 hover:-translate-y-0.5 transition-all duration-300 flex items-center justify-center gap-2 mt-8">
                    <i class="fas fa-sign-in-alt"></i> Sign In
                </button>

                <!-- Sign Up Link -->
                <p class="text-center mt-6 text-slate-600 dark:text-slate-400 font-medium">
                    Don't have an account? 
                    <a asp-action="Register" class="font-bold text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors ml-1">Sign Up</a>
                </p>
            </form>

            <!-- Social Login -->
            <div class="mt-8 pt-8 border-t border-slate-200 dark:border-white/10">
                <p class="text-center text-slate-500 dark:text-slate-400 text-sm font-bold tracking-wide uppercase mb-6">Or continue with</p>
                <div class="flex gap-4">
                    <button class="flex-1 py-3.5 px-4 border border-slate-200 dark:border-white/10 rounded-2xl hover:bg-slate-50 dark:hover:bg-white/5 transition-all duration-300 flex items-center justify-center group hover:shadow-md dark:hover:border-white/20">
                        <i class="fab fa-google text-rose-500 text-lg group-hover:scale-110 transition-transform"></i>
                    </button>
                    <button class="flex-1 py-3.5 px-4 border border-slate-200 dark:border-white/10 rounded-2xl hover:bg-slate-50 dark:hover:bg-white/5 transition-all duration-300 flex items-center justify-center group hover:shadow-md dark:hover:border-white/20">
                        <i class="fab fa-facebook-f text-blue-600 dark:text-blue-500 text-lg group-hover:scale-110 transition-transform"></i>
                    </button>
                    <button class="flex-1 py-3.5 px-4 border border-slate-200 dark:border-white/10 rounded-2xl hover:bg-slate-50 dark:hover:bg-white/5 transition-all duration-300 flex items-center justify-center group hover:shadow-md dark:hover:border-white/20">
                        <i class="fab fa-github text-slate-900 dark:text-white text-lg group-hover:scale-110 transition-transform"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
