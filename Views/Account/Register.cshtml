@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 bg-slate-50 dark:bg-[#05050A] transition-colors duration-500 relative overflow-hidden">
    
    <!-- Ambient Glow -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-0 right-1/4 w-[600px] h-[600px] rounded-full bg-indigo-500/10 dark:bg-indigo-600/10 blur-[120px] mix-blend-screen"></div>
        <div class="absolute bottom-1/4 left-1/4 w-[400px] h-[400px] rounded-full bg-purple-500/10 dark:bg-purple-600/10 blur-[100px] mix-blend-screen"></div>
        <!-- Ambient Grid -->
        <div class="absolute inset-0 opacity-[0.02] dark:opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 50px 50px;"></div>
    </div>

    <div class="max-w-lg w-full z-10 relative">
        <!-- Card -->
        <div class="bg-white dark:bg-[#0f0f13]/80 backdrop-blur-xl rounded-[2.5rem] shadow-2xl dark:shadow-indigo-500/5 p-8 sm:p-10 border border-slate-200 dark:border-white/10 transition-colors duration-500">
            <!-- Header -->
            <div class="text-center mb-10">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl mb-6 shadow-lg shadow-indigo-500/30 ring-1 ring-white/20">
                    <i class="fas fa-user-plus text-white text-2xl"></i>
                </div>
                <h2 class="text-3xl font-black text-slate-900 dark:text-white mb-2 tracking-tight">Create Account</h2>
                <p class="text-slate-500 dark:text-slate-400 font-medium tracking-wide">Join thousands of freelancers and clients</p>
            </div>

            <form asp-action="Register" method="post" class="space-y-5">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="bg-rose-50 dark:bg-rose-500/10 border border-rose-200 dark:border-rose-500/20 text-rose-700 dark:text-rose-400 px-4 py-3 rounded-2xl text-sm font-medium" role="alert"></div>
                }
                
                <!-- Name Fields -->
                <div class="grid grid-cols-2 gap-5">
                    <div>
                        <label for="firstName" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">First Name</label>
                        <div class="relative group border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 rounded-2xl focus-within:ring-2 focus-within:ring-indigo-500/50 focus-within:border-indigo-500 transition-all">
                            <input type="text" id="firstName" name="FirstName" 
                                   class="w-full px-4 py-3.5 bg-transparent border-none text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-0 transition-all font-medium" 
                                   placeholder="John" required>
                        </div>
                    </div>
                    <div>
                        <label for="lastName" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Last Name</label>
                        <div class="relative group border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 rounded-2xl focus-within:ring-2 focus-within:ring-indigo-500/50 focus-within:border-indigo-500 transition-all">
                            <input type="text" id="lastName" name="LastName" 
                                   class="w-full px-4 py-3.5 bg-transparent border-none text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-0 transition-all font-medium" 
                                   placeholder="Doe" required>
                        </div>
                    </div>
                </div>

                <!-- Email Field -->
                <div>
                    <label for="email" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Email Address</label>
                    <div class="relative group border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 rounded-2xl focus-within:ring-2 focus-within:ring-indigo-500/50 focus-within:border-indigo-500 transition-all">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fas fa-envelope text-slate-400 dark:text-slate-500 group-focus-within:text-indigo-500 transition-colors"></i>
                        </div>
                        <input type="email" id="email" name="Email" 
                               class="w-full pl-11 pr-4 py-3.5 bg-transparent border-none text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-0 transition-all font-medium" 
                               placeholder="john@example.com" required>
                    </div>
                </div>

                <!-- Password Fields -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <div>
                        <label for="password" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Password</label>
                        <div class="relative group border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 rounded-2xl focus-within:ring-2 focus-within:ring-indigo-500/50 focus-within:border-indigo-500 transition-all">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <i class="fas fa-lock text-slate-400 dark:text-slate-500 group-focus-within:text-indigo-500 transition-colors"></i>
                            </div>
                            <input type="password" id="password" name="Password" 
                                   class="w-full pl-11 pr-4 py-3.5 bg-transparent border-none text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-0 transition-all font-medium" 
                                   placeholder="Min. 6 chars" required>
                        </div>
                    </div>
                    <div>
                        <label for="confirmPassword" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Confirm</label>
                        <div class="relative group border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 rounded-2xl focus-within:ring-2 focus-within:ring-indigo-500/50 focus-within:border-indigo-500 transition-all">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <i class="fas fa-check text-slate-400 dark:text-slate-500 group-focus-within:text-emerald-500 transition-colors"></i>
                            </div>
                            <input type="password" id="confirmPassword" name="ConfirmPassword" 
                                   class="w-full pl-11 pr-4 py-3.5 bg-transparent border-none text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-0 transition-all font-medium" 
                                   placeholder="Re-enter" required>
                        </div>
                    </div>
                </div>

                <!-- Role Selection -->
                <div class="pt-2">
                    <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-3">I want to:</label>
                    <div class="grid grid-cols-2 gap-4">
                        <label class="relative cursor-pointer">
                            <input type="radio" name="Role" value="Freelancer" class="peer sr-only" checked>
                            <div class="p-4 border-2 border-slate-200 dark:border-white/10 rounded-2xl peer-checked:border-indigo-600 dark:peer-checked:border-indigo-500 peer-checked:bg-indigo-50/50 dark:peer-checked:bg-indigo-500/10 transition-all hover:border-slate-300 dark:hover:border-white/20 group">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-indigo-100 dark:bg-indigo-500/20 rounded-xl flex items-center justify-center transition-colors duration-300">
                                        <i class="fas fa-laptop-code text-indigo-600 dark:text-indigo-400 group-hover:scale-110 transition-transform"></i>
                                    </div>
                                    <div>
                                        <div class="font-bold text-slate-900 dark:text-white text-sm">Freelancer</div>
                                        <div class="text-[11px] font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mt-0.5">Work on projects</div>
                                    </div>
                                </div>
                            </div>
                        </label>
                        <label class="relative cursor-pointer">
                            <input type="radio" name="Role" value="Client" class="peer sr-only">
                            <div class="p-4 border-2 border-slate-200 dark:border-white/10 rounded-2xl peer-checked:border-purple-600 dark:peer-checked:border-purple-500 peer-checked:bg-purple-50/50 dark:peer-checked:bg-purple-500/10 transition-all hover:border-slate-300 dark:hover:border-white/20 group">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-purple-100 dark:bg-purple-500/20 rounded-xl flex items-center justify-center transition-colors duration-300">
                                        <i class="fas fa-briefcase text-purple-600 dark:text-purple-400 group-hover:scale-110 transition-transform"></i>
                                    </div>
                                    <div>
                                        <div class="font-bold text-slate-900 dark:text-white text-sm">Client</div>
                                        <div class="text-[11px] font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mt-0.5">Hire freelancers</div>
                                    </div>
                                </div>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- Terms Checkbox -->
                <div class="pt-4">
                    <label class="flex items-start cursor-pointer group">
                        <input type="checkbox" required class="w-4.5 h-4.5 mt-0.5 text-indigo-600 border-slate-300 dark:border-slate-600 rounded bg-slate-50 dark:bg-white/5 focus:ring-indigo-500/50 focus:ring-offset-0 dark:focus:ring-offset-0 transition-all">
                        <span class="ml-3 text-sm font-medium text-slate-600 dark:text-slate-400">
                            I agree to the <a href="#" class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-bold transition-colors">Terms of Service</a> and <a href="#" class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-bold transition-colors">Privacy Policy</a>
                        </span>
                    </label>
                </div>

                <!-- Submit Button -->
                <button type="submit" 
                        class="w-full py-4 px-4 mt-8 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 text-white font-bold text-lg rounded-2xl hover:shadow-xl hover:shadow-indigo-500/30 hover:-translate-y-0.5 transition-all duration-300 flex items-center justify-center gap-2">
                    <i class="fas fa-user-plus"></i> Create Account
                </button>

                <!-- Sign In Link -->
                <p class="text-center mt-6 text-slate-600 dark:text-slate-400 font-medium">
                    Already have an account? 
                    <a asp-action="Login" class="font-bold text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors ml-1">Sign In</a>
                </p>
            </form>
        </div>
    </div>
</div>
