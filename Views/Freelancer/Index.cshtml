@model SGP_Freelancing.Models.DTOs.PagedResult<SGP_Freelancing.Models.DTOs.FreelancerProfileDto>
@{
    ViewData["Title"] = "Find Freelancers";
    var skills = ViewBag.Skills as List<SGP_Freelancing.Models.Entities.Skill> ?? new List<SGP_Freelancing.Models.Entities.Skill>();
    var searchDto = ViewBag.SearchDto as SGP_Freelancing.Models.DTOs.FreelancerSearchDto ?? new SGP_Freelancing.Models.DTOs.FreelancerSearchDto();
}

<style>
    .freelancer-card {
        backdrop-filter: blur(12px);
        border-radius: 1.5rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }

    html:not(.dark) .freelancer-card {
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid rgba(0, 0, 0, 0.08);
    }

    html.dark .freelancer-card {
        background: rgba(15, 17, 21, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .freelancer-card:hover {
        transform: translateY(-8px);
    }

    html:not(.dark) .freelancer-card:hover {
        box-shadow: 0 20px 40px -10px rgba(0,0,0,0.15), 0 0 20px rgba(99, 102, 241, 0.08);
        border-color: rgba(99, 102, 241, 0.3);
    }

    html.dark .freelancer-card:hover {
        box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5), 0 0 20px rgba(99, 102, 241, 0.05);
        border-color: rgba(99, 102, 241, 0.2);
    }
</style>

<div class="container mx-auto px-6 py-8">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-2">Find Freelancers</h1>
        <p class="text-slate-600 dark:text-slate-400">Discover talented professionals for your next project</p>
    </div>

    <!-- Search and Filter Section -->
    <form method="get" asp-action="Index" class="mb-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
            <!-- Search -->
            <div>
                <input type="text" 
                       name="Search" 
                       value="@searchDto.Search" 
                       placeholder="Search by name, title, or skills..." 
                       class="w-full px-4 py-3 rounded-xl border bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:focus:ring-indigo-400" />
            </div>

            <!-- Min Rate -->
            <div>
                <input type="number" 
                       name="MinHourlyRate" 
                       value="@searchDto.MinHourlyRate" 
                       placeholder="Min hourly rate ($)" 
                       step="1"
                       class="w-full px-4 py-3 rounded-xl border bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:focus:ring-indigo-400" />
            </div>

            <!-- Max Rate -->
            <div>
                <input type="number" 
                       name="MaxHourlyRate" 
                       value="@searchDto.MaxHourlyRate" 
                       placeholder="Max hourly rate ($)" 
                       step="1"
                       class="w-full px-4 py-3 rounded-xl border bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:focus:ring-indigo-400" />
            </div>

            <!-- Sort By -->
            <div>
                <select name="SortBy" 
                        class="w-full px-4 py-3 rounded-xl border bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:focus:ring-indigo-400">
                    <option value="">Sort by: Best Match</option>
                    <option value="rating" selected="@(searchDto.SortBy == "rating")">Highest Rated</option>
                    <option value="rate-asc" selected="@(searchDto.SortBy == "rate-asc")">Lowest Rate</option>
                    <option value="rate-desc" selected="@(searchDto.SortBy == "rate-desc")">Highest Rate</option>
                    <option value="completed" selected="@(searchDto.SortBy == "completed")">Most Projects</option>
                </select>
            </div>
        </div>

        <div class="flex gap-4">
            <button type="submit" 
                    class="px-6 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-semibold rounded-xl transition-all">
                <i class="fas fa-search mr-2"></i>Search
            </button>
            <a asp-action="Index" 
               class="px-6 py-3 bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-300 font-semibold rounded-xl border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700 transition-all">
                Clear Filters
            </a>
        </div>
    </form>

    <!-- Results Count -->
    @if (Model.TotalCount > 0)
    {
        <div class="mb-6">
            <p class="text-slate-600 dark:text-slate-400">
                Found <strong class="text-slate-900 dark:text-white">@Model.TotalCount</strong> freelancer@(Model.TotalCount != 1 ? "s" : "")
            </p>
        </div>
    }

    <!-- Freelancers Grid -->
    @if (Model.Items.Any())
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
            @foreach (var freelancer in Model.Items)
            {
                <div class="freelancer-card p-6">
                    <div class="flex items-start justify-between mb-4">
                        <div class="flex items-center gap-4">
                            <div class="w-16 h-16 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white text-xl font-bold">
                                @(freelancer.Title?.Substring(0, 1).ToUpper() ?? "F")
                            </div>
                            <div>
                                <h3 class="text-lg font-bold text-slate-900 dark:text-white">@freelancer.Title</h3>
                                @if (freelancer.AverageRating > 0)
                                {
                                    <div class="flex items-center gap-1">
                                        <i class="fas fa-star text-yellow-400 text-sm"></i>
                                        <span class="text-slate-600 dark:text-slate-400 text-sm">@freelancer.AverageRating.ToString("F1")</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <p class="text-slate-600 dark:text-slate-400 text-sm mb-4 line-clamp-3">
                        @(freelancer.Bio ?? "No bio provided")
                    </p>

                    <!-- Skills -->
                    @if (freelancer.Skills != null && freelancer.Skills.Any())
                    {
                        <div class="flex flex-wrap gap-2 mb-4">
                            @foreach (var skill in freelancer.Skills.Take(4))
                            {
                                <span class="px-3 py-1 bg-indigo-100 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 text-xs rounded-full">
                                    @skill.Name
                                </span>
                            }
                            @if (freelancer.Skills.Count > 4)
                            {
                                <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs rounded-full">
                                    +@(freelancer.Skills.Count - 4) more
                                </span>
                            }
                        </div>
                    }

                    <!-- Stats -->
                    <div class="flex items-center justify-between pt-4 border-t border-slate-200 dark:border-slate-700">
                        <div>
                            <span class="text-2xl font-bold text-slate-900 dark:text-white">$@freelancer.HourlyRate.ToString("F0")</span>
                            <span class="text-slate-500 dark:text-slate-400 text-sm">/hr</span>
                        </div>
                        <a asp-action="Details" asp-route-id="@freelancer.Id" 
                           class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg transition-all">
                            View Profile
                        </a>
                    </div>

                    @if (freelancer.CompletedProjects > 0)
                    {
                        <div class="mt-2 text-xs text-slate-500 dark:text-slate-400">
                            @freelancer.CompletedProjects project@(freelancer.CompletedProjects != 1 ? "s" : "") completed
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="flex justify-center gap-2">
                @if (Model.HasPreviousPage)
                {
                    <a asp-action="Index" 
                       asp-route-search="@searchDto.Search"
                       asp-route-minHourlyRate="@searchDto.MinHourlyRate"
                       asp-route-maxHourlyRate="@searchDto.MaxHourlyRate"
                       asp-route-minRating="@searchDto.MinRating"
                       asp-route-sortBy="@searchDto.SortBy"
                       asp-route-page="@(Model.PageNumber - 1)"
                       class="px-4 py-2 bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-300 font-semibold rounded-lg border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700 transition-all">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                }

                @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                {
                    <a asp-action="Index" 
                       asp-route-search="@searchDto.Search"
                       asp-route-minHourlyRate="@searchDto.MinHourlyRate"
                       asp-route-maxHourlyRate="@searchDto.MaxHourlyRate"
                       asp-route-minRating="@searchDto.MinRating"
                       asp-route-sortBy="@searchDto.SortBy"
                       asp-route-page="@i"
                       class="px-4 py-2 @(i == Model.PageNumber ? "bg-indigo-600 text-white" : "bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-300") font-semibold rounded-lg border border-slate-200 dark:border-slate-700 hover:bg-indigo-700 hover:text-white transition-all">
                        @i
                    </a>
                }

                @if (Model.HasNextPage)
                {
                    <a asp-action="Index" 
                       asp-route-search="@searchDto.Search"
                       asp-route-minHourlyRate="@searchDto.MinHourlyRate"
                       asp-route-maxHourlyRate="@searchDto.MaxHourlyRate"
                       asp-route-minRating="@searchDto.MinRating"
                       asp-route-sortBy="@searchDto.SortBy"
                       asp-route-page="@(Model.PageNumber + 1)"
                       class="px-4 py-2 bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-300 font-semibold rounded-lg border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700 transition-all">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                }
            </div>
        }
    }
    else
    {
        <div class="text-center py-12">
            <i class="fas fa-users text-6xl text-slate-300 dark:text-slate-600 mb-4"></i>
            <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">No Freelancers Found</h3>
            <p class="text-slate-600 dark:text-slate-400 mb-4">Try adjusting your search filters</p>
            <a asp-action="Index" 
               class="inline-block px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-all">
                View All Freelancers
            </a>
        </div>
    }
</div>
